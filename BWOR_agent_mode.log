【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB
import math

# Sets
components = [1, 2, 3]
levels = [1, 2, 3]

# Parameters
r = {
    (1,1): 0.3, (1,2): 0.4, (1,3): 0.5,
    (2,1): 0.2, (2,2): 0.5, (2,3): 0.9,
    (3,1): 0.1, (3,2): 0.2, (3,3): 0.7
}

c = {
    (1,1): 1, (1,2): 2, (1,3): 3,
    (2,1): 3, (2,2): 5, (2,3): 6,
    (3,1): 2, (3,2): 3, (3,3): 4
}

B = 8  # Budget

# Create model
model = gp.Model("SparePartsOptimization")

# Decision variables
x = model.addVars(components, levels, vtype=GRB.BINARY, name="x")

# Objective: maximize sum of log reliabilities
model.setObjective(
    gp.quicksum(math.log(r[i, k]) * x[i, k] for i in components for k in levels),
    GRB.MAXIMIZE
)

# Constraint: each component selects exactly one level
for i in components:
    model.addConstr(gp.quicksum(x[i, k] for k in levels) == 1, name=f"SelectOne_{i}")

# Budget constraint
model.addConstr(
    gp.quicksum(c[i, k] * x[i, k] for i in components for k in levels) <= B,
    name="Budget"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Objective Value (Sum of Logs):", model.objVal)
    total_cost = 0
    for i in components:
        for k in levels:
            if x[i, k].X > 0.5:
                print(f"Component A{i}: {k} spare(s)")
                total_cost += c[i, k]
    print("Total Cost:", total_cost)
else:
    print("No optimal solution found.")
```
