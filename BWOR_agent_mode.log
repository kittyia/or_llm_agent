import gurobipy as gp
from gurobipy import GRB

# Sets
projects = ['A', 'B', 'C']
levels = [0, 1, 2, 3, 4]

# Parameters: benefits (thousand yuan)
benefits = {
    'A': [0, 41, 48, 60, 66],
    'B': [0, 42, 50, 60, 66],
    'C': [0, 64, 68, 78, 76]
}

budget = 4  # total available investment (thousand yuan)

# Create model
model = gp.Model("Investment_Allocation")

# Decision variables: x[i,k] = 1 if project i receives k thousand yuan
x = model.addVars(projects, levels, vtype=GRB.BINARY, name="x")

# Objective function: maximize total benefit
model.setObjective(
    gp.quicksum(benefits[i][k] * x[i, k] for i in projects for k in levels),
    GRB.MAXIMIZE
)

# Constraint 1: total budget equals 4
model.addConstr(
    gp.quicksum(k * x[i, k] for i in projects for k in levels) == budget,
    name="Budget"
)

# Constraint 2: each project selects exactly one investment level
for i in projects:
    model.addConstr(
        gp.quicksum(x[i, k] for k in levels) == 1,
        name=f"SelectOne_{i}"
    )

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total benefit: {model.objVal:.0f} (thousand yuan)")
    print("Optimal investment allocation:")
    for i in projects:
        for k in levels:
            if x[i, k].x > 0.5:
                print(f"  Project {i}: {k} thousand yuan")
else:
    print("No optimal solution found.")
```
