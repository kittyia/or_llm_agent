【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
products = [1, 2, 3]
quarters = [1, 2, 3, 4]

# Parameters
D = {
    (1,1):1500, (1,2):1000, (1,3):2000, (1,4):1200,
    (2,1):1500, (2,2):1500, (2,3):1200, (2,4):1500,
    (3,1):1000, (3,2):2000, (3,3):1500, (3,4):2500
}

a = {1:2, 2:4, 3:3}
H = 15000
p = {1:20, 2:20, 3:10}
h = 5

# Create model
model = gp.Model("Production_Planning")

# Decision variables
x = model.addVars(products, quarters, lb=0, name="x")
I = model.addVars(products, quarters, lb=0, name="I")
B = model.addVars(products, quarters, lb=0, name="B")

# Objective function
model.setObjective(
    gp.quicksum(h * I[i,t] + p[i] * B[i,t] for i in products for t in quarters),
    GRB.MINIMIZE
)

# Inventory–Backlog balance constraints
for i in products:
    for t in quarters:
        if t == 1:
            model.addConstr(
                I[i,t] - B[i,t] == x[i,t] - D[i,t],
                name=f"balance_{i}_{t}"
            )
        else:
            model.addConstr(
                I[i,t] - B[i,t] ==
                I[i,t-1] - B[i,t-1] + x[i,t] - D[i,t],
                name=f"balance_{i}_{t}"
            )

# Capacity constraints
for t in quarters:
    model.addConstr(
        gp.quicksum(a[i] * x[i,t] for i in products) <= H,
        name=f"capacity_{t}"
    )

# Production restriction: product 1 cannot be produced in Q2
model.addConstr(x[1,2] == 0, name="prod_restrict_1_2")

# Ending inventory requirements
for i in products:
    model.addConstr(I[i,4] == 150, name=f"ending_inventory_{i}")
    model.addConstr(B[i,4] == 0, name=f"ending_backlog_{i}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Objective Value: {model.objVal}\n")
    for t in quarters:
        print(f"Quarter {t}:")
        for i in products:
            print(f"  Product {i}: "
                  f"Production = {x[i,t].x:.2f}, "
                  f"Inventory = {I[i,t].x:.2f}, "
                  f"Backlog = {B[i,t].x:.2f}")
        print()
else:
    print("No optimal solution found.")
```
