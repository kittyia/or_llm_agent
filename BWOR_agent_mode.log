import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Sets
# -----------------------------
months = range(1, 13)
products = [1, 2]

# -----------------------------
# Parameters
# -----------------------------
# Demand
d = {}
for t in months:
    # Product 1
    if 1 <= t <= 4:
        d[1, t] = 10000
    elif 5 <= t <= 9:
        d[1, t] = 30000
    else:
        d[1, t] = 100000

    # Product 2
    if 3 <= t <= 9:
        d[2, t] = 15000
    else:
        d[2, t] = 50000

# Production cost
c = {}
for t in months:
    # Product 1
    if 1 <= t <= 5:
        c[1, t] = 5
    else:
        c[1, t] = 4.5

    # Product 2
    if 1 <= t <= 5:
        c[2, t] = 8
    else:
        c[2, t] = 7

# Volume per unit
v = {1: 0.2, 2: 0.4}

# Capacities and costs
production_capacity = 120000
warehouse_capacity = 15000
internal_storage_cost = 1
external_storage_cost = 1.5

# -----------------------------
# Model
# -----------------------------
model = gp.Model("Production_Planning_With_External_Warehouse")

# Decision variables
x = model.addVars(products, months, lb=0, name="Production")
I = model.addVars(products, months, lb=0, name="Inventory")
V_in = model.addVars(months, lb=0, name="InternalVolume")
V_out = model.addVars(months, lb=0, name="ExternalVolume")

# -----------------------------
# Constraints
# -----------------------------

# Inventory balance
for i in products:
    for t in months:
        if t == 1:
            model.addConstr(
                x[i, t] - d[i, t] == I[i, t],
                name=f"InventoryBalance_{i}_{t}"
            )
        else:
            model.addConstr(
                I[i, t-1] + x[i, t] - d[i, t] == I[i, t],
                name=f"InventoryBalance_{i}_{t}"
            )

# End-of-horizon inventory equals zero
for i in products:
    model.addConstr(I[i, 12] == 0, name=f"EndingInventory_{i}")

# Production capacity
for t in months:
    model.addConstr(
        x[1, t] + x[2, t] <= production_capacity,
        name=f"ProductionCapacity_{t}"
    )

# Storage volume balance
for t in months:
    model.addConstr(
        v[1] * I[1, t] + v[2] * I[2, t] == V_in[t] + V_out[t],
        name=f"VolumeBalance_{t}"
    )

# Internal warehouse capacity
for t in months:
    model.addConstr(
        V_in[t] <= warehouse_capacity,
        name=f"InternalCapacity_{t}"
    )

# -----------------------------
# Objective Function
# -----------------------------
model.setObjective(
    gp.quicksum(
        c[i, t] * x[i, t]
        for i in products for t in months
    )
    + gp.quicksum(
        internal_storage_cost * V_in[t]
        + external_storage_cost * V_out[t]
        for t in months
    ),
    GRB.MINIMIZE
)

# -----------------------------
# Solve
# -----------------------------
model.optimize()

# -----------------------------
# Output Results
# -----------------------------
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {model.objVal:.2f}\n")

    print("Production Plan:")
    for t in months:
        for i in products:
            print(f"Month {t}, Product {i}, Production: {x[i,t].x:.2f}")
        print()

    print("Inventory Plan:")
    for t in months:
        for i in products:
            print(f"Month {t}, Product {i}, Inventory: {I[i,t].x:.2f}")
        print()

    print("Warehouse Usage:")
    for t in months:
        print(f"Month {t}, Internal Volume: {V_in[t].x:.2f}, External Volume: {V_out[t].x:.2f}")
else:
    print("No optimal solution found.")
```
