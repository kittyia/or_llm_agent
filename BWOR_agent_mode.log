【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
students = range(6)  # 0-5 represent students 1-6
days = range(5)      # 0-4 represent Mon-Fri

undergraduates = {0, 1, 2, 3}
graduates = {4, 5}

# Parameters
wage = [10.0, 10.0, 9.9, 9.8, 10.8, 11.3]

availability = [
    [6, 0, 9, 0, 7],  # Student 1
    [0, 9, 0, 6, 0],  # Student 2
    [4, 8, 3, 0, 5],  # Student 3
    [5, 5, 6, 0, 4],  # Student 4
    [3, 0, 4, 8, 0],  # Student 5
    [0, 9, 0, 6, 3],  # Student 6
]

min_week_hours = [8 if i in undergraduates else 7 for i in students]
daily_required_hours = 14

# Model
model = gp.Model("Computer_Lab_Scheduling")

# Decision variables
x = model.addVars(students, days, lb=0.0, name="x")

# Objective: Minimize total wage cost
model.setObjective(
    gp.quicksum(wage[i] * x[i, d] for i in students for d in days),
    GRB.MINIMIZE
)

# Daily coverage constraints
for d in days:
    model.addConstr(
        gp.quicksum(x[i, d] for i in students) == daily_required_hours,
        name=f"Coverage_day_{d+1}"
    )

# Weekly minimum hours constraints
for i in students:
    model.addConstr(
        gp.quicksum(x[i, d] for d in days) >= min_week_hours[i],
        name=f"MinWeeklyHours_student_{i+1}"
    )

# Availability constraints
for i in students:
    for d in days:
        model.addConstr(
            x[i, d] <= availability[i][d],
            name=f"Availability_s{i+1}_d{d+1}"
        )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {model.objVal:.2f}\n")
    for i in students:
        for d in days:
            if x[i, d].x > 1e-6:
                print(f"Student {i+1}, Day {d+1}: {x[i, d].x:.2f} hours")
else:
    print("No optimal solution found.")
```
