【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Ship_Production_Planning")

# Decision variables
x = model.addVars(3, lb=0, name="x")  # Normal production
y = model.addVars(3, lb=0, name="y")  # Overtime production
I = model.addVars(3, lb=0, name="I")  # Inventory

# Parameters
normal_cost = [500, 600, 550]
overtime_cost = [c + 70 for c in normal_cost]
holding_cost = 40
demand = [3, 3, 3]
initial_inventory = 2

normal_capacity = [2, 4, 1]
overtime_capacity = [3, 2, 3]

# Capacity constraints
for t in range(3):
    model.addConstr(x[t] <= normal_capacity[t], name=f"NormalCap_{t+1}")
    model.addConstr(y[t] <= overtime_capacity[t], name=f"OvertimeCap_{t+1}")

# Inventory balance constraints
model.addConstr(I[0] == initial_inventory + x[0] + y[0] - demand[0], name="InventoryBalance_1")
model.addConstr(I[1] == I[0] + x[1] + y[1] - demand[1], name="InventoryBalance_2")
model.addConstr(I[2] == I[1] + x[2] + y[2] - demand[2], name="InventoryBalance_3")

# Final inventory requirement
model.addConstr(I[2] == 1, name="FinalInventory")

# Objective function
model.setObjective(
    gp.quicksum(normal_cost[t] * x[t] + overtime_cost[t] * y[t] for t in range(3)) +
    holding_cost * (I[0] + I[1]),
    GRB.MINIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost (thousand yuan): {model.objVal}")
    for t in range(3):
        print(f"Year {t+1}:")
        print(f"  Normal Production: {x[t].x}")
        print(f"  Overtime Production: {y[t].x}")
        print(f"  End Inventory: {I[t].x}")
else:
    print("No optimal solution found.")
```
