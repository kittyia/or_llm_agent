If desired, this model can be further strengthened with valid inequalities, but for 6 jobs this formulation is already computationally efficient.
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
jobs = range(6)
positions = range(6)

A = [30, 60, 60, 20, 80, 90]
B = [70, 70, 50, 60, 30, 40]

# Model
model = gp.Model("TwoMachineFlowShop")

# Decision variables
x = model.addVars(jobs, positions, vtype=GRB.BINARY, name="x")
CA = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0.0, name="CA")
CB = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0.0, name="CB")

# Assignment constraints
for j in jobs:
    model.addConstr(gp.quicksum(x[j, k] for k in positions) == 1, name=f"AssignJob_{j}")

for k in positions:
    model.addConstr(gp.quicksum(x[j, k] for j in jobs) == 1, name=f"AssignPos_{k}")

# Machine A completion times
model.addConstr(
    CA[0] == gp.quicksum(A[j] * x[j, 0] for j in jobs),
    name="CA_0"
)

for k in positions:
    if k > 0:
        model.addConstr(
            CA[k] == CA[k - 1] + gp.quicksum(A[j] * x[j, k] for j in jobs),
            name=f"CA_{k}"
        )

# Machine B completion times
model.addConstr(
    CB[0] == CA[0] + gp.quicksum(B[j] * x[j, 0] for j in jobs),
    name="CB_0"
)

for k in positions:
    if k > 0:
        model.addConstr(
            CB[k] >= CB[k - 1] + gp.quicksum(B[j] * x[j, k] for j in jobs),
            name=f"CB1_{k}"
        )
        model.addConstr(
            CB[k] >= CA[k] + gp.quicksum(B[j] * x[j, k] for j in jobs),
            name=f"CB2_{k}"
        )

# Objective: minimize makespan
model.setObjective(CB[5], GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Makespan: {model.objVal:.2f}")
    sequence = []
    for k in positions:
        for j in jobs:
            if x[j, k].X > 0.5:
                sequence.append(j + 1)
    print("Optimal Job Sequence:", sequence)
else:
    print("No optimal solution found.")
```
