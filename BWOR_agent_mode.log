【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Timber_Storage_Optimization")

# Sets
quarters = [1, 2, 3, 4]

# Parameters
c = {1: 410, 2: 430, 3: 460, 4: 450}  # Purchase prices
p = {1: 425, 2: 440, 3: 465, 4: 455}  # Selling prices
d = {1: 100, 2: 140, 3: 200, 4: 160}  # Max sales
S = 20  # Warehouse capacity

# Storage cost function
def storage_cost(i, j):
    if j == i:
        return 0
    else:
        return 70 + 100 * (j - i)

# Decision variables: x[i,j] for i <= j
x = {}
for i in quarters:
    for j in quarters:
        if j >= i:
            x[i, j] = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name=f"x_{i}_{j}")

# Objective function
model.setObjective(
    gp.quicksum(
        (p[j] - c[i] - storage_cost(i, j)) * x[i, j]
        for i in quarters for j in quarters if j >= i
    ),
    GRB.MAXIMIZE
)

# 1. Sales constraints
for j in quarters:
    model.addConstr(
        gp.quicksum(x[i, j] for i in quarters if i <= j) <= d[j],
        name=f"Sales_Limit_Q{j}"
    )

# 2. Warehouse capacity constraints
for k in [1, 2, 3]:
    model.addConstr(
        gp.quicksum(
            x[i, j]
            for i in quarters if i <= k
            for j in quarters if j > k
        ) <= S,
        name=f"Storage_Capacity_End_Q{k}"
