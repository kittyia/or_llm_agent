import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Hanguang_Automobile_Production")

# Decision variables
x1 = model.addVar(vtype=GRB.INTEGER, lb=0, name="x1")  # Zhujiang
x2 = model.addVar(vtype=GRB.INTEGER, lb=0, name="x2")  # Songhuajiang
x3 = model.addVar(vtype=GRB.INTEGER, lb=0, name="x3")  # Huanghe

y1 = model.addVar(vtype=GRB.BINARY, name="y1")
y2 = model.addVar(vtype=GRB.BINARY, name="y2")
