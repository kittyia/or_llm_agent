【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
P = range(7)   # Products 0-6 (I-VII)
T = range(6)   # Months 0-5 (Jan-Jun)

# Parameters
profits = [100, 60, 80, 40, 110, 90, 30]
holding_cost = 5

# Demand (rows: months Jan-Jun, columns: products I-VII)
demand = [
    [500, 1000, 300, 300, 800, 200, 100],   # Jan
    [600, 500, 200, 0, 400, 300, 150],      # Feb
    [300, 600, 0, 0, 500, 400, 100],        # Mar
    [200, 300, 400, 500, 200, 0, 100],      # Apr
    [0, 100, 500, 100, 1000, 300, 0],       # May
    [500, 500, 100, 300, 1100, 500, 60]     # Jun
]

# Machine hours per unit (machines: G, U, H, B, P)
a = {
    'G': [0.5, 0.7, 0,   0,   0.3, 0.2, 0.5],
    'U': [0.1, 0.2, 0,   0.3, 0,   0.6, 0],
    'H': [0.2, 0,   0.8, 0,   0,   0,   0.6],
    'B': [0.05,0.03,0,   0.07,0.1, 0,   0.08],
    'P': [0,   0,   0.01,0,   0.05,0,   0.05]
}

# Machines available each month after maintenance
machines = {
    'G': [3,4,4,4,3,4],
    'U': [2,2,2,1,1,2],
    'H': [3,1,3,3,3,2],
    'B': [1,1,0,1,1,1],
    'P': [1,1,1,1,1,0]
}

hours_per_machine = 24 * 2 * 8  # 384 hours per month

# Model
model = gp.Model("Factory_Planning")

# Decision variables
x = model.addVars(P, T, name="Prod", lb=0)
I = model.addVars(P, T, name="Inv", lb=0)

# Objective function
revenue = gp.quicksum(
    profits[p] * (
        (0 if t == 0 else I[p, t-1]) + x[p, t] - I[p, t]
    )
    for p in P for t in T
)

holding = gp.quicksum(
    holding_cost * I[p, t]
    for p in P for t in T[:-1]   # No holding cost for June ending inventory
)

model.setObjective(revenue - holding, GRB.MAXIMIZE)

# Constraints

# Demand constraints
for p in P:
    for t in T:
        prev_inventory = 0 if t == 0 else I[p, t-1]
        model.addConstr(
            prev_inventory + x[p, t] - I[p, t] <= demand[t][p],
            name=f"Demand_p{p}_t{t}"
        )

# Storage limit
for p in P:
    for t in T:
        model.addConstr(I[p, t] <= 100, name=f"Storage_p{p}_t{t}")

# Final inventory requirement (end of June = 50)
for p in P:
    model.addConstr(I[p, 5] == 50, name=f"FinalInv_p{p}")

# Machine capacity constraints
for m in a.keys():
    for t in T:
        model.addConstr(
            gp.quicksum(a[m][p] * x[p, t] for p in P)
            <= machines[m][t] * hours_per_machine,
            name=f"Cap_{m}_t{t}"
        )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Profit: {model.objVal:.2f}\n")
    for t in T:
        print(f"Month {t+1}:")
        for p in P:
            print(f"  Product {p+1}: Production = {x[p,t].x:.2f}, Inventory = {I[p,t].x:.2f}")
        print()
else:
    print("No optimal solution found.")
```
