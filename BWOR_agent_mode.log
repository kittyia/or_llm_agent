【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Blending_Liquor_Lexicographic")

# Index sets
grades = [1, 2, 3]
brands = ['R', 'Y', 'B']

# Decision variables x[i,j]
x = model.addVars(grades, brands, lb=0, name="x")

# ----- Supply Constraints -----
model.addConstr(x[1,'R'] + x[1,'Y'] + x[1,'B'] <= 1500, name="Supply_Grade1")
model.addConstr(x[2,'R'] + x[2,'Y'] + x[2,'B'] <= 2000, name="Supply_Grade2")
model.addConstr(x[3,'R'] + x[3,'Y'] + x[3,'B'] <= 1000, name="Supply_Grade3")

# ----- Blending Constraints (Hard Constraints) -----

# Red
model.addConstr(9 * x[3,'R'] <= x[1,'R'] + x[2,'R'], name="Red_Grade3")
model.addConstr(x[1,'R'] >= x[2,'R'] + x[3,'R'], name="Red_Grade1")

# Yellow
model.addConstr(3 * x[3,'Y'] <= 7 * x[1,'Y'] + 7 * x[2,'Y'], name="Yellow_Grade3")
model.addConstr(4 * x[1,'Y'] >= x[2,'Y'] + x[3,'Y'], name="Yellow_Grade1")

# Blue
model.addConstr(x[3,'B'] <= x[1,'B'] + x[2,'B'], name="Blue_Grade3")
model.addConstr(9 * x[1,'B'] >= x[2,'B'] + x[3,'B'], name="Blue_Grade1")

# ----- Profit Expression -----
Q_R = x[1,'R'] + x[2,'R'] + x[3,'R']
Q_Y = x[1,'Y'] + x[2,'Y'] + x[3,'Y']
Q_B = x[1,'B'] + x[2,'B'] + x[3,'B']

revenue = 5.5 * Q_R + 5.0 * Q_Y + 4.8 * Q_B
cost = (
    6 * (x[1,'R'] + x[1,'Y'] + x[1,'B']) +
    4.5 * (x[2,'R'] + x[2,'Y'] + x[2,'B']) +
    3 * (x[3,'R'] + x[3,'Y'] + x[3,'B'])
)

profit = revenue - cost

# ----- Lexicographic Objectives -----
# Priority 2: Maximize profit (higher priority)
model.setObjectiveN(profit, index=0, priority=2, sense=GRB.MAXIMIZE)

# Priority 3: Maximize Red production (lower priority)
model.setObjectiveN(Q_R, index=1, priority=1, sense=GRB.MAXIMIZE)

# Optimize
model.optimize()

# ----- Output Results -----
if model.status == GRB.OPTIMAL:
    print("\nOptimal Solution Found\n")

    for i in grades:
        for j in brands:
            print(f"x[{i},{j}] = {x[i,j].X:.2f}")

    print(f"\nTotal Red Production: {Q_R.getValue():.2f} kg")
    print(f"Total Yellow Production: {Q_Y.getValue():.2f} kg")
    print(f"Total Blue Production: {Q_B.getValue():.2f} kg")
    print(f"\nMaximum Profit: {profit.getValue():.2f} Yuan")
else:
    print("No optimal solution found.")
```
