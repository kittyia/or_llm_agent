 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Garage_Construction_Scheduling")

# Tasks and durations
tasks = {
    'a': 10, 'b': 8, 'c': 6, 'd': 16, 'e': 24,
    'f': 4, 'g': 4, 'h': 10, 'i': 4, 'j': 12,
    'k': 16, 'L': 8, 'm': 24, 'n': 4
}

# Precedence relationships (successor, predecessor)
precedence = [
    ('c', 'a'), ('c', 'b'),
    ('d', 'b'),
    ('e', 'c'),
    ('f', 'd'), ('f', 'e'),
    ('g', 'f'),
    ('h', 'f'),
    ('i', 'f'),
    ('j', 'g'),
    ('k', 'h'), ('k', 'i'), ('k', 'j'),
    ('L', 'c'),
    ('m', 'L'),
    ('n', 'k'), ('n', 'm')
]

# Decision variables: start times
S = model.addVars(tasks.keys(), lb=0, vtype=GRB.CONTINUOUS, name="S")

# Add precedence constraints
for succ, pred in precedence:
    model.addConstr(S[succ] >= S[pred] + tasks[pred], 
                    name=f"prec_{pred}_to_{succ}")

# Objective: minimize completion time of final task n
model.setObjective(S['n'] + tasks['n'], GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal project duration: {model.objVal} days\n")
    print("Start times:")
    for t in tasks:
        print(f"Task {t}: Start = {S[t].x:.2f}, Finish = {S[t].x + tasks[t]:.2f}")
else:
    print("No optimal solution found.")
```
