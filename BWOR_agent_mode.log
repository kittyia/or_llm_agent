【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Patrol_Unit_Assignment")

# Sets
warehouses = [1, 2, 3, 4]
units = [2, 3, 4]

# Expected accident data
c = {
    (1,2):18, (1,3):16, (1,4):12,
    (2,2):38, (2,3):36, (2,4):30,
    (3,2):14, (3,3):12, (3,4):11,
    (4,2):34, (4,3):31, (4,4):25
}

# Decision variables
x = model.addVars(warehouses, units, vtype=GRB.BINARY, name="x")

# Objective function
model.setObjective(
    gp.quicksum(c[i,j] * x[i,j] for i in warehouses for j in units),
    GRB.MINIMIZE
)

# Constraint 1: Each warehouse receives exactly one allocation
for i in warehouses:
    model.addConstr(gp.quicksum(x[i,j] for j in units) == 1, name=f"assign_{i}")

# Constraint 2: Total patrol units equals 12
model.addConstr(
    gp.quicksum(j * x[i,j] for i in warehouses for j in units) == 12,
    name="total_units"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total expected accidents: {model.objVal}")
    for i in warehouses:
        for j in units:
            if x[i,j].x > 0.5:
                print(f"Warehouse {i}: {j} patrol units")
else:
    print("No optimal solution found.")
```
