【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Tiantian_Food_Optimization")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x1")  # Product I (thousand boxes)
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x2")  # Product II (thousand boxes)

# Set objective function: Maximize revenue
model.setObjective(30 * x1 + 20 * x2, GRB.MAXIMIZE)

# Add constraints
model.addConstr(x1 + 2 * x2 <= 6, name="RawMaterial_A")
model.addConstr(2 * x1 + x2 <= 8, name="RawMaterial_B")
model.addConstr(x2 <= 2, name="Market_Demand_Product_II")
model.addConstr(x2 - x1 <= 1, name="Sales_Relationship")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal solution found:")
    print(f"x1 (Product I) = {x1.X:.4f} thousand boxes")
    print(f"x2 (Product II) = {x2.X:.4f} thousand boxes")
    print(f"Maximum Revenue = {model.objVal:.4f} thousand yuan")
else:
    print("No optimal solution found.")
```
