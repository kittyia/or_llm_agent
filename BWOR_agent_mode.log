import gurobipy as gp
from gurobipy import GRB

# Sets
origins = [1, 2, 3]
destinations = ['A', 'B', 'C']

# Data
supply = {1: 20, 2: 40, 3: 30}
demand = {'A': 30, 'B': 20, 'C': 20}

transport_cost = {
    (1, 'A'): 1, (1, 'B'): 2, (1, 'C'): 2,
    (2, 'A'): 1, (2, 'B'): 4, (2, 'C'): 5,
    (3, 'A'): 2, (3, 'B'): 3, (3, 'C'): 3
}

storage_cost = {1: 5, 2: 4, 3: 3}

# Model
model = gp.Model("Transportation_with_Storage")

# Decision variables
x = model.addVars(origins, destinations, lb=0, name="x")
s = model.addVars(origins, lb=0, name="s")

# Objective function
model.setObjective(
    gp.quicksum(transport_cost[i, j] * x[i, j] for i in origins for j in destinations) +
    gp.quicksum(storage_cost[i] * s[i] for i in origins),
    GRB.MINIMIZE
)

# Supply constraints (including storage)
for i in origins:
    model.addConstr(
        gp.quicksum(x[i, j] for j in destinations) + s[i] == supply[i],
        name=f"supply_{i}"
    )

# Demand constraints
for j in destinations:
    model.addConstr(
        gp.quicksum(x[i, j] for i in origins) == demand[j],
        name=f"demand_{j}"
    )

# Minimum shipment requirements
model.addConstr(
    gp.quicksum(x[2, j] for j in destinations) >= 38,
    name="min_ship_origin_2"
)

model.addConstr(
    gp.quicksum(x[3, j] for j in destinations) >= 27,
    name="min_ship_origin_3"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Objective Value: {model.objVal}\n")
    print("Shipment Plan:")
    for i in origins:
        for j in destinations:
            if x[i, j].x > 1e-6:
                print(f"x[{i},{j}] = {x[i,j].x}")
    print("\nStorage:")
    for i in origins:
        if s[i].x > 1e-6:
            print(f"s[{i}] = {s[i].x}")
else:
    print("No optimal solution found.")
```
