# ✅ Final Result

- The original model was **infeasible**.
- The corrected model properly incorporates the production constraint.
- The formulation is now fully consistent, linear, and suitable for direct Gurobi implementation.
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
warehouses = range(3)
regions = range(5)

# Parameters
S = [50, 100, 150]  # Warehouse capacities
D = [25, 105, 60, 30, 70]  # Demands
P = 270  # Factory capacity

c = [
    [10, 15, 20, 20, 40],
    [20, 40, 15, 30, 30],
    [30, 35, 40, 55, 25]
]

M = 1000  # Large penalty for unmet demand

# Model
model = gp.Model("Sugar_Transportation")

# Decision variables
x = model.addVars(warehouses, regions, lb=0, name="x")
s = model.addVars(regions, lb=0, name="shortage")

# Objective function
model.setObjective(
    gp.quicksum(c[i][j] * x[i, j] for i in warehouses for j in regions) +
    M * gp.quicksum(s[j] for j in regions),
    GRB.MINIMIZE
)

# Warehouse capacity constraints
for i in warehouses:
    model.addConstr(
        gp.quicksum(x[i, j] for j in regions) <= S[i],
        name=f"WarehouseCapacity_{i}"
    )

# Demand satisfaction constraints
for j in regions:
    model.addConstr(
        gp.quicksum(x[i, j] for i in warehouses) + s[j] == D[j],
        name=f"Demand_{j}"
    )

# Factory production capacity constraint
model.addConstr(
    gp.quicksum(x[i, j] for i in warehouses for j in regions) <= P,
    name="FactoryCapacity"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal}")
    print("\nShipment Plan:")
    for i in warehouses:
        for j in regions:
            if x[i, j].x > 1e-6:
                print(f"Warehouse A{i+1} -> Region B{j+1}: {x[i, j].x}")
    print("\nUnmet Demand:")
    for j in regions:
        if s[j].x > 1e-6:
            print(f"Region B{j+1} shortage: {s[j].x}")
else:
    print("No optimal solution found.")
```
