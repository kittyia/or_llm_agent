【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Course_Selection")

# Decision variables
x = model.addVars(7, vtype=GRB.BINARY, name="x")

# Objective: minimize total number of courses
model.setObjective(gp.quicksum(x[i] for i in range(7)), GRB.MINIMIZE)

# Category constraints (exactly 2 in each category)

# Mathematics: 1,2,3,4,7 -> indices 0,1,2,3,6
model.addConstr(x[0] + x[1] + x[2] + x[3] + x[6] == 2, "Math")

# Operations Research: 2,4,5,7 -> indices 1,3,4,6
model.addConstr(x[1] + x[3] + x[4] + x[6] == 2, "OR")

# Computer Science: 3,5,6 -> indices 2,4,5
model.addConstr(x[2] + x[4] + x[5] == 2, "CS")

# Prerequisite constraints
model.addConstr(x[4] <= x[5], "Sim_requires_Prog")   # Computer Simulation requires Programming
model.addConstr(x[2] <= x[5], "DS_requires_Prog")    # Data Structures requires Programming
model.addConstr(x[3] <= x[0], "MS_requires_Calc")    # Managerial Statistics requires Calculus
model.addConstr(x[6] <= x[3], "F_requires_MS")       # Forecasting requires Managerial Statistics

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    courses = [
        "Calculus",
        "Operations Research",
        "Data Structures",
        "Managerial Statistics",
        "Computer Simulation",
        "Computer Programming",
        "Forecasting"
    ]
    
    print(f"Minimum number of courses: {int(model.objVal)}\n")
    print("Selected courses:")
    for i in range(7):
        if x[i].x > 0.5:
            print(f"- {courses[i]}")
else:
    print("No optimal solution found.")
```
