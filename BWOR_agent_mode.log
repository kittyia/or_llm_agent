【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Chemical_Transportation_Profit_Maximization")

# Sets
plants = ['A', 'B', 'C', 'D']
regions = [1, 2, 3, 4, 5, 6]

# Supply (tons)
supply = {
    'A': 200,
    'B': 300,
    'C': 400,
    'D': 100
}

# Demand upper bounds (tons)
demand = {
    1: 200,
    2: 150,
    3: 400,
    4: 100,
    5: 150,
    6: 150
}

# Net profit per ton (price - production cost - transportation cost)
profit = {
    ('A',1): 0.3, ('A',2): 0.8, ('A',3): 0.3, ('A',4): 0.6, ('A',5): 0.1, ('A',6): 0.7,
    ('B',1): 0.3, ('B',2): 0.2, ('B',3):-0.5, ('B',4): 0.3, ('B',5):-0.4, ('B',6): 0.4,
    ('C',1): 0.2, ('C',2): 0.6, ('C',3): 0.4, ('C',4): 0.4, ('C',5): 0.1, ('C',6): 0.5,
    ('D',1):-0.1, ('D',2): 0.5, ('D',3): 0.1, ('D',4): 0.1, ('D',5):-0.4, ('D',6):-0.3
}

# Decision variables
x = model.addVars(plants, regions, lb=0, name="x")

# Objective function
model.setObjective(
    gp.quicksum(profit[i, j] * x[i, j] for i in plants for j in regions),
    GRB.MAXIMIZE
)

# Supply constraints
for i in plants:
    model.addConstr(
        gp.quicksum(x[i, j] for j in regions) <= supply[i],
        name=f"Supply_{i}"
    )

# Demand constraints
# Region I, II, V, VI (upper bounds)
for j in [1, 2, 5, 6]:
    model.addConstr(
        gp.quicksum(x[i, j] for i in plants) <= demand[j],
        name=f"Demand_Upper_{j}"
    )

# Region III (100 ≤ demand ≤ 400)
model.addConstr(
    gp.quicksum(x[i, 3] for i in plants) >= 100,
    name="Demand_Lower_3"
)
model.addConstr(
    gp.quicksum(x[i, 3] for i in plants) <= demand[3],
    name="Demand_Upper_3"
)

# Region IV (must be fully satisfied)
model.addConstr(
    gp.quicksum(x[i, 4] for i in plants) == demand[4],
    name="Demand_Exact_4"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.2f}")
    print("Optimal Transportation Plan (tons):")
    for i in plants:
        for j in regions:
            if x[i, j].x > 1e-6:
                print(f"Plant {i} -> Region {j}: {x[i, j].x:.2f}")
else:
    print("No optimal solution found.")
```
