【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
m = gp.Model("Transshipment_MinCostFlow")

# Nodes
nodes = ['X', 'Y', 'A', 'B', 'C']

# Supply/Demand (positive = supply, negative = demand)
b = {
    'X': 70,
    'Y': 55,
    'A': -35,
    'B': -40,
    'C': -50
}

# Arc costs (distance)
cost = {
    ('X','Y'): 12, ('Y','X'): 10,
    ('X','A'): 10, ('X','B'): 14, ('X','C'): 12,
    ('Y','A'): 15, ('Y','B'): 12, ('Y','C'): 18,
    ('A','B'): 14, ('A','C'): 11,
    ('B','A'): 10, ('B','C'): 4,
    ('C','A'): 8,  ('C','B'): 12
}

arcs = list(cost.keys())

# Decision variables
x = m.addVars(arcs, lb=0, name="x")

# Objective: minimize total transportation distance
m.setObjective(gp.quicksum(cost[i,j] * x[i,j] for (i,j) in arcs), GRB.MINIMIZE)

# Flow conservation constraints
for i in nodes:
    outflow = gp.quicksum(x[i,j] for (i,j) in arcs if i == i and (i,j) in arcs)
    inflow = gp.quicksum(x[j,i] for (j,i) in arcs if i == i and (j,i) in arcs)
    m.addConstr(outflow - inflow == b[i], name=f"flow_{i}")

# Optimize
m.optimize()

# Output results
if m.status == GRB.OPTIMAL:
    print(f"Optimal total transportation distance: {m.objVal}")
    print("Optimal transportation plan:")
    for (i,j) in arcs:
        if x[i,j].X > 1e-6:
            print(f"Ship {x[i,j].X:.2f} tons from {i} to {j}")
else:
    print("No optimal solution found.")
```
