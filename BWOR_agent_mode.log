【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
grades = ['A', 'B', 'C', 'D', 'E']
positions = [1, 2, 3, 4, 5]

p = {
    'A': 0.10,
    'B': 0.25,
    'C': 0.30,
    'D': 0.20,
    'E': 0.15
}

# Create model
model = gp.Model("Exam_Sorting_Optimization")

# Decision variables
x = model.addVars(grades, positions, vtype=GRB.BINARY, name="x")

# Objective: Minimize expected sorting workload
model.setObjective(
    gp.quicksum(p[g] * k * x[g, k] for g in grades for k in positions),
    GRB.MINIMIZE
)

# Constraint 1: Each grade assigned exactly one position
for g in grades:
    model.addConstr(gp.quicksum(x[g, k] for k in positions) == 1, name=f"Assign_{g}")

# Constraint 2: Each position assigned exactly one grade
for k in positions:
    model.addConstr(gp.quicksum(x[g, k] for g in grades) == 1, name=f"Position_{k}")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Sorting Order:")
    order = sorted(
        [(g, k) for g in grades for k in positions if x[g, k].x > 0.5],
        key=lambda item: item[1]
    )
    for g, k in order:
        print(f"Position {k}: Grade {g}")
    
    print(f"\nMinimum Expected Sorting Workload: {model.objVal}")
else:
    print("No optimal solution found.")
```
