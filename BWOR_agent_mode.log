If desired, this model can be further strengthened using a **permutation (position-free) formulation with pairwise precedence variables**, but for \(n=12\) this assignment formulation is perfectly suitable and Gurobi-friendly.
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Data
# -----------------------------
jobs = range(12)          # Jobs 0..11 represent jobs 1..12
positions = range(12)     # Positions 0..11

pA = [5, 8, 11, 2, 7, 6, 3, 9, 8, 3, 6, 10]
pB = [5, 9, 4, 3, 7, 9, 5, 4, 9, 5, 3, 4]

# -----------------------------
# Model
# -----------------------------
model = gp.Model("TwoMachineFlowShop")

# Decision variables
x = model.addVars(jobs, positions, vtype=GRB.BINARY, name="x")
C_A = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0.0, name="C_A")
C_B = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0.0, name="C_B")
C_max = model.addVar(vtype=GRB.CONTINUOUS, lb=0.0, name="C_max")

# -----------------------------
# Assignment constraints
# -----------------------------
for k in positions:
    model.addConstr(gp.quicksum(x[j, k] for j in jobs) == 1, name=f"AssignPos_{k}")

for j in jobs:
    model.addConstr(gp.quicksum(x[j, k] for k in positions) == 1, name=f"AssignJob_{j}")

# -----------------------------
# Processing time expressions
# -----------------------------
P_A = {}
P_B = {}
for k in positions:
    P_A[k] = gp.quicksum(pA[j] * x[j, k] for j in jobs)
    P_B[k] = gp.quicksum(pB[j] * x[j, k] for j in jobs)

# -----------------------------
# Machine A completion times
# -----------------------------
model.addConstr(C_A[0] == P_A[0], name="C_A_0")

for k in positions:
    if k > 0:
        model.addConstr(C_A[k] == C_A[k-1] + P_A[k], name=f"C_A_{k}")

# -----------------------------
# Machine B completion times
# -----------------------------
model.addConstr(C_B[0] >= C_A[0] + P_B[0], name="C_B_0")

for k in positions:
    model.addConstr(C_B[k] >= C_A[k] + P_B[k], name=f"C_B_flow_{k}")
    if k > 0:
        model.addConstr(C_B[k] >= C_B[k-1] + P_B[k], name=f"C_B_seq_{k}")

# -----------------------------
# Makespan constraints
# -----------------------------
for k in positions:
    model.addConstr(C_max >= C_B[k], name=f"Makespan_{k}")

# Objective
model.setObjective(C_max, GRB.MINIMIZE)

# -----------------------------
# Solve
# -----------------------------
model.optimize()

# -----------------------------
# Output results
# -----------------------------
if model.status == GRB.OPTIMAL:
    sequence = []
    for k in positions:
        for j in jobs:
            if x[j, k].X > 0.5:
                sequence.append(j + 1)  # convert to 1-based job index
                break

    print("Optimal Job Sequence:")
    print(sequence)
    print("\nMinimum Makespan:", C_max.X)
else:
    print("No optimal solution found.")
```
