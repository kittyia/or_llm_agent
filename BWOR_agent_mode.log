【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
n = 5
cost = [
    [4, 8, 7, 15, 12],
    [7, 9, 17, 14, 10],
    [6, 9, 12, 8, 7],
    [6, 7, 14, 6, 10],
    [6, 9, 12, 10, 6]
]

# Create model
model = gp.Model("Assignment_Problem")

# Decision variables
x = model.addVars(n, n, vtype=GRB.BINARY, name="x")

# Objective function
model.setObjective(
    gp.quicksum(cost[i][j] * x[i, j] for i in range(n) for j in range(n)),
    GRB.MINIMIZE
)

# Constraints: Each company assigned to exactly one store
for i in range(n):
    model.addConstr(gp.quicksum(x[i, j] for j in range(n)) == 1, name=f"Company_{i}")

# Constraints: Each store assigned exactly one company
for j in range(n):
    model.addConstr(gp.quicksum(x[i, j] for i in range(n)) == 1, name=f"Store_{j}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost (thousand yuan): {model.objVal}")
    for i in range(n):
        for j in range(n):
            if x[i, j].x > 0.5:
                print(f"Company A{i+1} is assigned to Store B{j+1}")
else:
    print("No optimal solution found.")
```
