【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Data
# -----------------------------
cities = ['A', 'B', 'C', 'D', 'E', 'F']

# Sailing times (days)
t = {
    ('A','A'):0, ('A','B'):1, ('A','C'):2, ('A','D'):14, ('A','E'):7, ('A','F'):7,
    ('B','A'):1, ('B','B'):0, ('B','C'):3, ('B','D'):13, ('B','E'):8, ('B','F'):8,
    ('C','A'):2, ('C','B'):3, ('C','C'):0, ('C','D'):15, ('C','E'):5, ('C','F'):5,
    ('D','A'):14, ('D','B'):13, ('D','C'):15, ('D','D'):0, ('D','E'):17, ('D','F'):20,
    ('E','A'):7, ('E','B'):8, ('E','C'):5, ('E','D'):17, ('E','E'):0, ('E','F'):3,
    ('F','A'):7, ('F','B'):8, ('F','C'):5, ('F','D'):20, ('F','E'):3, ('F','F'):0,
}

# Required sailings per day
required_routes = {
    ('E','D'): 3,
    ('B','C'): 2,
    ('A','F'): 1,
    ('D','B'): 1,
}

service_time = 1  # loading/unloading time per arrival (days)

# -----------------------------
# Model
# -----------------------------
model = gp.Model("Minimum_Number_of_Ships")

# Decision variables: ships per day traveling from i to j
x = model.addVars(cities, cities, lb=0.0, name="x")

# Total fleet size
N = model.addVar(lb=0.0, name="N")

# -----------------------------
# Constraints
# -----------------------------

# 1. Route demand constraints
for (i, j), demand in required_routes.items():
    model.addConstr(x[i, j] >= demand, name=f"demand_{i}_{j}")

# 2. Flow conservation at each city
for i in cities:
    model.addConstr(
        gp.quicksum(x[j, i] for j in cities) ==
        gp.quicksum(x[i, j] for j in cities),
        name=f"flow_balance_{i}"
    )

# 3. Fleet size definition
model.addConstr(
    N == gp.quicksum((t[i, j] + service_time) * x[i, j]
                     for i in cities for j in cities),
    name="fleet_size_definition"
)

# -----------------------------
# Objective
# -----------------------------
model.setObjective(N, GRB.MINIMIZE)

# -----------------------------
# Solve
# -----------------------------
model.optimize()

# -----------------------------
# Output Results
# -----------------------------
if model.status == GRB.OPTIMAL:
    print(f"Minimum number of ships required: {N.X:.2f}\n")
    print("Optimal ship flows (ships per day):")
    for i in cities:
        for j in cities:
            if x[i, j].X > 1e-6:
                print(f"x[{i},{j}] = {x[i,j].X:.2f}")
else:
    print("No optimal solution found.")
```
