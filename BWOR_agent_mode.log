    (2, 4): (4, 12),
    (3, 1): (0, 0),
    (3, 2): (1, 3)
}

budget = 5

# Decision variables
x = {}
for i in factories:
    for j in factories[i]:
        x[i, j] = model.addVar(vtype=GRB.BINARY, name=f"x_{i}_{j}")

model.update()

# Objective function
model.setObjective(
    gp.quicksum(data[i, j][1] * x[i, j] for i in factories for j in factories[i]),
    GRB.MAXIMIZE
)

# Budget constraint
model.addConstr(
    gp.quicksum(data[i, j][0] * x[i, j] for i in factories for j in factories[i]) <= budget,
    name="Budget"
)

# One plan per factory constraints
for i in factories:
    model.addConstr(
        gp.quicksum(x[i, j] for j in factories[i]) == 1,
        name=f"OnePlan_Factory_{i}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Return: {model.objVal}")
    print("Selected Plans:")
    for i in factories:
        for j in factories[i]:
            if x[i, j].x > 0.5:
                investment, ret = data[i, j]
                print(f"Factory {i}: Plan {j} (Investment: {investment}, Return: {ret})")
else:
    print("No optimal solution found.")
```
