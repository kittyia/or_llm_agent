【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Goal_Programming_Diet")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Milk")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Beef")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Eggs")

# Deviational variables (vitamin under/over achievement)
dA_minus = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dA_minus")
dA_plus  = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dA_plus")

dC_minus = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dC_minus")
dC_plus  = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dC_plus")

dD_minus = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dD_minus")
dD_plus  = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dD_plus")

# Deviational variables (cholesterol and cost)
dCh_plus = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dCh_plus")
dCost_plus = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="dCost_plus")

model.update()

# Goal constraints

# Vitamin A
model.addConstr(
    x1 + x2 + 10*x3 + dA_minus - dA_plus == 1,
    name="Vitamin_A"
)

# Vitamin C
model.addConstr(
    100*x1 + 10*x2 + 10*x3 + dC_minus - dC_plus == 30,
    name="Vitamin_C"
)

# Vitamin D
model.addConstr(
    10*x1 + 100*x2 + 10*x3 + dD_minus - dD_plus == 10,
    name="Vitamin_D"
)

# Cholesterol minimization goal
model.addConstr(
    70*x1 + 50*x2 + 120*x3 - dCh_plus == 0,
    name="Cholesterol_Goal"
)

# Cost minimization goal
model.addConstr(
    1.5*x1 + 8*x2 + 4*x3 - dCost_plus == 0,
    name="Cost_Goal"
)

# Set hierarchical objectives (preemptive goal programming)

# Priority 1: Minimize vitamin underachievement
model.setObjectiveN(
    dA_minus + dC_minus + dD_minus,
    index=0,
    priority=3,
    name="Priority1_Vitamins"
)

# Priority 2: Minimize cholesterol
model.setObjectiveN(
    dCh_plus,
    index=1,
    priority=2,
    name="Priority2_Cholesterol"
)

# Priority 3: Minimize cost
model.setObjectiveN(
    dCost_plus,
    index=2,
    priority=1,
    name="Priority3_Cost"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution:")
    print(f"Milk (500g units): {x1.X:.4f}")
    print(f"Beef (500g units): {x2.X:.4f}")
    print(f"Eggs (500g units): {x3.X:.4f}")
    print("\nDeviations:")
    print(f"dA_minus: {dA_minus.X:.4f}")
    print(f"dC_minus: {dC_minus.X:.4f}")
    print(f"dD_minus: {dD_minus.X:.4f}")
    print(f"dCh_plus: {dCh_plus.X:.4f}")
    print(f"dCost_plus: {dCost_plus.X:.4f}")
else:
    print("No optimal solution found.")
```
