import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Cargo_Loading_Problem")

# Sets
cargo_types = ['A', 'B', 'C']
compartments = ['F', 'M', 'R']

# Parameters
volume = {'A': 10, 'B': 5, 'C': 7}
weight = {'A': 8, 'B': 6, 'C': 4}
profit = {'A': 1000, 'B': 700, 'C': 600}
availability = {'A': 600, 'B': 1000, 'C': 800}

max_weight = {'F': 2000, 'M': 3000, 'R': 1500}
max_volume = {'F': 4000, 'M': 5000, 'R': 1500}

# Decision variables
x = model.addVars(cargo_types, compartments, 
                  vtype=GRB.INTEGER, 
                  name="x", 
                  lb=0)

# Auxiliary weight expressions
W = {}
for j in compartments:
    W[j] = gp.quicksum(weight[i] * x[i, j] for i in cargo_types)

# Objective function
model.setObjective(
    gp.quicksum(profit[i] * x[i, j] for i in cargo_types for j in compartments),
    GRB.MAXIMIZE
)

# Weight capacity constraints
for j in compartments:
    model.addConstr(W[j] <= max_weight[j], name=f"WeightCap_{j}")

# Volume capacity constraints
for j in compartments:
    model.addConstr(
        gp.quicksum(volume[i] * x[i, j] for i in cargo_types) <= max_volume[j],
        name=f"VolumeCap_{j}"
    )

# Availability constraints
for i in cargo_types:
    model.addConstr(
        gp.quicksum(x[i, j] for j in compartments) <= availability[i],
        name=f"Availability_{i}"
    )

# Balance constraints

# Front/Middle (±15%)
model.addConstr(W['F'] >= (17/30) * W['M'], name="Balance_FM_lower")
model.addConstr(W['F'] <= (23/30) * W['M'], name="Balance_FM_upper")

# Rear/Middle (±15%)
model.addConstr(W['R'] >= (17/40) * W['M'], name="Balance_RM_lower")
model.addConstr(W['R'] <= (23/40) * W['M'], name="Balance_RM_upper")

# Front/Rear (±10%)
model.addConstr(W['F'] >= 1.2 * W['R'], name="Balance_FR_lower")
model.addConstr(W['F'] <= (22/15) * W['R'], name="Balance_FR_upper")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Revenue: {model.objVal}")
    for i in cargo_types:
        for j in compartments:
            if x[i, j].x > 0:
                print(f"x[{i},{j}] = {int(x[i, j].x)}")
else:
    print("No optimal solution found.")
```
