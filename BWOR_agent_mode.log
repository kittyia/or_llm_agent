 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Feed_Optimization")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x1")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x2")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x3")
x4 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x4")
x5 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x5")

# Objective function: Minimize total cost
model.setObjective(
    0.2 * x1 + 0.7 * x2 + 0.4 * x3 + 0.3 * x4 + 0.8 * x5,
    GRB.MINIMIZE
)

# Nutritional constraints
# Protein (g)
model.addConstr(3 * x1 + 2 * x2 + 1 * x3 + 6 * x4 + 18 * x5 >= 700, "Protein")

# Minerals (g)
model.addConstr(1.0 * x1 + 0.5 * x2 + 0.2 * x3 + 2.0 * x4 + 0.5 * x5 >= 30, "Minerals")

# Vitamins (g) - converted from mg to g
model.addConstr(
    0.0005 * x1 + 0.001 * x2 + 0.0002 * x3 + 0.002 * x4 + 0.0008 * x5 >= 0.1,
    "Vitamins"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    for var in model.getVars():
        print(f"{var.varName} = {var.x:.6f} kg")
    print(f"Minimum Cost = ${model.objVal:.6f} per animal per day")
else:
    print("No optimal solution found.")
```
