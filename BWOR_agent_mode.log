【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Investment_Optimization")

# Decision variables (thousand yuan)
xA = model.addVar(lb=0, ub=350, vtype=GRB.CONTINUOUS, name="xA")
xB = model.addVar(lb=0, ub=350, vtype=GRB.CONTINUOUS, name="xB")
xC = model.addVar(lb=0, ub=350, vtype=GRB.CONTINUOUS, name="xC")

# Objective function: Maximize total profit
model.setObjective(0.05 * xA + 0.07 * xB + 0.10 * xC, GRB.MAXIMIZE)

# Constraints
model.addConstr(xA >= 300, name="MinInvestmentA")
model.addConstr(xA + xB + xC == 900, name="TotalInvestment")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    print(f"Investment in Product A: {xA.X:.2f} thousand yuan")
    print(f"Investment in Product B: {xB.X:.2f} thousand yuan")
    print(f"Investment in Product C: {xC.X:.2f} thousand yuan")
    print(f"Maximum Total Profit: {model.objVal:.2f} thousand yuan")
else:
    print("No optimal solution found.")
```
