【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
months = range(1, 5)
durations = range(1, 5)

demand = {
    1: 1500,
    2: 1000,
    3: 2000,
    4: 1200
}

cost = {
    1: 28,
    2: 45,
    3: 60,
    4: 73
}

# Create model
model = gp.Model("Warehouse_Rental_Optimization")

# Decision variables: x[i,d] for valid (i,d) where i + d - 1 <= 4
x = {}
for i in months:
    for d in durations:
        if i + d - 1 <= 4:
            x[i, d] = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name=f"x_{i}_{d}")

# Set objective: minimize total rental cost
model.setObjective(
    gp.quicksum(cost[d] * x[i, d] for (i, d) in x),
    GRB.MINIMIZE
)

# Coverage constraints
for t in months:
    model.addConstr(
        gp.quicksum(
            x[i, d]
            for (i, d) in x
            if i <= t <= i + d - 1
        ) >= demand[t],
        name=f"demand_month_{t}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total cost: {model.objVal:.2f}")
    print("Optimal rental plan (start_month, duration, area):")
    for (i, d), var in x.items():
        if var.X > 1e-6:
            print(f"Start Month {i}, Duration {d} months: {var.X:.2f} m^2")
else:
    print("No optimal solution found.")
```
