【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Spare_Parts_Optimization")

# Sets
I = range(3)  # Spare parts E1, E2, E3
J = range(3)  # Levels 1, 2, 3

# Parameters
r = [
    [0.3, 0.4, 0.5],  # E1
    [0.2, 0.5, 0.9],  # E2
    [0.1, 0.2, 0.7]   # E3
]

c = [
    [1, 2, 3],  # E1
    [3, 5, 6],  # E2
    [2, 3, 4]   # E3
]

B = 8  # Budget (thousand yuan)

# Decision variables
x = model.addVars(I, J, vtype=GRB.BINARY, name="x")

# Objective function: maximize total reliability
model.setObjective(
    gp.quicksum(r[i][j] * x[i, j] for i in I for j in J),
    GRB.MAXIMIZE
)

# Budget constraint
model.addConstr(
    gp.quicksum(c[i][j] * x[i, j] for i in I for j in J) <= B,
    name="Budget"
)

# Multiple-choice constraints (exactly one level per spare part)
for i in I:
    model.addConstr(
        gp.quicksum(x[i, j] for j in J) == 1,
        name=f"Select_one_level_E{i+1}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total reliability increase: {model.objVal:.4f}")
    print("Optimal spare levels:")
    for i in I:
        for j in J:
            if x[i, j].x > 0.5:
                print(f"E{i+1}: Level {j+1}")
else:
    print("No optimal solution found.")
```
