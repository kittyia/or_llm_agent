 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Production_Planning")

# Decision variables
x1 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="x1")
x2 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="x2")
x3 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="x3")

y1 = model.addVar(vtype=GRB.BINARY, name="y1")
y2 = model.addVar(vtype=GRB.BINARY, name="y2")
y3 = model.addVar(vtype=GRB.BINARY, name="y3")

# Resource constraints
model.addConstr(2*x1 + 4*x2 + 8*x3 <= 500, name="Resource_A")
model.addConstr(2*x1 + 3*x2 + 4*x3 <= 300, name="Resource_B")
model.addConstr(x1 + 2*x2 + 3*x3 <= 100, name="Resource_C")

# Production-activation linking constraints (tight Big-M)
model.addConstr(x1 <= 100 * y1, name="Link_x1")
model.addConstr(x2 <= 50 * y2, name="Link_x2")
model.addConstr(x3 <= (100/3) * y3, name="Link_x3")

# Objective function
model.setObjective(
    4*x1 + 5*x2 + 6*x3 - 100*y1 - 150*y2 - 200*y3,
    GRB.MAXIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal}")
    print(f"x1 = {x1.x}")
    print(f"x2 = {x2.x}")
    print(f"x3 = {x3.x}")
    print(f"y1 = {y1.x}")
    print(f"y2 = {y2.x}")
    print(f"y3 = {y3.x}")
else:
    print("No optimal solution found.")
```
