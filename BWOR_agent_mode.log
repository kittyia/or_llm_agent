【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Nurse_Scheduling_Plan1")

# Days 1..7
days = range(7)  # use 0..6 to represent Mon..Sun

# Decision variables: x[d] = number of nurses starting on day d
x = model.addVars(days, vtype=GRB.INTEGER, lb=0, name="x")

# Demands
R1 = 18
R2 = 20
R3 = 19
R4 = 17
R5 = 12

# Add constraints for each day t (modulo 7 indexing)
for t in days:
    model.addConstr(x[t] + x[(t - 1) % 7] >= R1, name=f"Period1_day{t}")
    model.addConstr(x[(t - 1) % 7] + x[(t - 2) % 7] >= R2, name=f"Period2_day{t}")
    model.addConstr(x[(t - 2) % 7] + x[(t - 3) % 7] >= R3, name=f"Period3_day{t}")
    model.addConstr(x[(t - 3) % 7] + x[(t - 4) % 7] >= R4, name=f"Period4_day{t}")
    model.addConstr(x[(t - 4) % 7] >= R5, name=f"Period5_day{t}")

# Objective: minimize total number of nurses
model.setObjective(gp.quicksum(x[d] for d in days), GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total number of nurses: {int(model.objVal)}")
    for d in days:
        print(f"Number of nurses starting on day {d + 1}: {int(x[d].x)}")
else:
    print("No optimal solution found.")
```
