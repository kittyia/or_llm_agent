model.addConstr(gp.quicksum(volumes[i] * x[i] for i in range(n)) <= V, name="VolumeCapacity")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total value: {model.objVal}")
