\text{s.t.} \quad 
& I_{t-1} + x_t = d_t + I_t \quad t=1,\dots,6 \\
& x_t \le 4y_t \quad t=1,\dots,6 \\
& I_t \le 3 \quad t=1,\dots,6 \\
& I_0 = 0,\; I_6 = 0 \\
& x_t \ge 0,\; I_t \ge 0 \\
& y_t \in \{0,1\}
\end{aligned}
}
