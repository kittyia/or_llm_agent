【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
I = [1, 2, 3]
J = ['A', 'B', 'C', 'D', 'E']

# Parameters
supply = {1: 50, 2: 100, 3: 150}
demand = {'A': 25, 'B': 115, 'C': 60, 'D': 30, 'E': 70}

cost = {
    (1, 'A'): 10, (1, 'B'): 15, (1, 'C'): 20, (1, 'D'): 20, (1, 'E'): 40,
    (2, 'A'): 20, (2, 'B'): 10, (2, 'C'): 15, (2, 'D'): 30, (2, 'E'): 30,
    (3, 'A'): 30, (3, 'B'): 35, (3, 'C'): 40, (3, 'D'): 55, (3, 'E'): 25
}

# Create model
model = gp.Model("Transportation_Problem")

# Decision variables
x = model.addVars(I, J, lb=0, vtype=GRB.CONTINUOUS, name="x")

# Objective function
model.setObjective(
    gp.quicksum(cost[i, j] * x[i, j] for i in I for j in J),
    GRB.MINIMIZE
)

# Supply constraints
for i in I:
    model.addConstr(
        gp.quicksum(x[i, j] for j in J) == supply[i],
        name=f"Supply_{i}"
    )

# Demand constraints
for j in J:
    model.addConstr(
        gp.quicksum(x[i, j] for i in I) == demand[j],
        name=f"Demand_{j}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal}\n")
    print("Optimal Transportation Plan:")
    for i in I:
        for j in J:
            if x[i, j].x > 1e-6:
                print(f"x[{i},{j}] = {x[i, j].x}")
else:
    print("No optimal solution found.")
```
