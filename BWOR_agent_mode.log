【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
mills = [1, 2, 3]
factories = [1, 2, 3]

# Parameters
supply = {1: 20, 2: 30, 3: 20}
capacity = {1: 15, 2: 25, 3: 20}

profit = {1: 12, 2: 16, 3: 11}

transport_cost = {
    (1,1): 3,  (1,2): 10, (1,3): 2,
    (2,1): 4,  (2,2): 11, (2,3): 8,
    (3,1): 8,  (3,2): 11, (3,3): 4
}

# Create model
model = gp.Model("Flour_Allocation")

# Decision variables
x = model.addVars(mills, factories, lb=0, vtype=GRB.CONTINUOUS, name="x")

# Objective function: maximize total net profit
model.setObjective(
    gp.quicksum(
        (profit[j] - transport_cost[i, j]) * x[i, j]
        for i in mills for j in factories
    ),
    GRB.MAXIMIZE
)

# Supply constraints
for i in mills:
    model.addConstr(
        gp.quicksum(x[i, j] for j in factories) <= supply[i],
        name=f"Supply_{i}"
    )

# Factory capacity constraints (equality form)
for j in factories:
    model.addConstr(
        gp.quicksum(x[i, j] for i in mills) == capacity[j],
        name=f"Capacity_{j}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Objective Value (Total Net Profit): {model.objVal:.2f}\n")
    print("Optimal Flour Allocation:")
    for i in mills:
        for j in factories:
            if x[i, j].x > 1e-6:
                print(f"Mill {i} -> Factory {j}: {x[i, j].x:.2f}")
else:
    print("No optimal solution found.")
```
