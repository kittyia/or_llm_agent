【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Nurse_Scheduling")

# Decision variables
x = model.addVars(6, lb=0, vtype=GRB.CONTINUOUS, name="x")

# Objective function: minimize total number of nurses
model.setObjective(gp.quicksum(x[i] for i in range(6)), GRB.MINIMIZE)

# Coverage constraints
model.addConstr(x[0] + x[5] >= 10, name="cover_2_6")
model.addConstr(x[0] + x[1] >= 15, name="cover_6_10")
model.addConstr(x[1] + x[2] >= 25, name="cover_10_14")
model.addConstr(x[2] + x[3] >= 20, name="cover_14_18")
model.addConstr(x[3] + x[4] >= 18, name="cover_18_22")
model.addConstr(x[4] + x[5] >= 12, name="cover_22_2")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum number of nurses required: {model.objVal}")
    start_times = ["2:00", "6:00", "10:00", "14:00", "18:00", "22:00"]
    for i in range(6):
        print(f"Nurses starting at {start_times[i]}: {x[i].x}")
else:
    print("No optimal solution found.")
```
