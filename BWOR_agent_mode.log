【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
products = [1, 2, 3]
stages = [1, 2, 3]

# Parameters
D = {
    (1,1):500, (2,1):750, (3,1):900,
    (1,2):680, (2,2):800, (3,2):800,
    (1,3):800, (2,3):950, (3,3):1000
}

a = {1:2.0, 2:1.0, 3:3.1}       # equipment hours per unit
c = {1:40, 2:20, 3:55}          # capital per unit

H = 5000                        # equipment capacity per stage
K = 93000                       # capital limit per stage

w = {1:1, 2:1, 3:2}             # shortage weights

# Model
model = gp.Model("Jinyuan_Production_Planning")

# Decision variables
x = model.addVars(products, stages, name="x", lb=0)
I = model.addVars(products, stages, name="I", lb=0)
s = model.addVars(products, stages, name="s", lb=0)
h = model.addVars(stages, name="h_overload", lb=0)

# Inventory balance constraints
for i in products:
    for t in stages:
        if t == 1:
            model.addConstr(
                x[i,t] + s[i,t] == D[(i,t)] + I[i,t],
                name=f"inv_balance_{i}_{t}"
            )
        else:
            model.addConstr(
                I[i,t-1] + x[i,t] + s[i,t] == D[(i,t)] + I[i,t],
                name=f"inv_balance_{i}_{t}"
            )

# Final inventory zero
for i in products:
    model.addConstr(I[i,3] == 0, name=f"final_inventory_{i}")

# Equipment capacity (soft constraint)
for t in stages:
    model.addConstr(
        gp.quicksum(a[i]*x[i,t] for i in products) <= H + h[t],
        name=f"equipment_capacity_{t}"
    )

# Working capital constraint (hard constraint)
for t in stages:
    model.addConstr(
        gp.quicksum(c[i]*x[i,t] for i in products) <= K,
        name=f"capital_constraint_{t}"
    )

# Multi-objective (lexicographic)
# Priority 1: minimize weighted shortages
model.setObjectiveN(
    gp.quicksum(w[i]*s[i,t] for i in products for t in stages),
    index=0,
    priority=2,
    name="Minimize_Shortage"
)

# Priority 2: minimize equipment overload
model.setObjectiveN(
    gp.quicksum(h[t] for t in stages),
    index=1,
    priority=1,
    name="Minimize_Overload"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("\nOptimal Production Plan:")
    for t in stages:
        print(f"\nStage {t}:")
        for i in products:
            print(f"  Product {i} Production: {x[i,t].X:.2f}, "
                  f"Inventory: {I[i,t].X:.2f}, "
                  f"Shortage: {s[i,t].X:.2f}")
        print(f"  Equipment Overload: {h[t].X:.2f}")

    print("\nTotal Weighted Shortage:",
          sum(w[i]*s[i,t].X for i in products for t in stages))
    print("Total Equipment Overload:",
          sum(h[t].X for t in stages))
else:
    print("No optimal solution found.")
```
