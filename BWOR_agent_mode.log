【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Sales_Outlet_Allocation")

# Index sets
regions = range(1, 4)
levels = range(0, 5)

# Profit data
profit = {
    1: [0, 16, 25, 30, 32],
    2: [0, 12, 17, 21, 22],
    3: [0, 10, 14, 16, 17]
}

# Decision variables: x[i,j] = 1 if region i gets j outlets
x = model.addVars(regions, levels, vtype=GRB.BINARY, name="x")

# Objective function
model.setObjective(
    gp.quicksum(profit[i][j] * x[i, j] for i in regions for j in levels),
    GRB.MAXIMIZE
)

# Constraint 1: Each region must have exactly one allocation level
for i in regions:
    model.addConstr(gp.quicksum(x[i, j] for j in levels) == 1, name=f"OneLevel_{i}")

# Constraint 2: Total number of outlets equals 4
model.addConstr(
    gp.quicksum(j * x[i, j] for i in regions for j in levels) == 4,
    name="TotalOutlets"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Allocation:")
    for i in regions:
        for j in levels:
            if x[i, j].x > 0.5:
                print(f"Region {i}: {j} outlets")
    print(f"Maximum Monthly Profit: {model.objVal}")
else:
    print("No optimal solution found.")
```
