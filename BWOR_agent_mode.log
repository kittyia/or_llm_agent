【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Basketball_Lineup_Selection")

# Player heights
heights = {
    1: 1.92,
    2: 1.90,
    3: 1.88,
    4: 1.86,
    5: 1.85,
    6: 1.83,
    7: 1.80,
    8: 1.78
}

players = range(1, 9)

# Decision variables
x = model.addVars(players, vtype=GRB.BINARY, name="x")

# Objective function: maximize total height
model.setObjective(gp.quicksum(heights[i] * x[i] for i in players), GRB.MAXIMIZE)

# Constraint 1: Select exactly 5 players
model.addConstr(gp.quicksum(x[i] for i in players) == 5, name="TotalPlayers")

# Constraint 2: Exactly one center (Players 1 and 2)
model.addConstr(x[1] + x[2] == 1, name="OneCenter")

# Constraint 3: At least one forward (Players 3, 4, 5)
model.addConstr(x[3] + x[4] + x[5] >= 1, name="AtLeastOneForward")

# Constraint 4: Logical constraints
model.addConstr(x[1] + x[6] <= 1, name="No1and6")
model.addConstr(x[4] + x[6] <= 1, name="No4and6")
model.addConstr(x[1] + x[4] <= 1, name="No1and4")

# Constraint 5: Players 2 and 8 cannot both be selected
model.addConstr(x[2] + x[8] <= 1, name="No2and8")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Height: {model.objVal:.2f} meters")
    print("Selected Players:")
    for i in players:
        if x[i].x > 0.5:
            print(f"Player {i} (Height: {heights[i]} m)")
else:
    print("No optimal solution found.")
```
