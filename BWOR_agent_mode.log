【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Factory_Production_Planning")

# Decision variables
x_I1 = model.addVar(lb=0, name="x_I1")     # Product I on A1
x_I2 = model.addVar(lb=0, name="x_I2")     # Product I on A2
x_II1 = model.addVar(lb=0, name="x_II1")   # Product II on A1
x_II2 = model.addVar(lb=0, name="x_II2")   # Product II on A2
x_III = model.addVar(lb=0, name="x_III")   # Product III on A2

y_I1 = model.addVar(lb=0, name="y_I1")     # Product I on B1
y_I2 = model.addVar(lb=0, name="y_I2")     # Product I on B2
y_I3 = model.addVar(lb=0, name="y_I3")     # Product I on B3
y_II = model.addVar(lb=0, name="y_II")     # Product II on B1
y_III = model.addVar(lb=0, name="y_III")   # Product III on B2

# Flow balance constraints
model.addConstr(x_I1 + x_I2 == y_I1 + y_I2 + y_I3, name="Flow_I")
model.addConstr(x_II1 + x_II2 == y_II, name="Flow_II")
model.addConstr(x_III == y_III, name="Flow_III")

# Machine capacity constraints - Stage A
model.addConstr(5*x_I1 + 10*x_II1 <= 6000, name="Cap_A1")
model.addConstr(7*x_I2 + 9*x_II2 + 12*x_III <= 10000, name="Cap_A2")

# Machine capacity constraints - Stage B
model.addConstr(6*y_I1 + 8*y_II <= 4000, name="Cap_B1")
model.addConstr(4*y_I2 + 11*y_III <= 7000, name="Cap_B2")
model.addConstr(7*y_I3 <= 4000, name="Cap_B3")

# Objective function
model.setObjective(
    1.00*(y_I1 + y_I2 + y_I3)
    + 1.65*y_II
    + 2.30*y_III
    - 0.25*x_I1
    - 0.50*x_II1
    - 0.21*x_I2
    - 0.27*x_II2
    - 0.36*x_III
    - 0.36*y_I1
    - 0.48*y_II
    - 0.44*y_I2
    - 1.21*y_III
    - 0.35*y_I3,
    GRB.MAXIMIZE
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.4f}\n")
    for v in model.getVars():
        print(f"{v.varName} = {v.x:.4f}")
else:
    print("No optimal solution found.")
```
