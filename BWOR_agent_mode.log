【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Workforce_Optimization")

# Decision variables
T = model.addVar(lb=0, ub=400, vtype=GRB.CONTINUOUS, name="Technicians")
L = model.addVar(lb=0, ub=800, vtype=GRB.CONTINUOUS, name="Laborers")

y11 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task1_TechAlone")
y12 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task1_MixedTeam")

y21 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task2_Tech")
y22 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task2_Labor")

y31 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task3_5LaborTeam")
y32 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Task3_MixedTeam")

# Objective function
model.setObjective(100 * T + 80 * L, GRB.MINIMIZE)

# Task completion constraints
model.addConstr(42 * y11 + 114 * y12 == 10000, name="Task1_Requirement")
model.addConstr(42 * y21 + 36 * y22 == 20000, name="Task2_Requirement")
model.addConstr(180 * y31 + 150 * y32 == 30000, name="Task3_Requirement")

# Workforce usage constraints
model.addConstr(y11 + y12 + y21 + y32 <= T, name="Technician_Usage")
model.addConstr(2 * y12 + y22 + 5 * y31 + 3 * y32 <= L, name="Laborer_Usage")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Total Cost:", model.objVal)
    print("Technicians recruited:", T.x)
    print("Laborers recruited:", L.x)
    print("Task1 - Technician alone:", y11.x)
    print("Task1 - Mixed teams:", y12.x)
    print("Task2 - Technicians:", y21.x)
    print("Task2 - Laborers:", y22.x)
    print("Task3 - 5-Laborer teams:", y31.x)
    print("Task3 - Mixed teams:", y32.x)
else:
    print("No optimal solution found.")
```
