    gp.quicksum(wage[i] * x[i, d] for i in students for d in days),
    GRB.MINIMIZE
)

# 1. Daily coverage requirement (total 14 hours per day)
for d in days:
    model.addConstr(
        gp.quicksum(x[i, d] for i in students) == H,
        name=f"DailyCoverage_{d}"
    )

# 2. Availability and linking constraints
for i in students:
    for d in days:
        model.addConstr(
            x[i, d] <= availability[i][d],
            name=f"Availability_{i}_{d}"
        )
        model.addConstr(
            x[i, d] <= availability[i][d] * y[i, d],
            name=f"Link_{i}_{d}"
        )

# 3. Weekly minimum working hours
for i in students:
    model.addConstr(
        gp.quicksum(x[i, d] for d in days) >= L[i],
        name=f"MinWeeklyHours_{i}"
    )

# 4. Each student works at most two days per week
for i in students:
    model.addConstr(
        gp.quicksum(y[i, d] for d in days) <= 2,
        name=f"MaxTwoDays_{i}"
    )

# 5. At most 3 students per day
for d in days:
    model.addConstr(
        gp.quicksum(y[i, d] for i in students) <= 3,
        name=f"MaxThreePerDay_{d}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total wage cost: {model.objVal:.2f}")
    for d in days:
        print(f"\nDay {d}:")
        for i in students:
            if x[i, d].x > 1e-6:
                print(f"  Student {i}: {x[i, d].x:.2f} hours")
else:
    print("No optimal solution found.")
```
