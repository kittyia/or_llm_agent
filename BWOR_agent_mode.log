【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
T = range(1, 7)
d = {1: 1, 2: 2, 3: 5, 4: 3, 5: 2, 6: 1}
P_max = 4
I_max = 3
c_p = 10
c_h = 1
F = 4

# Create model
model = gp.Model("Production_Planning")

# Decision variables
x = model.addVars(T, vtype=GRB.CONTINUOUS, lb=0, name="x")      # Production
I = model.addVars(T, vtype=GRB.CONTINUOUS, lb=0, name="I")      # Inventory
y = model.addVars(T, vtype=GRB.BINARY, name="y")                # Production indicator

# Objective function
model.setObjective(
    gp.quicksum(c_p * x[t] + c_h * I[t] + F * y[t] for t in T),
    GRB.MINIMIZE
)

# Inventory balance constraints
for t in T:
    if t == 1:
        model.addConstr(x[t] == d[t] + I[t], name=f"balance_{t}")
    else:
        model.addConstr(I[t-1] + x[t] == d[t] + I[t], name=f"balance_{t}")

# Final inventory must be zero
model.addConstr(I[6] == 0, name="final_inventory")

# Production capacity constraints
for t in T:
    model.addConstr(x[t] <= P_max * y[t], name=f"prod_cap_link_{t}")
    model.addConstr(x[t] <= P_max, name=f"prod_cap_{t}")

# Storage capacity constraints
for t in T:
    model.addConstr(I[t] <= I_max, name=f"storage_cap_{t}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal}")
    print("Month | Production | Inventory | Produce?")
    for t in T:
        print(f"{t:5d} | {x[t].x:10.2f} | {I[t].x:9.2f} | {int(y[t].x)}")
else:
    print("No optimal solution found.")
```
