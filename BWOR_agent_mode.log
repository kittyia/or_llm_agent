 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Hongdou_Garment_Production")

# Decision variables
x1 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Shirts")
x2 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Tshirts")
x3 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="CasualWear")

y1 = model.addVar(vtype=GRB.BINARY, name="Operate_Shirts")
y2 = model.addVar(vtype=GRB.BINARY, name="Operate_Tshirts")
y3 = model.addVar(vtype=GRB.BINARY, name="Operate_CasualWear")

# Objective function
model.setObjective(
    60 * x1 + 40 * x2 + 100 * x3
    - 2000 * y1 - 1500 * y2 - 1000 * y3,
    GRB.MAXIMIZE
)

# Resource constraints
model.addConstr(3 * x1 + 2 * x2 + 6 * x3 <= 150, name="Labor")
model.addConstr(4 * x1 + 3 * x2 + 6 * x3 <= 160, name="Material")

# Big-M constraints
model.addConstr(x1 <= 40 * y1, name="Link_Shirts")
model.addConstr(x2 <= 50 * y2, name="Link_Tshirts")
model.addConstr(x3 <= 25 * y3, name="Link_CasualWear")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.2f}")
    print(f"Shirts Production: {x1.x:.2f}")
    print(f"T-shirts Production: {x2.x:.2f}")
    print(f"Casual Wear Production: {x3.x:.2f}")
    print(f"Operate Shirt Equipment: {int(y1.x)}")
    print(f"Operate T-shirt Equipment: {int(y2.x)}")
    print(f"Operate Casual Wear Equipment: {int(y3.x)}")
else:
    print("No optimal solution found.")
```
