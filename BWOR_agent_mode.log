【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Power_Allocation")

# Sets
stations = [1, 2]
cities = [1, 2, 3]

# Cost matrix
cost = {
    (1, 1): 15, (1, 2): 18, (1, 3): 22,
    (2, 1): 21, (2, 2): 25, (2, 3): 16
}

# Supply capacities
supply = {1: 400, 2: 450}

# Decision variables
x = model.addVars(stations, cities, lb=0, vtype=GRB.CONTINUOUS, name="x")

# Objective function
model.setObjective(
    gp.quicksum(cost[i, j] * x[i, j] for i in stations for j in cities),
    GRB.MINIMIZE
)

# Supply constraints (use all electricity)
for i in stations:
    model.addConstr(
        gp.quicksum(x[i, j] for j in cities) == supply[i],
        name=f"Supply_Station_{i}"
    )

# Demand constraints
# City 1: 290 <= demand <= 320
model.addConstr(
    gp.quicksum(x[i, 1] for i in stations) >= 290,
    name="City1_Min"
)
model.addConstr(
    gp.quicksum(x[i, 1] for i in stations) <= 320,
    name="City1_Max"
)

# City 2: demand = 250
model.addConstr(
    gp.quicksum(x[i, 2] for i in stations) == 250,
    name="City2_Fixed"
)

# City 3: 270 <= demand <= 350
model.addConstr(
    gp.quicksum(x[i, 3] for i in stations) >= 270,
    name="City3_Min"
)
model.addConstr(
    gp.quicksum(x[i, 3] for i in stations) <= 350,
    name="City3_Max"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal}")
    for i in stations:
        for j in cities:
            print(f"x[{i},{j}] = {x[i, j].x}")
else:
    print("No optimal solution found.")
```
