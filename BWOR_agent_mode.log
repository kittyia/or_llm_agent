【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Farm_Optimization")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Soybeans_hm2")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Corn_hm2")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Wheat_hm2")
x4 = model.addVar(lb=0, ub=32, vtype=GRB.CONTINUOUS, name="DairyCows")
x5 = model.addVar(lb=0, ub=3000, vtype=GRB.CONTINUOUS, name="Chickens")
L_aw = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Unused_AW_Labor")
L_ss = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Unused_SS_Labor")

# Objective function
model.setObjective(
    175 * x1 + 300 * x2 + 120 * x3 +
    400 * x4 + 2 * x5 +
    1.8 * L_aw + 2.1 * L_ss,
    GRB.MAXIMIZE
)

# Constraints

# Land constraint
model.addConstr(x1 + x2 + x3 + 1.5 * x4 <= 100, name="Land")

# Capital constraint
model.addConstr(400 * x4 + 3 * x5 <= 15000, name="Capital")

# Autumn-Winter labor constraint
model.addConstr(
    20 * x1 + 35 * x2 + 10 * x3 +
    100 * x4 + 0.6 * x5 +
    L_aw <= 3500,
    name="AutumnWinterLabor"
)

# Spring-Summer labor constraint
model.addConstr(
    50 * x1 + 75 * x2 + 40 * x3 +
    50 * x4 + 0.3 * x5 +
    L_ss <= 4000,
    name="SpringSummerLabor"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Annual Net Income: {model.objVal:.2f} yuan\n")
    for var in model.getVars():
        print(f"{var.varName}: {var.x:.4f}")
else:
    print("No optimal solution found.")
```
