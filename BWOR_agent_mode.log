  <html><body><table><tr><td>Month</td><td>1</td><td>2</td><td>3</td><td>4</td><td>5</td><td>6</td></tr><tr><td>Delivery (hundreds of units)</td><td>1</td><td>2</td><td>5</td><td>3</td><td>2</td><td>1</td></tr></table></body></html>  

