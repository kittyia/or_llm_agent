# Flow Balance Constraints
# =========================
model.addConstr(a11 + a12 == b11 + b12 + b13, name="Flow_Product_I")
model.addConstr(a21 + a22 == b22, name="Flow_Product_II")
model.addConstr(a32 == b32, name="Flow_Product_III")

# =========================
# Machine Capacity Constraints
# =========================
# Stage A
model.addConstr(5*a11 + 10*a21 <= 6000, name="Capacity_A1")
model.addConstr(7*a12 + 9*a22 + 12*a32 <= 10000, name="Capacity_A2")

# Stage B
model.addConstr(6*b11 <= 4000, name="Capacity_B1")
model.addConstr(4*b12 + 8*b22 + 11*b32 <= 7000, name="Capacity_B2")
model.addConstr(7*b13 <= 4000, name="Capacity_B3")

# =========================
# Objective Function (Maximize Profit)
# =========================
objective = (
    1.00*(a11 + a12) +
    1.65*(a21 + a22) +
    2.30*a32
    - (0.25*a11 + 0.50*a21 + 0.21*a12 + 0.27*a22 + 0.36*a32)
    - (0.36*b11 + 0.44*b12 + 0.88*b22 + 1.21*b32 + 0.35*b13)
)

model.setObjective(objective, GRB.MAXIMIZE)

# =========================
# Solve Model
# =========================
model.optimize()

# =========================
# Output Results
# =========================
if model.status == GRB.OPTIMAL:
    print("Optimal Objective Value (Maximum Profit):", model.objVal)
    print("\nOptimal Production Plan:")
    for var in model.getVars():
        print(f"{var.varName} = {var.x}")
else:
    print("No optimal solution found.")
