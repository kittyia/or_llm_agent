  <html><body><table><tr><td>Month (k)</td><td>Buying Price</td><td>Selling Price</td></tr><tr><td>1</td><td>10</td><td>12</td></tr><tr><td>2</td><td>9</td><td>9</td></tr><tr><td>3</td><td>11</td><td>13</td></tr><tr><td>4</td><td>15</td><td>17</td></tr></table></body></html>  

