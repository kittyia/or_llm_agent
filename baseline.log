【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB, quicksum

# Create model
model = Model("Factory_Production_Optimization")

# ----------------------
# Parameters
# ----------------------

# Processing time (hours per unit)
proc_time = {
    ('A1','I'): 5, ('A1','II'): 10,
    ('A2','I'): 7, ('A2','II'): 9, ('A2','III'): 12,
    ('B1','I'): 6, ('B1','II'): 8,
    ('B2','I'): 4, ('B2','III'): 11,
    ('B3','I'): 7
}

# Machine available hours
capacity = {
    'A1': 6000,
    'A2': 10000,
    'B1': 4000,
    'B2': 7000,
    'B3': 4000
}

# Processing cost per hour
machine_cost = {
    'A1': 0.05,
    'A2': 0.03,
    'B1': 0.06,
    'B2': 0.11,
    'B3': 0.05
}

# Raw material cost per unit
raw_cost = {'I': 0.25, 'II': 0.35, 'III': 0.5}

# Unit selling price
price = {'I': 1.25, 'II': 2.0, 'III': 2.8}

# ----------------------
# Decision Variables
# ----------------------

# Stage A variables
x_A1_I = model.addVar(lb=0, name="x_A1_I")
x_A1_II = model.addVar(lb=0, name="x_A1_II")

x_A2_I = model.addVar(lb=0, name="x_A2_I")
x_A2_II = model.addVar(lb=0, name="x_A2_II")
x_A2_III = model.addVar(lb=0, name="x_A2_III")

# Stage B variables
x_B1_I = model.addVar(lb=0, name="x_B1_I")
x_B1_II = model.addVar(lb=0, name="x_B1_II")

x_B2_I = model.addVar(lb=0, name="x_B2_I")
x_B2_III = model.addVar(lb=0, name="x_B2_III")

x_B3_I = model.addVar(lb=0, name="x_B3_I")

model.update()

# ----------------------
# Flow Balance Constraints
# ----------------------

# Product I
model.addConstr(x_A1_I + x_A2_I == x_B1_I + x_B2_I + x_B3_I, "Flow_I")

# Product II
model.addConstr(x_A1_II + x_A2_II == x_B1_II, "Flow_II")

# Product III
model.addConstr(x_A2_III == x_B2_III, "Flow_III")

# ----------------------
# Machine Capacity Constraints
# ----------------------

# A1
model.addConstr(5 * x_A1_I + 10 * x_A1_II <= capacity['A1'], "Cap_A1")

# A2
model.addConstr(7 * x_A2_I + 9 * x_A2_II + 12 * x_A2_III <= capacity['A2'], "Cap_A2")

# B1
model.addConstr(6 * x_B1_I + 8 * x_B1_II <= capacity['B1'], "Cap_B1")

# B2
model.addConstr(4 * x_B2_I + 11 * x_B2_III <= capacity['B2'], "Cap_B2")

# B3
model.addConstr(7 * x_B3_I <= capacity['B3'], "Cap_B3")

# ----------------------
# Objective Function (Maximize Profit)
# ----------------------

# Total production per product
prod_I = x_A1_I + x_A2_I
prod_II = x_A1_II + x_A2_II
prod_III = x_A2_III

# Revenue
revenue = price['I'] * prod_I + price['II'] * prod_II + price['III'] * prod_III

# Raw material cost
raw_material = raw_cost['I'] * prod_I + raw_cost['II'] * prod_II + raw_cost['III'] * prod_III

# Processing cost
processing = (
    5 * x_A1_I * machine_cost['A1'] +
    10 * x_A1_II * machine_cost['A1'] +
    7 * x_A2_I * machine_cost['A2'] +
    9 * x_A2_II * machine_cost['A2'] +
    12 * x_A2_III * machine_cost['A2'] +
    6 * x_B1_I * machine_cost['B1'] +
    8 * x_B1_II * machine_cost['B1'] +
    4 * x_B2_I * machine_cost['B2'] +
    11 * x_B2_III * machine_cost['B2'] +
    7 * x_B3_I * machine_cost['B3']
)

# Profit
model.setObjective(revenue - raw_material - processing, GRB.MAXIMIZE)

# ----------------------
# Solve
# ----------------------

model.optimize()

# ----------------------
# Output Results
# ----------------------

if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.4f}")
    for v in model.getVars():
        if v.x > 1e-6:
            print(f"{v.varName} = {v.x:.4f}")
```
