There are three different products to be processed on three machine tools. Each product must first be processed on machine 1, then sequentially on machines 2 and 3. The order of processing the three products on each machine should remain the same. Assuming $t_{ij}$ represents the time to process the $i$-th product on the $j$-th machine, how should the schedule be arranged to minimize the total processing cycle for the three products? The timetable is as follows:
| Product | Machine 1 | Machine 2 | Machine 3 |
|---------|-----------|-----------|-----------|
| Product 1 | 2           | 3           | 1           |
| Product 2 | 4           | 2           | 3           |
| Product 3 | 3           | 5           | 2           |
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
jobs = [0, 1, 2]
machines = [0, 1, 2]
positions = [0, 1, 2]

t = {
    (0,0): 2, (0,1): 3, (0,2): 1,
    (1,0): 4, (1,1): 2, (1,2): 3,
    (2,0): 3, (2,1): 5, (2,2): 2,
}

# Model
model = gp.Model("PermutationFlowShop")

# Decision variables
x = model.addVars(jobs, positions, vtype=GRB.BINARY, name="x")
C = model.addVars(positions, machines, vtype=GRB.CONTINUOUS, name="C")

# Each position has exactly one job
for k in positions:
    model.addConstr(gp.quicksum(x[i, k] for i in jobs) == 1)

# Each job is assigned to exactly one position
for i in jobs:
    model.addConstr(gp.quicksum(x[i, k] for k in positions) == 1)

# Processing time at position k on machine j
p = {}
for k in positions:
    for j in machines:
        p[k, j] = gp.quicksum(t[i, j] * x[i, k] for i in jobs)

# Flow shop constraints
for k in positions:
    for j in machines:
        if k == 0 and j == 0:
            model.addConstr(C[k, j] >= p[k, j])
        elif k == 0:
            model.addConstr(C[k, j] >= C[k, j-1] + p[k, j])
        elif j == 0:
            model.addConstr(C[k, j] >= C[k-1, j] + p[k, j])
        else:
            model.addConstr(C[k, j] >= C[k-1, j] + p[k, j])
            model.addConstr(C[k, j] >= C[k, j-1] + p[k, j])

# Objective: minimize makespan
model.setObjective(C[positions[-1], machines[-1]], GRB.MINIMIZE)

# Solve
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Makespan:", model.objVal)
    schedule = []
    for k in positions:
        for i in jobs:
            if x[i, k].x > 0.5:
                schedule.append(i+1)
    print("Optimal Job Order:", schedule)
    print("Completion Times:")
    for k in positions:
        for j in machines:
            print(f"C[{k+1},{j+1}] = {C[k,j].x}")
```
