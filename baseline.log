Changjiang Comprehensive Shopping Mall has 5000 m² of space for lease and plans to attract the following 5 types of stores as tenants. The table below shows the area occupied by each type of store for one shop, the minimum and maximum number of shops for each type within the mall, and the expected annual profit (in ten thousand yuan) per store for different numbers of stores. Each store pays 20% of its annual profit as rent to the mall. Question: How many of each type of store should the mall lease to maximize total rental income?

Table 5-12

| Code | Store Type | Area per Shop / m² | Min | Max | 1 Store | 2 Stores | 3 Stores |
|------|------------|--------------------|-----|-----|---------|----------|----------|
| 1    | Jewelry    | 250                | 1   | 3   | 9       | 8        | 7        |
| 2    | Shoes & Hats | 350              | 1   | 2   | 10      | 9        | -        |
| 3    | General Merchandise | 800      | 1   | 3   | 27      | 21       | 20       |
| 4    | Bookstore  | 400                | 0   | 2   | 16      | 10       | -        |
| 5    | Catering   | 500                | 1   | 3   | 17      | 15       | 12       |
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
store_types = {
    1: {"name": "Jewelry", "area": 250, "min": 1, "max": 3, "profit": {1: 9, 2: 8, 3: 7}},
    2: {"name": "Shoes_Hats", "area": 350, "min": 1, "max": 2, "profit": {1: 10, 2: 9}},
    3: {"name": "General_Merchandise", "area": 800, "min": 1, "max": 3, "profit": {1: 27, 2: 21, 3: 20}},
    4: {"name": "Bookstore", "area": 400, "min": 0, "max": 2, "profit": {1: 16, 2: 10}},
    5: {"name": "Catering", "area": 500, "min": 1, "max": 3, "profit": {1: 17, 2: 15, 3: 12}},
}

total_area = 5000
rent_ratio = 0.2

# Create model
model = gp.Model("ShoppingMallLeasing")

# Decision variables: y[i,k] = 1 if k stores of type i are selected
y = {}

for i, data in store_types.items():
    min_k = data["min"]
    max_k = data["max"]
    for k in range(min_k, max_k + 1):
        y[i, k] = model.addVar(vtype=GRB.BINARY, name=f"y_{i}_{k}")
    if min_k == 0:
        y[i, 0] = model.addVar(vtype=GRB.BINARY, name=f"y_{i}_0")

model.update()

# Each store type must select exactly one k
for i, data in store_types.items():
    min_k = data["min"]
    max_k = data["max"]
    if min_k == 0:
        model.addConstr(
            gp.quicksum(y[i, k] for k in range(0, max_k + 1)) == 1,
            name=f"select_one_{i}"
        )
    else:
        model.addConstr(
            gp.quicksum(y[i, k] for k in range(min_k, max_k + 1)) == 1,
            name=f"select_one_{i}"
        )

# Area constraint
model.addConstr(
    gp.quicksum(
        store_types[i]["area"] * k * y[i, k]
        for (i, k) in y
    ) <= total_area,
    name="AreaConstraint"
)

# Objective: maximize total rental income (20% of total profit)
model.setObjective(
    gp.quicksum(
        rent_ratio * k * store_types[i]["profit"].get(k, 0) * y[i, k]
        for (i, k) in y
    ),
    GRB.MAXIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal total rental income (ten thousand yuan):", model.objVal)
    print("Optimal store allocation:")
    for i, data in store_types.items():
        for k in range(data["min"], data["max"] + 1):
            if (i, k) in y and y[i, k].x > 0.5:
                print(f"{data['name']}: {k} stores")
        if data["min"] == 0 and y[i, 0].x > 0.5:
            print(f"{data['name']}: 0 stores")
else:
    print("No optimal solution found.")
```
