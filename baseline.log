A fabric dyeing plant has 3 dyeing vats. Each batch of fabric must be dyed in sequence in each vat: first, the second, and third vats. The plant must color five batches of fabric of different sizes. The time required in hours to dye batch $i$ in vat $j$ is given in the following matrix:

$$
\left(\begin{array}{ccc}
3 & 1 & 1 \\
2 & 1.5 & 1 \\
3 & 1.2 & 1.3 \\
2 & 2 & 2 \\
2.1 & 2 & 3
\end{array}\right)
$$

Schedule the dyeing operations in the vats to minimize the completion time of the last batch.
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
n = 5  # number of batches (jobs)
m = 3  # number of vats (machines)

processing_time = [
    [3, 1, 1],
    [2, 1.5, 1],
    [3, 1.2, 1.3],
    [2, 2, 2],
    [2.1, 2, 3]
]

# Create model
model = gp.Model("FlowShopScheduling")

# Decision variables
x = model.addVars(n, n, vtype=GRB.BINARY, name="x")  # x[i,k] = 1 if job i at position k
C = model.addVars(n, m, vtype=GRB.CONTINUOUS, lb=0, name="C")  # completion times

# Each position has exactly one job
for k in range(n):
    model.addConstr(gp.quicksum(x[i, k] for i in range(n)) == 1)

# Each job is assigned to exactly one position
for i in range(n):
    model.addConstr(gp.quicksum(x[i, k] for k in range(n)) == 1)

# Completion time constraints

# First machine
model.addConstr(
    C[0, 0] == gp.quicksum(processing_time[i][0] * x[i, 0] for i in range(n))
)

for k in range(1, n):
    model.addConstr(
        C[k, 0] >= C[k - 1, 0] + gp.quicksum(processing_time[i][0] * x[i, k] for i in range(n))
    )

# Remaining machines
for j in range(1, m):
    # First position
    model.addConstr(
        C[0, j] >= C[0, j - 1] + gp.quicksum(processing_time[i][j] * x[i, 0] for i in range(n))
    )
    for k in range(1, n):
        model.addConstr(
            C[k, j] >= C[k - 1, j] + gp.quicksum(processing_time[i][j] * x[i, k] for i in range(n))
        )
        model.addConstr(
            C[k, j] >= C[k, j - 1] + gp.quicksum(processing_time[i][j] * x[i, k] for i in range(n))
        )

# Objective: minimize makespan (completion time of last job on last machine)
model.setObjective(C[n - 1, m - 1], GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    sequence = []
    for k in range(n):
        for i in range(n):
            if x[i, k].X > 0.5:
                sequence.append(i + 1)
    print("Optimal sequence of batches:", sequence)
    print("Minimum makespan:", C[n - 1, m - 1].X)
```
