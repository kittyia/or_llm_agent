Assuming a paper mill receives three orders for rolls of paper, with length and width requirements as shown in Table 1.2.

Table 1.2

| Order Number | Width (meters) | Length (meters) |
| :---: | :---: | :---: |
| 1 | 0.5 | 1000 |
| 2 | 0.7 | 3000 |
| 3 | 0.9 | 2000 |

The mill produces rolls of paper with standard widths of 1 meter and 2 meters. Assuming the length of the rolls is unlimited and can be spliced to reach the required length, how should the rolls be cut to minimize the area of waste?
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
orders = {
    1: {"width": 0.5, "demand": 1000},
    2: {"width": 0.7, "demand": 3000},
    3: {"width": 0.9, "demand": 2000},
}

roll_widths = [1.0, 2.0]

# Generate cutting patterns
patterns = []
pattern_id = 0

for W in roll_widths:
    if W == 1.0:
        # Manually enumerate feasible patterns for 1m rolls
        candidates = [
            (2, 0, 0),
            (1, 0, 0),
            (0, 1, 0),
            (0, 0, 1),
        ]
        for a1, a2, a3 in candidates:
            total_width = a1 * 0.5 + a2 * 0.7 + a3 * 0.9
            if total_width <= W and total_width > 0:
                patterns.append({
                    "id": pattern_id,
                    "roll_width": W,
                    "cuts": {1: a1, 2: a2, 3: a3},
                    "waste": W - total_width
                })
                pattern_id += 1
    else:
        # Enumerate feasible patterns for 2m rolls
        for a1 in range(0, 5):      # max 4 of 0.5
            for a2 in range(0, 3):  # max 2 of 0.7
                for a3 in range(0, 3):  # max 2 of 0.9
                    total_width = a1 * 0.5 + a2 * 0.7 + a3 * 0.9
                    if total_width <= W and total_width > 0:
                        patterns.append({
                            "id": pattern_id,
                            "roll_width": W,
                            "cuts": {1: a1, 2: a2, 3: a3},
                            "waste": W - total_width
                        })
                        pattern_id += 1

# Create model
model = gp.Model("Paper_Cutting_Stock")

# Decision variables: length produced with each pattern
x = {}
for p in patterns:
    x[p["id"]] = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name=f"x_{p['id']}")

# Demand constraints (length requirements)
for i in orders:
    model.addConstr(
        gp.quicksum(patterns[p]["cuts"][i] * x[p] for p in x)
        == orders[i]["demand"],
        name=f"demand_order_{i}"
    )

# Objective: minimize total waste area
model.setObjective(
    gp.quicksum(patterns[p]["waste"] * x[p] for p in x),
    GRB.MINIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total waste area: {model.objVal:.4f}")
    print("\nCutting plan:")
    for p in patterns:
        pid = p["id"]
        if x[pid].X > 1e-6:
            print(f"Pattern {pid}: Roll width {p['roll_width']} m, "
                  f"Cuts {p['cuts']}, "
                  f"Length produced = {x[pid].X:.2f}")
```
