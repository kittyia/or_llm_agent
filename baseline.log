import gurobipy as gp
from gurobipy import GRB
import math

# -----------------------------
# Data
# -----------------------------
customers = list(range(1, 21))
nodes = [0] + customers
K = range(5)  # at most 5 vehicles

coords = {
    0: (40, 50),
    1: (45, 68), 2: (45, 70), 3: (42, 66), 4: (42, 68), 5: (42, 65),
    6: (40, 69), 7: (40, 66), 8: (38, 68), 9: (38, 70), 10: (35, 66),
    11: (35, 69), 12: (25, 85), 13: (22, 75), 14: (22, 85), 15: (20, 80),
    16: (20, 85), 17: (18, 75), 18: (15, 75), 19: (15, 80), 20: (30, 50)
}

demand = {
    0: 0,
    1: 10, 2: 30, 3: 10, 4: 10, 5: 10,
    6: 20, 7: 20, 8: 20, 9: 10, 10: 10,
    11: 10, 12: 20, 13: 30, 14: 10, 15: 40,
    16: 40, 17: 20, 18: 20, 19: 10, 20: 10
}

time_window = {
    0: (0, 1236),
    1: (912, 967), 2: (825, 870), 3: (65, 146), 4: (727, 782), 5: (15, 67),
    6: (621, 702), 7: (170, 225), 8: (255, 324), 9: (534, 605), 10: (357, 410),
    11: (448, 505), 12: (652, 721), 13: (30, 92), 14: (567, 620), 15: (384, 429),
    16: (475, 528), 17: (99, 148), 18: (179, 254), 19: (278, 345), 20: (10, 73)
}

service_time = {i: 90 for i in nodes}
capacity = 200

# Distance matrix
dist = {}
for i in nodes:
    for j in nodes:
        if i != j:
            xi, yi = coords[i]
            xj, yj = coords[j]
            dist[i, j] = math.hypot(xi - xj, yi - yj)

# Big-M
M = 10000

# -----------------------------
# Model
# -----------------------------
model = gp.Model("VRPHTW")

# Decision variables
x = model.addVars(dist.keys(), K, vtype=GRB.BINARY, name="x")
t = model.addVars(nodes, K, vtype=GRB.CONTINUOUS, name="t")
y = model.addVars(K, vtype=GRB.BINARY, name="y")

# Objective: minimize total distance
model.setObjective(
    gp.quicksum(dist[i, j] * x[i, j, k] for (i, j) in dist for k in K),
    GRB.MINIMIZE
)

# -----------------------------
# Constraints
# -----------------------------

# Each customer visited exactly once
for i in customers:
    model.addConstr(
        gp.quicksum(x[j, i, k] for j in nodes if j != i for k in K) == 1
    )

# Flow conservation
for k in K:
    for i in customers:
        model.addConstr(
            gp.quicksum(x[j, i, k] for j in nodes if j != i) ==
            gp.quicksum(x[i, j, k] for j in nodes if j != i)
        )

# Depot departure and return
for k in K:
    model.addConstr(
        gp.quicksum(x[0, j, k] for j in customers) == y[k]
    )
    model.addConstr(
        gp.quicksum(x[j, 0, k] for j in customers) == y[k]
    )

# Capacity constraints
for k in K:
    model.addConstr(
        gp.quicksum(demand[i] * gp.quicksum(x[j, i, k] for j in nodes if j != i)
                    for i in customers) <= capacity
    )

# Time window constraints
for k in K:
    for i in nodes:
        a, b = time_window[i]
        model.addConstr(t[i, k] >= a)
        model.addConstr(t[i, k] <= b)

# Time propagation constraints
for k in K:
    for (i, j) in dist:
        model.addConstr(
            t[j, k] >= t[i, k] + service_time[i] + dist[i, j]
            - M * (1 - x[i, j, k])
        )

# Solve
model.setParam("OutputFlag", 1)
model.optimize()

# -----------------------------
# Output
# -----------------------------
if model.status == GRB.OPTIMAL:
    print(f"Optimal total distance: {model.objVal:.2f}")
    for k in K:
        if y[k].x > 0.5:
            print(f"\nRoute for vehicle {k}:")
            route = [0]
            current = 0
            while True:
                next_node = None
                for j in nodes:
                    if j != current and (current, j) in dist:
                        if x[current, j, k].x > 0.5:
                            next_node = j
                            break
                if next_node == 0 or next_node is None:
                    route.append(0)
                    break
                route.append(next_node)
                current = next_node
            print(" -> ".join(map(str, route)))
else:
    print("No optimal solution found.")
```
