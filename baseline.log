Jieli Company needs to recruit three types of professionals to work in the two regional branches located in Donghai City and Nanjiang City. The demand for different professionals in these regional branches is shown in Table 4-3. After assessing the situation of the applicants, the company has categorized them into 6 types. Table 4-4 lists the specialties each type of person can handle, the specialty they prefer, and the city they prefer to work in. The company's personnel arrangement considers the following three priorities:
$p_1$: All three types of professionals needed are fully met;
$p_2$: 8000 recruited personnel meet their preferred specialty;
$p_3$: 8000 recruited personnel meet their preferred city.
Try to establish a mathematical model for goal planning accordingly.

Table 4-3
| Branch Location | Specialty | Demand |
|-----------------|-----------|--------|
| Donghai City    | 1         | 1000   |
| Donghai City    | 2         | 2000   |
| Nanjiang City   | 3         | 1500   |
| Nanjiang City   | 1         | 2000   |
| Nanjiang City   | 2         | 1000   |
| Nanjiang City   | 3         | 1000   |

Table 4-4

| Type | Number of People | Suitable Specialty | Preferred Specialty | Preferred City |
|------|------------------|--------------------|---------------------|----------------|
| 1    | 1500             | 1,2                | 1                   | Donghai        |
| 2    | 1500             | 2,3                | 2                   | Donghai        |
| 3    | 1500             | 1,3                | 1                   | Nanjiang       |
| 4    | 1500             | 1,3                | 3                   | Nanjiang       |
| 5    | 1500             | 2,3                | 3                   | Donghai        |
| 6    | 1500             | 3                  | 3                   | Nanjiang       |
-------------
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB, quicksum

# ----------------------
# Data
# ----------------------
types = range(1, 7)
cities = ["Donghai", "Nanjiang"]
specialties = [1, 2, 3]

# Supply of each type
supply = {i: 1500 for i in types}

# Demand (city, specialty)
demand = {
    ("Donghai", 1): 1000,
    ("Donghai", 2): 2000,
    ("Nanjiang", 1): 2000,
    ("Nanjiang", 2): 1000,
    ("Nanjiang", 3): 2500  # 1500 + 1000 combined in table
}

# Suitable specialties for each type
suitable = {
    1: [1, 2],
    2: [2, 3],
    3: [1, 3],
    4: [1, 3],
    5: [2, 3],
    6: [3]
}

# Preferred specialty
pref_specialty = {
    1: 1,
    2: 2,
    3: 1,
    4: 3,
    5: 3,
    6: 3
}

# Preferred city
pref_city = {
    1: "Donghai",
    2: "Donghai",
    3: "Nanjiang",
    4: "Nanjiang",
    5: "Donghai",
    6: "Nanjiang"
}

# ----------------------
# Model
# ----------------------
m = Model("Goal_Programming_Recruitment")

# Decision variables: x[i,c,s]
x = {}
for i in types:
    for c in cities:
        for s in specialties:
            if s in suitable[i]:
                x[i, c, s] = m.addVar(vtype=GRB.INTEGER, name=f"x_{i}_{c}_{s}")
            else:
                x[i, c, s] = m.addVar(lb=0, ub=0, vtype=GRB.INTEGER, name=f"x_{i}_{c}_{s}")

# Deviation variables for demand goals
d_minus = {}
d_plus = {}
for c, s in demand:
    d_minus[c, s] = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name=f"d_minus_{c}_{s}")
    d_plus[c, s] = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name=f"d_plus_{c}_{s}")

# Deviation variables for preference goals
g2_minus = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name="g2_minus")
g2_plus = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name="g2_plus")

g3_minus = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name="g3_minus")
g3_plus = m.addVar(lb=0, vtype=GRB.CONTINUOUS, name="g3_plus")

m.update()

# ----------------------
# Constraints
# ----------------------

# Supply constraints
for i in types:
    m.addConstr(
        quicksum(x[i, c, s] for c in cities for s in specialties) <= supply[i],
        name=f"supply_{i}"
    )

# Demand goal constraints
for (c, s), dem in demand.items():
    m.addConstr(
        quicksum(x[i, c, s] for i in types) + d_minus[c, s] - d_plus[c, s] == dem,
        name=f"demand_goal_{c}_{s}"
    )

# Preferred specialty goal (8000)
m.addConstr(
    quicksum(x[i, c, pref_specialty[i]] for i in types for c in cities)
    + g2_minus - g2_plus == 8000,
    name="preferred_specialty_goal"
)

# Preferred city goal (8000)
m.addConstr(
    quicksum(x[i, pref_city[i], s] for i in types for s in specialties)
    + g3_minus - g3_plus == 8000,
    name="preferred_city_goal"
)

# ----------------------
# Multi-objective (Preemptive Goal Programming)
# ----------------------

# Priority 1: minimize unmet demand (underachievement only)
m.setObjectiveN(
    quicksum(d_minus[c, s] for c, s in demand),
    index=0,
    priority=3,
    sense=GRB.MINIMIZE,
    name="Priority1_Demand"
)

# Priority 2: minimize underachievement of preferred specialty
m.setObjectiveN(
    g2_minus,
    index=1,
    priority=2,
    sense=GRB.MINIMIZE,
    name="Priority2_Specialty"
)

# Priority 3: minimize underachievement of preferred city
m.setObjectiveN(
    g3_minus,
    index=2,
    priority=1,
    sense=GRB.MINIMIZE,
    name="Priority3_City"
)

# ----------------------
# Solve
# ----------------------
m.optimize()

# ----------------------
# Output results
# ----------------------
if m.status == GRB.OPTIMAL:
    print("Optimal Solution Found\n")
    for i in types:
        for c in cities:
            for s in specialties:
                if x[i, c, s].x > 0:
                    print(f"Type {i} assigned to {c}, Specialty {s}: {x[i,c,s].x}")
    
    print("\nUnmet Demand Deviations:")
    for c, s in demand:
        print(f"{c}, Specialty {s}, Under: {d_minus[c,s].x}, Over: {d_plus[c,s].x}")
    
    print(f"\nPreferred Specialty Underachievement: {g2_minus.x}")
    print(f"Preferred City Underachievement: {g3_minus.x}")
```
