xB = model.addVar(vtype=GRB.CONTINUOUS, name="Product_B", lb=0)

# Objective function: Maximize profit
model.setObjective(30 * xA + 10 * xB, GRB.MAXIMIZE)

# Constraints

# Production time constraint
model.addConstr(6 * xA + 3 * xB <= 40, name="Time_Constraint")

# Market demand constraint
model.addConstr(xB >= 3 * xA, name="Demand_Constraint")

# Storage constraint for product A
