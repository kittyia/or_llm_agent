from gurobipy import Model, GRB

# Create model
model = Model("Feed_Optimization")

# Data
feeds = range(5)

protein = [3, 2, 1, 6, 18]          # g per g feed
minerals = [1, 0.5, 0.2, 2, 0.5]     # g per g feed
vitamins = [0.5, 1, 0.2, 2, 0.8]     # mg per g feed
price_per_kg = [0.2, 0.7, 0.4, 0.3, 0.8]  # ¥ per kg

# Convert price to ¥ per gram
price = [p / 1000 for p in price_per_kg]

# Decision variables: grams of each feed
x = model.addVars(feeds, lb=0, name="x")

# Objective: Minimize total cost
model.setObjective(sum(price[i] * x[i] for i in feeds), GRB.MINIMIZE)

# Constraints
model.addConstr(sum(protein[i] * x[i] for i in feeds) >= 700, name="Protein")
model.addConstr(sum(minerals[i] * x[i] for i in feeds) >= 30, name="Minerals")
model.addConstr(sum(vitamins[i] * x[i] for i in feeds) >= 100, name="Vitamins")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum Cost: {model.objVal:.6f} ¥")
    for i in feeds:
        print(f"Feed {i+1}: {x[i].x:.6f} grams")
