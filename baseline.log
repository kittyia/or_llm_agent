import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Farm_Optimization")

# Decision variables
corn = model.addVar(lb=0, name="Corn")
wheat = model.addVar(lb=0, name="Wheat")
soybeans = model.addVar(lb=0, name="Soybeans")
