    print(f"Optimal number of cows: {int(cows.X)}")
    print(f"Optimal number of sheep: {int(sheep.X)}")
    print(f"Optimal number of chickens: {int(chickens.X)}")
    print(f"Maximum profit: ${model.objVal:.2f}")
else:
    print("No optimal solution found.")
