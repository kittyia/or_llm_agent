    print(f"Optimal number of trucks from Warehouse A: {x.x}")
    print(f"Optimal number of trucks from Warehouse B: {y.x}")
    print(f"Minimum total transportation cost: {model.objVal} yuan")
else:
    print("No optimal solution found.")
