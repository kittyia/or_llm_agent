A traveling salesman must visit 7 customers at 7 different locations, with the (symmetric) distance matrix as follows:

|  | 1 | 2 | 3 | 4 | 5 | 6 | 7 |
| :---: | :---: | :---: | :---: | :---: | :---: | :---: | :---: |
| 1 | - | 86 | 49 | 57 | 31 | 69 | 50 |
| 2 |  | - | 68 | 79 | 93 | 24 | 5 |
| 3 |  |  | - | 16 | 7 | 72 | 67 |
| 4 |  |  |  | - | 90 | 69 | 1 |
| 5 |  |  |  |  | - | 86 | 59 |
| 6 |  |  |  |  |  | - | 81 |

Formulate a mathematical program to determine the visiting order starting and ending at location 1 to minimize the travel distance, and solve it using COPTPY.
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
N = 7
nodes = range(1, N + 1)

# Distance matrix (symmetric)
dist = {
    (1,2):86,(1,3):49,(1,4):57,(1,5):31,(1,6):69,(1,7):50,
    (2,3):68,(2,4):79,(2,5):93,(2,6):24,(2,7):5,
    (3,4):16,(3,5):7,(3,6):72,(3,7):67,
    (4,5):90,(4,6):69,(4,7):1,
    (5,6):86,(5,7):59,
    (6,7):81
}

# Make symmetric
for i in nodes:
    for j in nodes:
        if i == j:
            continue
        if (i, j) not in dist and (j, i) in dist:
            dist[(i, j)] = dist[(j, i)]

# Model
model = gp.Model("TSP")

# Decision variables
x = model.addVars(nodes, nodes, vtype=GRB.BINARY, name="x")
u = model.addVars(nodes, vtype=GRB.CONTINUOUS, lb=0, ub=N-1, name="u")

# Objective function
model.setObjective(
    gp.quicksum(dist[i, j] * x[i, j] for i in nodes for j in nodes if i != j),
    GRB.MINIMIZE
)

# Constraints

# No self-loops
for i in nodes:
    model.addConstr(x[i, i] == 0)

# Each node has exactly one outgoing arc
for i in nodes:
    model.addConstr(gp.quicksum(x[i, j] for j in nodes if j != i) == 1)

# Each node has exactly one incoming arc
for j in nodes:
    model.addConstr(gp.quicksum(x[i, j] for i in nodes if i != j) == 1)

# MTZ subtour elimination
for i in nodes:
    if i == 1:
        continue
    for j in nodes:
        if j == 1 or i == j:
            continue
        model.addConstr(u[i] - u[j] + (N - 1) * x[i, j] <= N - 2)

# Fix depot order variable
model.addConstr(u[1] == 0)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total distance: {model.objVal}")
    print("Optimal tour:")
    tour = []
    current = 1
    visited = set()
    while True:
        tour.append(current)
        visited.add(current)
        for j in nodes:
            if j not in visited and x[current, j].x > 0.5:
                current = j
                break
        else:
            break
    tour.append(1)
    print(" -> ".join(map(str, tour)))
```
