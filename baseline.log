    print(f"Acres of Corn: {corn.x:.2f}")
    print(f"Acres of Wheat: {wheat.x:.2f}")
    print(f"Acres of Soybeans: {soybeans.x:.2f}")
    print(f"Acres of Sorghum: {sorghum.x:.2f}")
