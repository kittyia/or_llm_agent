A university computer lab hires 4 undergraduates (designated 1, 2, 3, and 4) and 2 graduate students (designated 5 and 6) for duty answering questions. The maximum duty hours from Monday to Friday and the hourly wage for each person are shown in Table 5-9.

Table 5-9
| Student ID | Wage (CNY/h) | Monday | Tuesday | Wednesday | Thursday | Friday |
|------------|--------------|--------|---------|-----------|----------|--------|
| 1          | 10.0         | 6      | 0       | 6         | 0        | 7      |
| 2          | 10.0         | 0      | 6       | 0         | 6        | 0      |
| 3          | 9.9          | 4      | 8       | 3         | 0        | 5      |
| 4          | 9.8          | 5      | 5       | 6         | 0        | 4      |
| 5          | 10.8         | 3      | 0       | 4         | 8        | 0      |
| 6          | 11.3         | 0      | 6       | 0         | 6        | 3      |

The lab operates from 8:00 AM to 10:00 PM, and there must be one and only one student on duty during open hours. It is also required that each undergraduate must work at least 8 hours per week, and each graduate student must work at least 7 hours per week. Additionally, supplement the following requirements: each student can work no more than 2 shifts per week, and no more than 3 students can be scheduled for duty each day. Based on these conditions, establish a new mathematical model.
-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
students = range(1, 7)
days = ["Mon", "Tue", "Wed", "Thu", "Fri"]

# Parameters
wage = {
    1: 10.0, 2: 10.0, 3: 9.9, 4: 9.8, 5: 10.8, 6: 11.3
}

max_hours = {
    (1, "Mon"): 6, (1, "Tue"): 0, (1, "Wed"): 6, (1, "Thu"): 0, (1, "Fri"): 7,
    (2, "Mon"): 0, (2, "Tue"): 6, (2, "Wed"): 0, (2, "Thu"): 6, (2, "Fri"): 0,
    (3, "Mon"): 4, (3, "Tue"): 8, (3, "Wed"): 3, (3, "Thu"): 0, (3, "Fri"): 5,
    (4, "Mon"): 5, (4, "Tue"): 5, (4, "Wed"): 6, (4, "Thu"): 0, (4, "Fri"): 4,
    (5, "Mon"): 3, (5, "Tue"): 0, (5, "Wed"): 4, (5, "Thu"): 8, (5, "Fri"): 0,
    (6, "Mon"): 0, (6, "Tue"): 6, (6, "Wed"): 0, (6, "Thu"): 6, (6, "Fri"): 3,
}

open_hours_per_day = 14  # 8:00 AM to 10:00 PM

# Model
model = gp.Model("Lab_Scheduling")

# Decision variables
x = model.addVars(students, days, vtype=GRB.CONTINUOUS, name="hours", lb=0)
y = model.addVars(students, days, vtype=GRB.BINARY, name="shift")

# Objective: Minimize total wage cost
model.setObjective(
    gp.quicksum(wage[i] * x[i, d] for i in students for d in days),
    GRB.MINIMIZE
)

# Constraints

# Daily coverage: exactly 14 hours per day
for d in days:
    model.addConstr(
        gp.quicksum(x[i, d] for i in students) == open_hours_per_day,
        name=f"coverage_{d}"
    )

# Maximum available hours and linking with shift binary
for i in students:
    for d in days:
        model.addConstr(
            x[i, d] <= max_hours[(i, d)],
            name=f"max_hours_{i}_{d}"
        )
        model.addConstr(
            x[i, d] <= max_hours[(i, d)] * y[i, d],
            name=f"link_{i}_{d}"
        )

# Minimum weekly hours
for i in students:
    if i <= 4:  # undergraduates
        model.addConstr(
            gp.quicksum(x[i, d] for d in days) >= 8,
            name=f"min_week_undergrad_{i}"
        )
    else:  # graduates
        model.addConstr(
            gp.quicksum(x[i, d] for d in days) >= 7,
            name=f"min_week_grad_{i}"
        )

# Each student works no more than 2 shifts per week
for i in students:
    model.addConstr(
        gp.quicksum(y[i, d] for d in days) <= 2,
        name=f"max_shifts_{i}"
    )

# No more than 3 students scheduled per day
for d in days:
    model.addConstr(
        gp.quicksum(y[i, d] for i in students) <= 3,
        name=f"max_students_per_day_{d}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total cost: {model.objVal:.2f} CNY")
    for d in days:
        print(f"\nDay: {d}")
        for i in students:
            if x[i, d].x > 1e-6:
                print(f"  Student {i}: {x[i, d].x:.2f} hours")
else:
    print("No optimal solution found.")
```
