【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Data
devices = ['A', 'B', 'C', 'D']
prep_cost = {'A': 1000, 'B': 920, 'C': 800, 'D': 700}
unit_cost = {'A': 20, 'B': 24, 'C': 16, 'D': 28}
capacity = {'A': 900, 'B': 1000, 'C': 1200, 'D': 1600}
demand = 2000

# Create model
model = Model("Production_Planning")

# Decision variables
x = model.addVars(devices, vtype=GRB.CONTINUOUS, name="Production", lb=0)
y = model.addVars(devices, vtype=GRB.BINARY, name="Enable")

# Objective function: Minimize total cost
model.setObjective(
    sum(prep_cost[i] * y[i] + unit_cost[i] * x[i] for i in devices),
    GRB.MINIMIZE
)

# Constraints

# Demand satisfaction
model.addConstr(sum(x[i] for i in devices) == demand, name="Demand")

# Capacity constraints linked with binary variables
for i in devices:
    model.addConstr(x[i] <= capacity[i] * y[i], name=f"Capacity_{i}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum Total Cost: {model.objVal:.2f} Yuan")
    for i in devices:
        print(f"Device {i}: Enabled = {int(y[i].x)}, Production = {x[i].x:.2f} units")
