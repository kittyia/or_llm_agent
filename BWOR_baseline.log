【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
months = range(1, 13)
cash_flow = {
    1: -12, 2: -10, 3: -8, 4: -10, 5: -4, 6: 5,
    7: -7, 8: -2, 9: 15, 10: 12, 11: -7, 12: 45
}

# Create model
model = gp.Model("Tongxin_Toy_Factory_Financing")

# Decision variables
A = model.addVar(lb=0, name="Annual_Loan")  # Annual loan
m = model.addVars(months, lb=0, name="Monthly_Loan")  # Monthly short-term loans
d = model.addVars(months, lb=0, name="Deposit")  # Monthly deposits
B = model.addVars(months, lb=0, name="End_Balance")  # End-of-month cash balance

# Month 1 balance
model.addConstr(
    B[1] == A + m[1] + cash_flow[1] + 0.004 * d[1],
    name="Balance_1"
)

# Months 2 to 12 balance
for t in range(2, 13):
    model.addConstr(
        B[t] == B[t-1]
               - 1.015 * m[t-1]
               + m[t]
               + cash_flow[t]
               + 0.004 * d[t]
               - 0.01 * A,
        name=f"Balance_{t}"
    )

# Final cash at beginning of next year after repayments
final_cash = B[12] - 1.015 * m[12] - 1.01 * A

# Objective: maximize final cash
model.setObjective(final_cash, GRB.MAXIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Final Cash (thousand yuan): {model.objVal:.4f}")
    print(f"Annual Loan: {A.x:.4f}")
    for t in months:
        print(f"Month {t}: Monthly Loan = {m[t].x:.4f}, Deposit = {d[t].x:.4f}, End Balance = {B[t].x:.4f}")
