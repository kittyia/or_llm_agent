【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Yangtze_Shopping_Mall")

# Data
store_types = {
    1: {"name": "Jewelry", "area": 250, "min": 1, "max": 3, "profit": {1: 9, 2: 8, 3: 7}},
    2: {"name": "Shoes_Hats", "area": 350, "min": 1, "max": 2, "profit": {1: 10, 2: 9}},
    3: {"name": "Department", "area": 800, "min": 1, "max": 3, "profit": {1: 27, 2: 21, 3: 20}},
    4: {"name": "Bookstore", "area": 400, "min": 0, "max": 2, "profit": {1: 16, 2: 10}},
    5: {"name": "Catering", "area": 500, "min": 1, "max": 3, "profit": {1: 17, 2: 15, 3: 12}},
}

total_area = 5000
rent_rate = 0.2

# Decision variables: y[i,k] = 1 if k stores of type i are opened
y = {}
for i in store_types:
    for k in range(store_types[i]["min"], store_types[i]["max"] + 1):
        y[i, k] = model.addVar(vtype=GRB.BINARY, name=f"y_{i}_{k}")

# Constraint: choose exactly one option for each store type
for i in store_types:
    model.addConstr(
        gp.quicksum(y[i, k] for k in range(store_types[i]["min"], store_types[i]["max"] + 1)) == 1,
        name=f"select_one_option_{i}"
    )

# Area constraint
model.addConstr(
    gp.quicksum(
        store_types[i]["area"] * k * y[i, k]
        for i in store_types
        for k in range(store_types[i]["min"], store_types[i]["max"] + 1)
    ) <= total_area,
    name="area_constraint"
)

# Objective: maximize total rental income
model.setObjective(
    gp.quicksum(
        rent_rate * k * store_types[i]["profit"].get(k, 0) * y[i, k]
        for i in store_types
        for k in range(store_types[i]["min"], store_types[i]["max"] + 1)
    ),
    GRB.MAXIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Maximum Rental Income (thousand Yuan): {model.objVal:.2f}")
    for i in store_types:
        for k in range(store_types[i]["min"], store_types[i]["max"] + 1):
            if y[i, k].x > 0.5:
                print(f"{store_types[i]['name']}: {k} stores")
