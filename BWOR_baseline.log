import gurobipy as gp
from gurobipy import GRB

# Data
months = range(6)
demand = [1, 2, 5, 3, 2, 1]  # in hundreds of units
prod_capacity = 4           # 400 units = 4 hundreds
storage_capacity = 3        # 300 units = 3 hundreds

prod_cost = 10000           # per 100 units
fixed_cost = 4000           # per month if production occurs
storage_cost = 1000         # per 100 units per month

# Model
model = gp.Model("Production_Planning")

# Decision variables
production = model.addVars(months, lb=0, ub=prod_capacity, vtype=GRB.CONTINUOUS, name="Production")
inventory = model.addVars(months, lb=0, ub=storage_capacity, vtype=GRB.CONTINUOUS, name="Inventory")
produce_flag = model.addVars(months, vtype=GRB.BINARY, name="ProduceFlag")

# Objective function
model.setObjective(
    gp.quicksum(prod_cost * production[t] + fixed_cost * produce_flag[t] + storage_cost * inventory[t]
                for t in months),
    GRB.MINIMIZE
)

# Constraints

# Production capacity linked with binary variable
for t in months:
    model.addConstr(production[t] <= prod_capacity * produce_flag[t], name=f"ProdCapacity_{t}")

# Inventory balance constraints
for t in months:
    if t == 0:
        model.addConstr(production[t] - demand[t] == inventory[t], name=f"InventoryBalance_{t}")
    else:
        model.addConstr(inventory[t-1] + production[t] - demand[t] == inventory[t],
                        name=f"InventoryBalance_{t}")

# Ending inventory must be zero
model.addConstr(inventory[5] == 0, name="EndingInventory")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal:.2f} yuan")
    for t in months:
        print(f"Month {t+1}: Production = {production[t].x:.2f} (hundreds), "
              f"Inventory = {inventory[t].x:.2f} (hundreds)")
```
