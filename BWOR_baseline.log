model.addConstr(x["Computer_Simulation"] <= x["Computer_Programming"], "CSim_prereq")
model.addConstr(x["Data_Structures"] <= x["Computer_Programming"], "DS_prereq")
model.addConstr(x["Managerial_Statistics"] <= x["Calculus"], "MS_prereq")
model.addConstr(x["Forecasting"] <= x["Managerial_Statistics"], "F_prereq")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum number of courses: {int(model.objVal)}")
    print("Courses to take:")
    for c in courses:
        if x[c].x > 0.5:
            print(c)
