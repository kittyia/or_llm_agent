【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB
import math

# Number of cities
n = 10
cities = range(n)

# Coordinates of cities
coords = {
    0: (0, 0),
    1: (5, 20),
    2: (8, 12),
    3: (7, 4),
    4: (10, 15),
    5: (12, 18),
    6: (18, 18),
    7: (18, 15),
    8: (18, 18),
    9: (20, 17)
}

# Distance matrix
dist = {}
for i in cities:
    for j in cities:
        if i != j:
            dist[i, j] = math.hypot(coords[i][0] - coords[j][0],
                                    coords[i][1] - coords[j][1])

# Create model
model = gp.Model("TSP")

# Decision variables: x[i,j] = 1 if travel from city i to city j
x = model.addVars(dist.keys(), vtype=GRB.BINARY, name="x")

# MTZ variables
u = model.addVars(cities, vtype=GRB.CONTINUOUS, lb=0, ub=n-1, name="u")

# Objective: minimize total distance
model.setObjective(gp.quicksum(dist[i, j] * x[i, j] for i, j in dist), GRB.MINIMIZE)

# Each city has exactly one outgoing edge
for i in cities:
    model.addConstr(gp.quicksum(x[i, j] for j in cities if i != j) == 1)

# Each city has exactly one incoming edge
for j in cities:
    model.addConstr(gp.quicksum(x[i, j] for i in cities if i != j) == 1)

# MTZ subtour elimination constraints
for i in cities:
    for j in cities:
        if i != j and i != 0 and j != 0:
            model.addConstr(u[i] - u[j] + n * x[i, j] <= n - 1)

# Optimize
model.optimize()

# Extract solution
if model.status == GRB.OPTIMAL:
    print(f"Optimal tour length: {model.objVal:.2f}")
    tour = []
    current = 0
    visited = set([0])
    while len(tour) < n:
        for j in cities:
            if current != j and (current, j) in x and x[current, j].X > 0.5:
                tour.append(current + 1)
                current = j
                break
    tour.append(1)
    print("Optimal tour:")
    print(" -> ".join(map(str, tour)))
