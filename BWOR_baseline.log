【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB, quicksum

# Data
workers = ['A', 'B', 'C', 'D', 'E']
stations = ['I', 'II', 'III', 'IV', 'V']

efficiency = {
    ('A','I'):2, ('A','II'):3, ('A','III'):4, ('A','IV'):1, ('A','V'):7,
    ('B','I'):3, ('B','II'):4, ('B','III'):2, ('B','IV'):5, ('B','V'):6,
    ('C','I'):2, ('C','II'):5, ('C','III'):3, ('C','IV'):4, ('C','V'):1,
    ('D','I'):5, ('D','II'):2, ('D','III'):3, ('D','IV'):2, ('D','V'):5,
    ('E','I'):3, ('E','II'):7, ('E','III'):6, ('E','IV'):2, ('E','V'):4,
}

# Create model
model = Model("Assembly_Line_Assignment")

# Decision variables
x = model.addVars(workers, stations, vtype=GRB.BINARY, name="x")

# Objective: maximize total production efficiency
model.setObjective(
    quicksum(efficiency[w, s] * x[w, s] for w in workers for s in stations),
    GRB.MAXIMIZE
)

# Constraints: each worker assigned to exactly one station
for w in workers:
    model.addConstr(quicksum(x[w, s] for s in stations) == 1, name=f"Worker_{w}")

# Constraints: each station assigned exactly one worker
for s in stations:
    model.addConstr(quicksum(x[w, s] for w in workers) == 1, name=f"Station_{s}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Maximum Total Production Efficiency: {model.objVal}")
    for w in workers:
        for s in stations:
            if x[w, s].x > 0.5:
                print(f"Worker {w} is assigned to Station {s}")
