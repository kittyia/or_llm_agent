5.12 There are four individuals — X, Y, Z, and R — and five tasks A, B, C, D, and F. The time (in unspecified units) each person needs to complete each task is shown in Table 5-3. Since there are more tasks than people, the following assignment conditions are considered:(a) One person may take on two tasks, while the other three people each handle one. (b) Either X or Z must take on two tasks, and Y and R each take one. (c) Each person completes one task, but tasks A and B must be completed, while one among C, D, or F may be left unassigned. Objective: For each scenario (a), (b), and (c), determine the assignment plan that results in the minimum total completion time. 

Table 5-3  


<html><body><table><tr><td> Person / Task</td><td>A</td><td>B</td><td>C</td><td>D</td><td>F</td></tr><tr><td>X</td><td>25</td><td>29</td><td>31</td><td>42</td><td>37</td></tr><tr><td>Y</td><td>39</td><td>38</td><td>26</td><td>20</td><td>33</td></tr><tr><td>Z</td><td>34</td><td>27</td><td>28</td><td>40</td><td>32</td></tr><tr><td>R</td><td>24</td><td>42</td><td>36</td><td>23</td><td>45</td></tr></table></body></html>  

-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
persons = ["X", "Y", "Z", "R"]
tasks = ["A", "B", "C", "D", "F"]

time = {
    ("X","A"):25, ("X","B"):29, ("X","C"):31, ("X","D"):42, ("X","F"):37,
    ("Y","A"):39, ("Y","B"):38, ("Y","C"):26, ("Y","D"):20, ("Y","F"):33,
    ("Z","A"):34, ("Z","B"):27, ("Z","C"):28, ("Z","D"):40, ("Z","F"):32,
    ("R","A"):24, ("R","B"):42, ("R","C"):36, ("R","D"):23, ("R","F"):45,
}

def solve_scenario_a():
    m = gp.Model("Scenario_a")
    x = m.addVars(persons, tasks, vtype=GRB.BINARY, name="x")

    # Each task assigned exactly once
    for j in tasks:
        m.addConstr(gp.quicksum(x[i,j] for i in persons) == 1)

    # Total assignments = 5
    m.addConstr(gp.quicksum(x[i,j] for i in persons for j in tasks) == 5)

    # One person gets 2 tasks, others get 1
    y = m.addVars(persons, vtype=GRB.BINARY, name="y")
    for i in persons:
        m.addConstr(gp.quicksum(x[i,j] for j in tasks) == 1 + y[i])
    m.addConstr(gp.quicksum(y[i] for i in persons) == 1)

    m.setObjective(gp.quicksum(time[i,j]*x[i,j] for i in persons for j in tasks), GRB.MINIMIZE)
    m.optimize()

    print("\nScenario (a) Optimal Total Time:", m.objVal)
    for i in persons:
        for j in tasks:
            if x[i,j].x > 0.5:
                print(f"{i} -> {j}")

def solve_scenario_b():
    m = gp.Model("Scenario_b")
    x = m.addVars(persons, tasks, vtype=GRB.BINARY, name="x")

    # Each task assigned exactly once
    for j in tasks:
        m.addConstr(gp.quicksum(x[i,j] for i in persons) == 1)

    # X or Z gets 2 tasks; Y and R get 1
    yX = m.addVar(vtype=GRB.BINARY, name="yX")
    yZ = m.addVar(vtype=GRB.BINARY, name="yZ")

    m.addConstr(gp.quicksum(x["X",j] for j in tasks) == 1 + yX)
    m.addConstr(gp.quicksum(x["Z",j] for j in tasks) == 1 + yZ)
    m.addConstr(gp.quicksum(x["Y",j] for j in tasks) == 1)
    m.addConstr(gp.quicksum(x["R",j] for j in tasks) == 1)
    m.addConstr(yX + yZ == 1)

    m.setObjective(gp.quicksum(time[i,j]*x[i,j] for i in persons for j in tasks), GRB.MINIMIZE)
    m.optimize()

    print("\nScenario (b) Optimal Total Time:", m.objVal)
    for i in persons:
        for j in tasks:
            if x[i,j].x > 0.5:
                print(f"{i} -> {j}")

def solve_scenario_c():
    m = gp.Model("Scenario_c")
    x = m.addVars(persons, tasks, vtype=GRB.BINARY, name="x")

    # Each person assigned exactly one task
    for i in persons:
        m.addConstr(gp.quicksum(x[i,j] for j in tasks) == 1)

    # Each task assigned at most once
    for j in tasks:
        m.addConstr(gp.quicksum(x[i,j] for i in persons) <= 1)

    # Tasks A and B must be assigned
    m.addConstr(gp.quicksum(x[i,"A"] for i in persons) == 1)
    m.addConstr(gp.quicksum(x[i,"B"] for i in persons) == 1)

    # Exactly 4 tasks assigned
    m.addConstr(gp.quicksum(x[i,j] for i in persons for j in tasks) == 4)

    m.setObjective(gp.quicksum(time[i,j]*x[i,j] for i in persons for j in tasks), GRB.MINIMIZE)
    m.optimize()

    print("\nScenario (c) Optimal Total Time:", m.objVal)
    for i in persons:
        for j in tasks:
            if x[i,j].x > 0.5:
                print(f"{i} -> {j}")

if __name__ == "__main__":
    solve_scenario_a()
    solve_scenario_b()
    solve_scenario_c()
```
