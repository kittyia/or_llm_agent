    (2,3): 0.9, (2,4): 1.8, (2,5): 1.2, (2,6): 2.6, (2,7): 2.3, (2,8): 1.1,
    (3,4): 2.6, (3,5): 1.7, (3,6): 2.5, (3,7): 1.9, (3,8): 1.0,
    (4,5): 0.7, (4,6): 1.6, (4,7): 1.5, (4,8): 0.9,
    (5,6): 0.9, (5,7): 1.1, (5,8): 0.8,
    (6,7): 0.6, (6,8): 1.0,
    (7,8): 0.5
}

# Create model
model = gp.Model("Minimum_Spanning_Tree")

# Binary variables for undirected edges
x = model.addVars(edges.keys(), vtype=GRB.BINARY, name="x")

# Directed arcs for flow
arcs = []
for (i,j) in edges:
    arcs.append((i,j))
    arcs.append((j,i))

# Flow variables
f = model.addVars(arcs, vtype=GRB.CONTINUOUS, lb=0, name="f")

# Objective: Minimize total distance
model.setObjective(gp.quicksum(edges[i,j]*x[i,j] for (i,j) in edges), GRB.MINIMIZE)

# Total edges in MST = number of nodes - 1 = 8
model.addConstr(gp.quicksum(x[i,j] for (i,j) in edges) == len(nodes) - 1)

# Flow conservation constraints
for k in nodes:
    inflow = gp.quicksum(f[i,j] for (i,j) in arcs if j == k)
    outflow = gp.quicksum(f[i,j] for (i,j) in arcs if i == k)
    if k == root:
        model.addConstr(outflow - inflow == len(nodes) - 1)
    else:
        model.addConstr(inflow - outflow == 1)

# Capacity constraints
for (i,j) in edges:
    model.addConstr(f[i,j] <= (len(nodes)-1)*x[i,j])
    model.addConstr(f[j,i] <= (len(nodes)-1)*x[i,j])

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum Total Pipeline Length: {model.objVal:.2f} miles")
    print("Selected Pipelines:")
    for (i,j) in edges:
        if x[i,j].x > 0.5:
            print(f"Connect {i} - {j} (Distance: {edges[i,j]} miles)")
