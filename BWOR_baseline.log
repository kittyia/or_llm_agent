        5 & 18 & 0.5 & 0.8 & 0.8 \\
        \bottomrule
    \end{tabular}
\end{table}

The goal is to determine a feed selection plan that both meets the nutritional requirements for animal growth and minimizes the cost.

-------------
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Feed_Optimization")

# Data
protein = [3, 2, 1, 6, 18]        # g per kg
minerals = [1.0, 0.5, 0.2, 2.0, 0.5]  # g per kg
vitamins = [0.5, 1.0, 0.2, 2.0, 0.8]  # mg per kg
price = [0.2, 0.7, 0.4, 0.3, 0.8]     # $ per kg

# Requirements
protein_req = 700
minerals_req = 30
vitamins_req = 100

# Decision variables: kg of each feed
x = model.addVars(5, lb=0, vtype=GRB.CONTINUOUS, name="Feed")

# Objective: minimize total cost
model.setObjective(sum(price[i] * x[i] for i in range(5)), GRB.MINIMIZE)

# Constraints
model.addConstr(sum(protein[i] * x[i] for i in range(5)) >= protein_req, "Protein")
model.addConstr(sum(minerals[i] * x[i] for i in range(5)) >= minerals_req, "Minerals")
model.addConstr(sum(vitamins[i] * x[i] for i in range(5)) >= vitamins_req, "Vitamins")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal total cost:", model.objVal)
    for i in range(5):
        print(f"Feed {i+1} (kg):", x[i].x)
else:
    print("No optimal solution found.")
