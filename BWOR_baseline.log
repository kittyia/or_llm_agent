【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Power_Allocation")

# Sets
stations = ['I', 'II']
cities = ['C1', 'C2', 'C3']

# Supply capacities
supply = {
    'I': 400,
    'II': 450
}

# Cost matrix (Yuan per unit)
cost = {
    ('I', 'C1'): 15, ('I', 'C2'): 18, ('I', 'C3'): 22,
    ('II', 'C1'): 21, ('II', 'C2'): 25, ('II', 'C3'): 16
}

# Decision variables: x[i,j] = electricity supplied from station i to city j
x = model.addVars(stations, cities, vtype=GRB.CONTINUOUS, name="x", lb=0)

# Supply constraints (use all available electricity)
for i in stations:
    model.addConstr(gp.quicksum(x[i, j] for j in cities) == supply[i], name=f"supply_{i}")

# City demand constraints
# City 1: between 290 and 320
model.addConstr(gp.quicksum(x[i, 'C1'] for i in stations) >= 290, name="C1_min")
model.addConstr(gp.quicksum(x[i, 'C1'] for i in stations) <= 320, name="C1_max")

# City 2: fixed at 250
model.addConstr(gp.quicksum(x[i, 'C2'] for i in stations) == 250, name="C2_fixed")

# City 3: between 270 and 350
model.addConstr(gp.quicksum(x[i, 'C3'] for i in stations) >= 270, name="C3_min")
model.addConstr(gp.quicksum(x[i, 'C3'] for i in stations) <= 350, name="C3_max")

# Objective function: minimize total cost
model.setObjective(
    gp.quicksum(cost[i, j] * x[i, j] for i in stations for j in cities),
    GRB.MINIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal:.2f}")
    for i in stations:
        for j in cities:
            print(f"Supply from Station {i} to City {j}: {x[i, j].x:.2f}")
else:
    print("No optimal solution found.")
```
