    ("Freestyle", "Zhao"): 29.2,
    ("Freestyle", "Qian"): 26.4,
    ("Freestyle", "Zhang"): 29.6,
    ("Freestyle", "Wang"): 28.5,
    ("Freestyle", "Zhou"): 31.1,
}

# Model
