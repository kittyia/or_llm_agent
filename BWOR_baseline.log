【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
workshops = ['A', 'B', 'C', 'D', 'E']
locations = ['Urban', 'Alpha', 'Beta']

# Savings (10,000 yuan/year)
savings = {
    ('A', 'Alpha'): 100, ('A', 'Beta'): 100,
    ('B', 'Alpha'): 150, ('B', 'Beta'): 200,
    ('C', 'Alpha'): 100, ('C', 'Beta'): 150,
    ('D', 'Alpha'): 200, ('D', 'Beta'): 150,
    ('E', 'Alpha'): 50,  ('E', 'Beta'): 150,
}

# Transportation volumes C_ik (t/year)
C = {
    ('A','B'): 0,    ('A','C'): 1000, ('A','D'): 1500, ('A','E'): 0,
    ('B','C'): 1400, ('B','D'): 1200, ('B','E'): 0,
    ('C','D'): 0,    ('C','E'): 2000,
    ('D','E'): 700
}

# Transportation cost per ton D_jl (yuan/t)
D = {
    ('Alpha','Alpha'): 500, ('Alpha','Beta'): 1400, ('Alpha','Urban'): 1300,
    ('Beta','Alpha'): 1400, ('Beta','Beta'): 500,   ('Beta','Urban'): 900,
    ('Urban','Alpha'): 1300,('Urban','Beta'): 900,  ('Urban','Urban'): 1000
}

# Model
m = gp.Model("Workshop_Relocation")

# Decision variables
x = m.addVars(workshops, locations, vtype=GRB.BINARY, name="x")

# Each workshop assigned to exactly one location
for i in workshops:
    m.addConstr(gp.quicksum(x[i,j] for j in locations) == 1)

# Capacity constraint: no more than 3 workshops per location
for j in locations:
    m.addConstr(gp.quicksum(x[i,j] for i in workshops) <= 3)

# Objective: Minimize total cost = transport cost - savings
transport_cost = gp.quicksum(
    C[i,k] * D[j,l] * x[i,j] * x[k,l]
    for (i,k) in C
    for j in locations
    for l in locations
)

total_savings = gp.quicksum(
    savings[i,j] * x[i,j]
    for (i,j) in savings
)

m.setObjective(transport_cost - total_savings, GRB.MINIMIZE)

# Optimize
m.optimize()

# Output results
if m.status == GRB.OPTIMAL:
    print("Optimal total cost:", m.objVal)
    for i in workshops:
        for j in locations:
            if x[i,j].x > 0.5:
                print(f"Workshop {i} -> {j}")
