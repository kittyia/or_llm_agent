 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Pastry_Production")

# Decision variables (thousand boxes)
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Product_I")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Product_II")

# Raw material supply constraints (convert tons to kg: 1 ton = 1000 kg)
model.addConstr(1 * x1 + 2 * x2 <= 6000, name="Material_A")
model.addConstr(2 * x1 + 1 * x2 <= 8000, name="Material_B")

# Market constraints
model.addConstr(x2 <= 2, name="Sales_II_Limit")
model.addConstr(x2 - x1 <= 1, name="Sales_Relationship")

# Objective function: maximize wholesale revenue (thousand yuan)
model.setObjective(30 * x1 + 20 * x2, GRB.MAXIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal production of Product I (thousand boxes): {x1.x}")
    print(f"Optimal production of Product II (thousand boxes): {x2.x}")
    print(f"Maximum wholesale revenue (thousand yuan): {model.objVal}")
