 ```python
import gurobipy as gp
from gurobipy import GRB

# տվյալներ
jobs = range(12)
positions = range(12)

pA = [5, 8, 11, 2, 7, 6, 3, 9, 8, 3, 6, 10]
pB = [5, 9, 4, 3, 7, 9, 5, 4, 9, 5, 3, 4]

# route: 1 if A->B (Jobs 1-7), 0 if B->A (Jobs 8-12)
routeAfirst = [1]*7 + [0]*5

M = 1000

model = gp.Model("TwoMachineMixedFlowShop")

# փոփոխականներ
x = model.addVars(jobs, positions, vtype=GRB.BINARY, name="x")
CA = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0, name="CA")
CB = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0, name="CB")
Cmax = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Cmax")

# յուրաքանչյուր job մեկ դիրքում
for i in jobs:
    model.addConstr(gp.quicksum(x[i, k] for k in positions) == 1)

# յուրաքանչյուր դիրքում մեկ job
for k in positions:
    model.addConstr(gp.quicksum(x[i, k] for i in jobs) == 1)

for k in positions:
    pA_k = gp.quicksum(pA[i] * x[i, k] for i in jobs)
    pB_k = gp.quicksum(pB[i] * x[i, k] for i in jobs)
    r_k = gp.quicksum(routeAfirst[i] * x[i, k] for i in jobs)

    if k == 0:
        model.addConstr(CA[k] >= pA_k)
        model.addConstr(CB[k] >= pB_k)
    else:
        model.addConstr(CA[k] >= CA[k-1] + pA_k)
        model.addConstr(CB[k] >= CB[k-1] + pB_k)

    # precedence constraints depending on route
    model.addConstr(CB[k] >= CA[k] + pB_k - M * (1 - r_k))
    model.addConstr(CA[k] >= CB[k] + pA_k - M * r_k)

# makespan
model.addConstr(Cmax >= CA[11])
model.addConstr(Cmax >= CB[11])

model.setObjective(Cmax, GRB.MINIMIZE)

model.optimize()

# արդյունքներ
if model.status == GRB.OPTIMAL:
    sequence = []
    for k in positions:
        for i in jobs:
            if x[i, k].X > 0.5:
                sequence.append(i + 1)
    print("Optimal Job Sequence:", sequence)
    print("Makespan:", Cmax.X)
```
