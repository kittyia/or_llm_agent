import gurobipy as gp
from gurobipy import GRB

# Sets
students = [1, 2, 3, 4, 5, 6]
days = ["Mon", "Tue", "Wed", "Thu", "Fri"]

undergraduates = [1, 2, 3, 4]
graduates = [5, 6]

# Parameters
wage = {
    1: 10.0, 2: 10.0, 3: 9.9, 4: 9.8,
    5: 10.8, 6: 11.3
}

max_hours = {
    (1, "Mon"): 6, (1, "Tue"): 0, (1, "Wed"): 9, (1, "Thu"): 0, (1, "Fri"): 7,
    (2, "Mon"): 0, (2, "Tue"): 9, (2, "Wed"): 0, (2, "Thu"): 6, (2, "Fri"): 0,
    (3, "Mon"): 4, (3, "Tue"): 8, (3, "Wed"): 3, (3, "Thu"): 0, (3, "Fri"): 5,
    (4, "Mon"): 5, (4, "Tue"): 5, (4, "Wed"): 6, (4, "Thu"): 0, (4, "Fri"): 4,
    (5, "Mon"): 3, (5, "Tue"): 0, (5, "Wed"): 4, (5, "Thu"): 8, (5, "Fri"): 0,
    (6, "Mon"): 0, (6, "Tue"): 9, (6, "Wed"): 0, (6, "Thu"): 6, (6, "Fri"): 3,
}

daily_required_hours = 14  # 8:00–22:00

# Model
model = gp.Model("Computer_Lab_Scheduling")

# Decision variables
x = model.addVars(students, days, vtype=GRB.CONTINUOUS, lb=0, name="hours")
y = model.addVars(students, days, vtype=GRB.BINARY, name="assign")

# Objective: Minimize total wage payment
model.setObjective(
    gp.quicksum(wage[i] * x[i, d] for i in students for d in days),
    GRB.MINIMIZE
)

# Constraints

# Daily coverage: exactly 14 hours per day
for d in days:
    model.addConstr(
        gp.quicksum(x[i, d] for i in students) == daily_required_hours,
        name=f"DailyCoverage_{d}"
    )

