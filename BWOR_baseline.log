    Jinyuan Company produces three types of products over a planning period divided into three stages. A production plan needs to be formulated to determine the quantity of each product to be produced at each stage.
 The plan is constrained by market demand, equipment working hours, and financial capital. Relevant data are shown in Table 4-16 and Table 4-17. It is assumed that the initial and final inventories of all products are zero. 

\begin{table}[h]
    \centering
    \caption{Table 4-16: Product Demand at Each Stage}
    \renewcommand{\arraystretch}{1.2}
    \begin{tabular}{c|ccc}
        \toprule
        Demand Stage & Product 1 & Product 2 & Product 3 \\
        \midrule
        1 & 500 & 750 & 900 \\
        2 & 680 & 800 & 800 \\
        3 & 800 & 950 & 1000 \\
        \bottomrule
    \end{tabular}
\end{table}

\begin{table}[h]
    \centering
    \caption{Table 4-17: Resource Consumption per Unit Product and Stage Resource Limits}
    \renewcommand{\arraystretch}{1.2}
    \begin{tabular}{c|ccc|c}
        \toprule
        Item & Product 1 & Product 2 & Product 3 & Stage Resource Limit \\
        \midrule
        Equipment Working Hours (h) & 2.0 & 1.0 & 3.1 & 5000 \\
        Working Capital Occupied (yuan) & 40 & 20 & 55 & 93000 \\
        \bottomrule
    \end{tabular}
\end{table}

The company sets the following three prioritized objectives: 1.Timely delivery to meet demand, minimizing stockouts. The importance of timely delivery for Product 3 is twice that of Products 1 and 2. 2.Minimize overloading of processing equipment at each stage. 3.Ensure that working capital usage does not exceed the limit.Please formulate a mathematical model and optimize it accordingly.

-------------
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB, quicksum

# Sets
products = range(3)   # 0,1,2 -> Product 1,2,3
stages = range(3)     # 0,1,2 -> Stage 1,2,3

# Data
demand = {
    (0,0):500, (1,0):750, (2,0):900,
    (0,1):680, (1,1):800, (2,1):800,
    (0,2):800, (1,2):950, (2,2):1000
}

hours = {0:2.0, 1:1.0, 2:3.1}
capital = {0:40, 1:20, 2:55}

hour_limit = 5000
capital_limit = 93000

# Create model
m = Model("Jinyuan_Production_Planning")

# Decision variables
x = m.addVars(products, stages, lb=0, name="Production")
shortage = m.addVars(products, stages, lb=0, name="Shortage")
inventory = m.addVars(products, stages, lb=0, name="Inventory")
overload = m.addVars(stages, lb=0, name="Overload")
overcapital = m.addVars(stages, lb=0, name="OverCapital")

# Inventory balance constraints
for p in products:
    for t in stages:
        if t == 0:
            m.addConstr(x[p,t] - demand[(p,t)] + shortage[p,t] == inventory[p,t])
        else:
            m.addConstr(inventory[p,t-1] + x[p,t] - demand[(p,t)] + shortage[p,t] == inventory[p,t])

# Final inventory = 0
for p in products:
    m.addConstr(inventory[p,2] == 0)

# Equipment working hours with overload
for t in stages:
    m.addConstr(
        quicksum(hours[p] * x[p,t] for p in products) 
        <= hour_limit + overload[t]
    )

# Capital constraint with overcapital slack
for t in stages:
    m.addConstr(
        quicksum(capital[p] * x[p,t] for p in products)
        <= capital_limit + overcapital[t]
    )

# Multi-objective priorities

# Objective 1: Minimize weighted shortages (Product 3 weight = 2)
m.setObjectiveN(
    quicksum(
        (2 if p == 2 else 1) * shortage[p,t]
        for p in products for t in stages
    ),
    index=0,
    priority=3,
    name="Minimize_Shortage"
)

# Objective 2: Minimize equipment overload
m.setObjectiveN(
    quicksum(overload[t] for t in stages),
    index=1,
    priority=2,
    name="Minimize_Overload"
)

# Objective 3: Minimize capital overuse
m.setObjectiveN(
    quicksum(overcapital[t] for t in stages),
    index=2,
    priority=1,
    name="Minimize_OverCapital"
)

# Optimize
m.optimize()

# Output results
if m.status == GRB.OPTIMAL:
    print("\nOptimal Production Plan:\n")
    for t in stages:
        print(f"Stage {t+1}:")
        for p in products:
            print(f"  Product {p+1} Production: {x[p,t].x:.2f}, Shortage: {shortage[p,t].x:.2f}")
        print(f"  Equipment Overload: {overload[t].x:.2f}")
        print(f"  Capital Overuse: {overcapital[t].x:.2f}")
        print()
