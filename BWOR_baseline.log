import gurobipy as gp
from gurobipy import GRB

# Data
jobs = range(12)
positions = range(12)

processing_A = [5, 8, 11, 2, 7, 6, 3, 9, 8, 3, 6, 10]
processing_B = [5, 9, 4, 3, 7, 9, 5, 4, 9, 5, 3, 4]

# Model
model = gp.Model("Two_Machine_Flowshop")

# Decision variables: x[i,k] = 1 if job i is assigned to position k
x = model.addVars(jobs, positions, vtype=GRB.BINARY, name="x")

# Completion times on machines A and B at position k
C_A = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0, name="C_A")
C_B = model.addVars(positions, vtype=GRB.CONTINUOUS, lb=0, name="C_B")

# Each job is assigned to exactly one position
for i in jobs:
    model.addConstr(gp.quicksum(x[i, k] for k in positions) == 1)

# Each position has exactly one job
for k in positions:
    model.addConstr(gp.quicksum(x[i, k] for i in jobs) == 1)

# Completion time constraints for machine A
for k in positions:
    if k == 0:
        model.addConstr(
            C_A[k] == gp.quicksum(processing_A[i] * x[i, k] for i in jobs)
        )
    else:
        model.addConstr(
            C_A[k] == C_A[k-1] + gp.quicksum(processing_A[i] * x[i, k] for i in jobs)
        )

# Completion time constraints for machine B
for k in positions:
    if k == 0:
        model.addConstr(
            C_B[k] >= C_A[k] + gp.quicksum(processing_B[i] * x[i, k] for i in jobs)
        )
    else:
        model.addConstr(
            C_B[k] >= C_B[k-1] + gp.quicksum(processing_B[i] * x[i, k] for i in jobs)
        )
        model.addConstr(
            C_B[k] >= C_A[k] + gp.quicksum(processing_B[i] * x[i, k] for i in jobs)
        )

# Objective: minimize makespan (completion time of last job on machine B)
model.setObjective(C_B[11], GRB.MINIMIZE)

# Solve
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    sequence = []
    for k in positions:
        for i in jobs:
            if x[i, k].x > 0.5:
                sequence.append(i + 1)
    print("Optimal Job Sequence:", sequence)
    print("Minimum Makespan:", C_B[11].x)
