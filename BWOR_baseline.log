model = gp.Model("Production_Planning")

# Decision variables
production = model.addVars(quarters, name="Production", lb=0)
inventory = model.addVars(quarters, name="Inventory", lb=0)

# Objective function: Minimize total production + holding cost
model.setObjective(
    gp.quicksum(prod_cost[t] * production[t] for t in quarters) +
    gp.quicksum(holding_cost * inventory[t] for t in quarters),
    GRB.MINIMIZE
)

# Constraints

# Production capacity constraints
for t in quarters:
    model.addConstr(production[t] <= capacity[t], name=f"Capacity_{t}")

# Inventory balance constraints
for t in quarters:
    if t == 0:
        model.addConstr(production[t] - demand[t] == inventory[t], name=f"InventoryBalance_{t}")
    else:
        model.addConstr(inventory[t-1] + production[t] - demand[t] == inventory[t],
                        name=f"InventoryBalance_{t}")

# Final inventory should be zero
model.addConstr(inventory[3] == 0, name="FinalInventory")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Production Plan:")
    for t in quarters:
        print(f"Quarter {t+1}: Production = {production[t].x:.2f}, Inventory = {inventory[t].x:.2f}")
    print(f"Minimum Total Cost (thousand yuan): {model.objVal:.2f}")
