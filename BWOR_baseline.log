 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Factory_Production_Planning")

# Products and Machines
products = ["I", "II", "III"]
A_machines = ["A1", "A2"]
B_machines = ["B1", "B2", "B3"]

# Processing times (hours per unit)
proc_time_A = {
    ("I", "A1"): 5, ("I", "A2"): 7,
    ("II", "A1"): 10, ("II", "A2"): 9,
    ("III", "A2"): 12
}

proc_time_B = {
    ("I", "B1"): 6, ("I", "B2"): 4, ("I", "B3"): 7,
    ("II", "B1"): 8,
    ("III", "B2"): 11
}

# Machine available hours
avail_hours = {
    "A1": 6000,
    "A2": 10000,
    "B1": 4000,
    "B2": 7000,
    "B3": 4000
}

# Processing cost ($ per hour)
proc_cost = {
    "A1": 0.05,
    "A2": 0.03,
    "B1": 0.06,
    "B2": 0.11,
    "B3": 0.05
}

# Raw material cost ($ per unit)
raw_cost = {"I": 0.25, "II": 0.35, "III": 0.50}

# Selling price ($ per unit)
sell_price = {"I": 1.25, "II": 2.00, "III": 2.80}

# Decision variables
xA = model.addVars(proc_time_A.keys(), name="xA", lb=0)
xB = model.addVars(proc_time_B.keys(), name="xB", lb=0)

# Flow balance constraints (Stage A output = Stage B input for each product)
for p in products:
    model.addConstr(
        gp.quicksum(xA[p, m] for (pp, m) in proc_time_A if pp == p) ==
        gp.quicksum(xB[p, m] for (pp, m) in proc_time_B if pp == p),
        name=f"FlowBalance_{p}"
    )

# Machine capacity constraints for Stage A
for m in A_machines:
    model.addConstr(
        gp.quicksum(proc_time_A[p, m] * xA[p, m]
                    for (p, mm) in proc_time_A if mm == m)
        <= avail_hours[m],
        name=f"Capacity_{m}"
    )

# Machine capacity constraints for Stage B
for m in B_machines:
    model.addConstr(
        gp.quicksum(proc_time_B[p, m] * xB[p, m]
                    for (p, mm) in proc_time_B if mm == m)
        <= avail_hours[m],
        name=f"Capacity_{m}"
    )

# Total production per product (from Stage B)
production = {
    p: gp.quicksum(xB[p, m] for (pp, m) in proc_time_B if pp == p)
    for p in products
}

# Objective: Maximize profit
revenue = gp.quicksum(sell_price[p] * production[p] for p in products)
raw_material = gp.quicksum(raw_cost[p] * production[p] for p in products)
processing = (
    gp.quicksum(proc_time_A[p, m] * proc_cost[m] * xA[p, m]
                for (p, m) in proc_time_A) +
    gp.quicksum(proc_time_B[p, m] * proc_cost[m] * xB[p, m]
                for (p, m) in proc_time_B)
)

model.setObjective(revenue - raw_material - processing, GRB.MAXIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: ${model.objVal:.2f}\n")
    print("Production Plan:")
    for p in products:
        print(f"Product {p}: {production[p].getValue():.2f} units")
    print("\nDetailed Machine Allocation (Stage A):")
    for (p, m) in proc_time_A:
        if xA[p, m].x > 1e-6:
            print(f"xA[{p},{m}] = {xA[p,m].x:.2f}")
    print("\nDetailed Machine Allocation (Stage B):")
    for (p, m) in proc_time_B:
        if xB[p, m].x > 1e-6:
            print(f"xB[{p},{m}] = {xB[p,m].x:.2f}")
```
