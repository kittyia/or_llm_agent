【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Candy_Production_Optimization")

# Decision variables: production quantities (kg)
x = model.addVar(lb=0, name="Brand_X")
y = model.addVar(lb=0, name="Brand_Y")
z = model.addVar(lb=0, name="Brand_Z")

# Raw material usage in each brand (kg)
a_x = model.addVar(lb=0, name="A_in_X")
b_x = model.addVar(lb=0, name="B_in_X")
c_x = model.addVar(lb=0, name="C_in_X")

a_y = model.addVar(lb=0, name="A_in_Y")
b_y = model.addVar(lb=0, name="B_in_Y")
c_y = model.addVar(lb=0, name="C_in_Y")

a_z = model.addVar(lb=0, name="A_in_Z")
b_z = model.addVar(lb=0, name="B_in_Z")
c_z = model.addVar(lb=0, name="C_in_Z")

# Composition constraints
model.addConstr(a_x + b_x + c_x == x, "Comp_X")
model.addConstr(a_y + b_y + c_y == y, "Comp_Y")
model.addConstr(a_z + b_z + c_z == z, "Comp_Z")

# Proportion constraints
model.addConstr(a_x >= 0.60 * x, "A_prop_X")
model.addConstr(c_x <= 0.20 * x, "C_prop_X")

model.addConstr(a_y >= 0.30 * y, "A_prop_Y")
model.addConstr(c_y <= 0.50 * y, "C_prop_Y")

model.addConstr(c_z <= 0.60 * z, "C_prop_Z")

# Raw material availability constraints
model.addConstr(a_x + a_y + a_z <= 2000, "A_limit")
model.addConstr(b_x + b_y + b_z <= 2500, "B_limit")
model.addConstr(c_x + c_y + c_z <= 1200, "C_limit")

# Costs and prices
price_x, price_y, price_z = 3.40, 2.85, 2.25
proc_x, proc_y, proc_z = 0.50, 0.40, 0.30
cost_A, cost_B, cost_C = 2.00, 1.50, 1.00

# Objective: Maximize profit
revenue = price_x * x + price_y * y + price_z * z
processing_cost = proc_x * x + proc_y * y + proc_z * z
raw_material_cost = (
    cost_A * (a_x + a_y + a_z) +
    cost_B * (b_x + b_y + b_z) +
    cost_C * (c_x + c_y + c_z)
)

profit = revenue - processing_cost - raw_material_cost

model.setObjective(profit, GRB.MAXIMIZE)

# Solve
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: ${model.objVal:.2f}")
    print(f"Produce {x.x:.2f} kg of Brand X")
    print(f"Produce {y.x:.2f} kg of Brand Y")
    print(f"Produce {z.x:.2f} kg of Brand Z")
else:
    print("No optimal solution found.")
```
