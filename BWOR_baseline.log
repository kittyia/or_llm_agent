【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
years = [1, 2, 3, 4]
max_life = 4

purchase_price = {1: 2.5, 2: 2.6, 3: 2.8, 4: 3.1}
salvage_value = {1: 2.0, 2: 1.6, 3: 1.3, 4: 1.1}
operating_cost = {1: 0.3, 2: 0.8, 3: 1.5, 4: 2.0}

# Precompute cumulative operating cost for k years
cumulative_om = {}
for k in range(1, max_life + 1):
    cumulative_om[k] = sum(operating_cost[i] for i in range(1, k + 1))

# Model
model = gp.Model("Machine_Replacement")

# Decision variables: x[t,k] = 1 if machine bought at start of year t and kept for k years
x = {}
for t in years:
    for k in range(1, max_life + 1):
        if t + k - 1 <= 4:
            x[t, k] = model.addVar(vtype=GRB.BINARY, name=f"x_{t}_{k}")

model.update()

# Coverage constraints: each year must be covered exactly once
for y in years:
    model.addConstr(
        gp.quicksum(x[t, k] for (t, k) in x if t <= y <= t + k - 1) == 1,
        name=f"cover_year_{y}"
    )

# Objective: minimize total cost
model.setObjective(
    gp.quicksum(
        x[t, k] * (purchase_price[t] + cumulative_om[k] - salvage_value[k])
        for (t, k) in x
    ),
    GRB.MINIMIZE
)

# Solve
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal:.4f} thousand yuan")
    print("Replacement Plan:")
    for (t, k) in x:
        if x[t, k].x > 0.5:
            print(f"  Buy at start of year {t}, keep for {k} year(s)")
