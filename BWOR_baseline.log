\end{table}

If factory $A_3$ is built, its annual production cost is estimated to be 1200 thousand yuan;if $A_4$ is built, the annual production cost is 1500 thousand yuan.The goal is to decide whether to build factory $A_3$ or $A_4$ in order to minimize the total annual cost, which includes all transportation costs and the production cost(in thousand yuan) of the new factory.

-------------
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
factories = ['A1', 'A2', 'A3', 'A4']
demand_points = ['B1', 'B2', 'B3', 'B4']

# Transportation costs (thousand yuan per kt)
cost = {
    ('A1','B1'):2, ('A1','B2'):9, ('A1','B3'):3, ('A1','B4'):4,
    ('A2','B1'):8, ('A2','B2'):3, ('A2','B3'):5, ('A2','B4'):7,
    ('A3','B1'):7, ('A3','B2'):6, ('A3','B3'):1, ('A3','B4'):2,
    ('A4','B1'):4, ('A4','B2'):5, ('A4','B3'):2, ('A4','B4'):5,
}

# Production capacities (kt/year)
capacity = {
    'A1': 400,
    'A2': 600,
    'A3': 200,
    'A4': 200
}

# Demand (kt/year)
demand = {
    'B1': 350,
    'B2': 400,
    'B3': 300,
    'B4': 150
}

# Fixed production cost for new factories (thousand yuan)
fixed_cost = {
    'A3': 1200,
    'A4': 1500
}

# Model
model = gp.Model("Factory_Selection_Transportation")

# Decision variables
x = model.addVars(factories, demand_points, lb=0, name="x")  # shipment quantities
y = model.addVars(['A3', 'A4'], vtype=GRB.BINARY, name="y")  # build decision

# Objective: transportation cost + fixed cost
transport_cost = gp.quicksum(cost[i,j] * x[i,j] for i in factories for j in demand_points)
fixed_cost_term = gp.quicksum(fixed_cost[i] * y[i] for i in ['A3','A4'])
model.setObjective(transport_cost + fixed_cost_term, GRB.MINIMIZE)

# Demand satisfaction constraints
for j in demand_points:
    model.addConstr(gp.quicksum(x[i,j] for i in factories) == demand[j], name=f"Demand_{j}")

# Capacity constraints for existing factories
model.addConstr(gp.quicksum(x['A1',j] for j in demand_points) <= capacity['A1'], name="Cap_A1")
model.addConstr(gp.quicksum(x['A2',j] for j in demand_points) <= capacity['A2'], name="Cap_A2")

# Capacity constraints for new factories (only if built)
model.addConstr(gp.quicksum(x['A3',j] for j in demand_points) <= capacity['A3'] * y['A3'], name="Cap_A3")
model.addConstr(gp.quicksum(x['A4',j] for j in demand_points) <= capacity['A4'] * y['A4'], name="Cap_A4")

# Only one new factory can be built
model.addConstr(y['A3'] + y['A4'] == 1, name="One_Factory")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal} thousand yuan")
    for i in factories:
        for j in demand_points:
            if x[i,j].x > 1e-6:
                print(f"Ship {x[i,j].x:.2f} kt from {i} to {j}")
    for i in ['A3','A4']:
        print(f"Build {i}: {int(y[i].x)}")
