【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Transshipment_Problem")

# Nodes
supply_nodes = ['X', 'Y']
demand_nodes = ['A', 'B', 'C']
all_nodes = ['X', 'Y', 'A', 'B', 'C']

# Supply and demand
supply = {'X': 70, 'Y': 55}
demand = {'A': 35, 'B': 40, 'C': 50}

# Distance matrix (cost per ton)
distance = {
    ('X', 'Y'): 12, ('Y', 'X'): 10,
    ('X', 'A'): 10, ('X', 'B'): 14, ('X', 'C'): 12,
    ('Y', 'A'): 15, ('Y', 'B'): 12, ('Y', 'C'): 18,
    ('A', 'B'): 14, ('A', 'C'): 11,
    ('B', 'A'): 10, ('B', 'C'): 4,
    ('C', 'A'): 8,  ('C', 'B'): 12
}

# Decision variables: flow from i to j
x = model.addVars(distance.keys(), lb=0, name="flow")

# Objective: minimize total transportation distance
model.setObjective(
    gp.quicksum(distance[i, j] * x[i, j] for (i, j) in distance),
    GRB.MINIMIZE
)

# Flow conservation constraints

# Supply nodes
for i in supply_nodes:
    model.addConstr(
        gp.quicksum(x[i, j] for (ii, j) in distance if ii == i) -
        gp.quicksum(x[j, i] for (j, ii) in distance if ii == i)
        == supply[i],
        name=f"supply_balance_{i}"
    )

# Demand nodes
for i in demand_nodes:
    model.addConstr(
        gp.quicksum(x[j, i] for (j, ii) in distance if ii == i) -
        gp.quicksum(x[i, j] for (ii, j) in distance if ii == i)
        == demand[i],
        name=f"demand_balance_{i}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Distance: {model.objVal}")
    for (i, j) in distance:
        if x[i, j].x > 1e-6:
            print(f"Ship {x[i, j].x} tons from {i} to {j}")
```
