# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total time: {model.objVal:.2f} seconds")
    print("Assignment:")
    for s in strokes:
        for a in athletes:
            if x[s, a].x > 0.5:
                print(f"{s}: {a}")
