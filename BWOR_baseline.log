    ('A2', 'B1'): 20, ('A2', 'B2'): 40, ('A2', 'B3'): 15, ('A2', 'B4'): 30, ('A2', 'B5'): 30,
    ('A3', 'B1'): 30, ('A3', 'B2'): 35, ('A3', 'B3'): 40, ('A3', 'B4'): 55, ('A3', 'B5'): 25,
}

# Model
