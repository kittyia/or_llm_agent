【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
origins = ["I", "II", "III"]
destinations = ["A", "B", "C", "D", "E"]

# Supply
supply = {
    "I": 50,
    "II": 100,
    "III": 150
}

# Demand
demand = {
    "A": 25,
    "B": 115,
    "C": 60,
    "D": 30,
    "E": 70
}

# Transportation cost
cost = {
    ("I", "A"): 10, ("I", "B"): 15, ("I", "C"): 20, ("I", "D"): 20, ("I", "E"): 40,
    ("II", "A"): 20, ("II", "B"): 10, ("II", "C"): 15, ("II", "D"): 30, ("II", "E"): 30,
    ("III", "A"): 30, ("III", "B"): 35, ("III", "C"): 40, ("III", "D"): 55, ("III", "E"): 25
}

# Create model
model = gp.Model("Transportation_Problem")

# Decision variables
x = model.addVars(origins, destinations, vtype=GRB.CONTINUOUS, name="x", lb=0)

# Objective function
model.setObjective(
    gp.quicksum(cost[i, j] * x[i, j] for i in origins for j in destinations),
    GRB.MINIMIZE
)

# Supply constraints
for i in origins:
    model.addConstr(
        gp.quicksum(x[i, j] for j in destinations) == supply[i],
        name=f"Supply_{i}"
    )

# Demand constraints
for j in destinations:
    model.addConstr(
        gp.quicksum(x[i, j] for i in origins) == demand[j],
        name=f"Demand_{j}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal}\n")
    print("Optimal Transportation Plan:")
    for i in origins:
        for j in destinations:
            if x[i, j].x > 1e-6:
                print(f"Ship {x[i, j].x:.2f} units from {i} to {j}")
```
