-------------
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Diet_Goal_Programming")

# Decision variables: quantity (units of 500g)
milk = model.addVar(lb=0, name="Milk")
beef = model.addVar(lb=0, name="Beef")
eggs = model.addVar(lb=0, name="Eggs")

# Deviation variables for vitamin goals
dA_minus = model.addVar(lb=0, name="dA_minus")
dA_plus  = model.addVar(lb=0, name="dA_plus")

dC_minus = model.addVar(lb=0, name="dC_minus")
dC_plus  = model.addVar(lb=0, name="dC_plus")

dD_minus = model.addVar(lb=0, name="dD_minus")
dD_plus  = model.addVar(lb=0, name="dD_plus")

# Vitamin goal constraints
model.addConstr(1*milk + 1*beef + 10*eggs + dA_minus - dA_plus == 1, "Vitamin_A")
model.addConstr(100*milk + 10*beef + 10*eggs + dC_minus - dC_plus == 30, "Vitamin_C")
model.addConstr(10*milk + 100*beef + 10*eggs + dD_minus - dD_plus == 10, "Vitamin_D")

# Cholesterol and cost expressions
cholesterol = 70*milk + 50*beef + 120*eggs
cost = 1.5*milk + 8*beef + 4*eggs

# Priority weights (Preemptive goal programming using large weights)
P1 = 1e6  # Highest priority: minimize vitamin underachievement
P2 = 1e3  # Second priority: minimize cholesterol
P3 = 1    # Third priority: minimize cost

# Objective function
model.setObjective(
    P1*(dA_minus + dC_minus + dD_minus) +
    P2*cholesterol +
    P3*cost,
    GRB.MINIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution:")
    print(f"Milk (500g units): {milk.X}")
    print(f"Beef (500g units): {beef.X}")
    print(f"Eggs (500g units): {eggs.X}")
    print("\nDeviation Variables:")
    print(f"dA_minus: {dA_minus.X}, dA_plus: {dA_plus.X}")
    print(f"dC_minus: {dC_minus.X}, dC_plus: {dC_plus.X}")
    print(f"dD_minus: {dD_minus.X}, dD_plus: {dD_plus.X}")
    print(f"\nTotal Cholesterol: {cholesterol.getValue()}")
    print(f"Total Cost: {cost.getValue()}")
    print(f"\nObjective Value: {model.ObjVal}")
