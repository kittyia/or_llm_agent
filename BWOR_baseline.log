import gurobipy as gp
from gurobipy import GRB

# Data
departments = [1, 2, 3]
X = [0, 1, 2, 3]
Y = [0, 1, 2, 3]

# Profit tables r_i(x,y)
r = {
    1: {
        (0,0):0,(0,1):1,(0,2):3,(0,3):6,
        (1,0):4,(1,1):5,(1,2):6,(1,3):7,
        (2,0):5,(2,1):6,(2,2):7,(2,3):8,
        (3,0):6,(3,1):7,(3,2):8,(3,3):9
    },
    2: {
        (0,0):0,(0,1):2,(0,2):4,(0,3):6,
        (1,0):1,(1,1):4,(1,2):6,(1,3):7,
        (2,0):4,(2,1):6,(2,2):8,(2,3):9,
        (3,0):6,(3,1):8,(3,2):10,(3,3):11
    },
    3: {
        (0,0):0,(0,1):3,(0,2):5,(0,3):8,
        (1,0):2,(1,1):5,(1,2):7,(1,3):9,
        (2,0):4,(2,1):7,(2,2):9,(2,3):11,
        (3,0):6,(3,1):9,(3,2):11,(3,3):13
    }
}

# Total available resources
total_x = 3
total_y = 3

# Model
model = gp.Model("Resource_Allocation")

# Decision variables: z[i,x,y] = 1 if department i receives (x,y)
z = model.addVars(departments, X, Y, vtype=GRB.BINARY, name="z")

# Each department chooses exactly one (x,y) combination
for i in departments:
    model.addConstr(gp.quicksum(z[i,x,y] for x in X for y in Y) == 1)

# Resource constraints
model.addConstr(
    gp.quicksum(x * z[i,x,y] for i in departments for x in X for y in Y) == total_x
)

model.addConstr(
    gp.quicksum(y * z[i,x,y] for i in departments for x in X for y in Y) == total_y
)

# Objective: maximize total profit
model.setObjective(
    gp.quicksum(r[i][(x,y)] * z[i,x,y] for i in departments for x in X for y in Y),
    GRB.MAXIMIZE
)

# Solve
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Profit: {model.objVal}")
    for i in departments:
        for x in X:
            for y in Y:
                if z[i,x,y].x > 0.5:
                    print(f"Department {i}: x = {x}, y = {y}, profit = {r[i][(x,y)]}")
