-------------
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Production_Planning")

# Data
products = ['I', 'II', 'III']
resources = ['A', 'B', 'C']

resource_amount = {'A': 500, 'B': 300, 'C': 100}

consumption = {
    ('A', 'I'): 2, ('A', 'II'): 4, ('A', 'III'): 8,
    ('B', 'I'): 2, ('B', 'II'): 3, ('B', 'III'): 4,
    ('C', 'I'): 1, ('C', 'II'): 2, ('C', 'III'): 3,
}

variable_cost = {'I': 4, 'II': 5, 'III': 6}
fixed_cost = {'I': 100, 'II': 150, 'III': 200}
selling_price = {'I': 8, 'II': 10, 'III': 12}

# Profit per unit
unit_profit = {p: selling_price[p] - variable_cost[p] for p in products}

# Decision variables
x = model.addVars(products, vtype=GRB.CONTINUOUS, name="Production", lb=0)
y = model.addVars(products, vtype=GRB.BINARY, name="Produce")

# Big-M values (maximum feasible production for each product)
M = {}
for p in products:
    M[p] = min(resource_amount[r] / consumption[(r, p)] for r in resources)

# Resource constraints
for r in resources:
    model.addConstr(
        sum(consumption[(r, p)] * x[p] for p in products) <= resource_amount[r],
        name=f"Resource_{r}"
    )

# Linking constraints
for p in products:
    model.addConstr(x[p] <= M[p] * y[p], name=f"Link_{p}")

# Objective function: Maximize total profit
model.setObjective(
    sum(unit_profit[p] * x[p] - fixed_cost[p] * y[p] for p in products),
    GRB.MAXIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Profit: {model.objVal}")
    for p in products:
        print(f"Production of Product {p}: {x[p].x}")
        print(f"Produce Product {p} (0/1): {y[p].x}")
