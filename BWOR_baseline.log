【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Factory_Investment_Optimization")

# Data
factories = {
    1: {
        1: {"investment": 0, "return": 0},
        2: {"investment": 1, "return": 5},
        3: {"investment": 2, "return": 6},
    },
    2: {
        1: {"investment": 0, "return": 0},
        2: {"investment": 2, "return": 8},
        3: {"investment": 3, "return": 9},
        4: {"investment": 4, "return": 12},
    },
    3: {
        1: {"investment": 0, "return": 0},
        2: {"investment": 1, "return": 3},
    }
}

budget = 5

# Decision variables
x = {}
for i in factories:
    for j in factories[i]:
        x[i, j] = model.addVar(vtype=GRB.BINARY, name=f"x_{i}_{j}")

# Objective function: maximize total return
model.setObjective(
    gp.quicksum(factories[i][j]["return"] * x[i, j] 
                for i in factories 
                for j in factories[i]),
    GRB.MAXIMIZE
)

# Constraint: each factory selects exactly one plan
for i in factories:
    model.addConstr(
        gp.quicksum(x[i, j] for j in factories[i]) == 1,
        name=f"OnePlan_Factory_{i}"
    )

# Budget constraint
model.addConstr(
    gp.quicksum(factories[i][j]["investment"] * x[i, j] 
                for i in factories 
                for j in factories[i]) <= budget,
    name="BudgetConstraint"
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Return: {model.objVal} million yuan")
    print("Selected Plans:")
    for i in factories:
        for j in factories[i]:
            if x[i, j].x > 0.5:
                print(f"Factory {i}: Plan {j} "
                      f"(Investment: {factories[i][j]['investment']}, "
                      f"Return: {factories[i][j]['return']})")
else:
    print("No optimal solution found.")
