import gurobipy as gp
from gurobipy import GRB
import math

# -----------------------------
# Data
# -----------------------------

cities = ["A", "B", "C", "D", "E", "F"]

# Sailing times (days)
sailing_time = {
    ("A","A"):0, ("A","B"):1, ("A","C"):2, ("A","D"):14, ("A","E"):7, ("A","F"):7,
    ("B","A"):1, ("B","B"):0, ("B","C"):3, ("B","D"):13, ("B","E"):8, ("B","F"):8,
    ("C","A"):2, ("C","B"):3, ("C","C"):0, ("C","D"):15, ("C","E"):5, ("C","F"):5,
    ("D","A"):14, ("D","B"):13, ("D","C"):15, ("D","D"):0, ("D","E"):17, ("D","F"):20,
    ("E","A"):7, ("E","B"):8, ("E","C"):5, ("E","D"):17, ("E","E"):0, ("E","F"):3,
    ("F","A"):7, ("F","B"):8, ("F","C"):5, ("F","D"):20, ("F","E"):3, ("F","F"):0,
}

# Route data: (origin, destination, sailings per day)
routes = {
    1: ("E", "D", 3),
    2: ("B", "C", 2),
    3: ("A", "F", 1),
    4: ("D", "B", 1),
}

loading_time = 1  # days
unloading_time = 1  # days

# -----------------------------
# Model
# -----------------------------

model = gp.Model("Minimum_Number_of_Ships")

# Decision variables: ships assigned to each route
ships = model.addVars(routes.keys(), vtype=GRB.INTEGER, name="Ships")

# Objective: minimize total ships
model.setObjective(gp.quicksum(ships[r] for r in routes), GRB.MINIMIZE)

# Constraints: ships must cover required cycle time
for r in routes:
    origin, destination, sailings_per_day = routes[r]
    
    travel_time = sailing_time[(origin, destination)]
    
    # Round trip cycle time (sailing both directions + loading/unloading at both ends)
    cycle_time = travel_time + sailing_time[(destination, origin)] + 2 * (loading_time + unloading_time)
    
    required_ships = sailings_per_day * cycle_time
    
    model.addConstr(ships[r] >= required_ships, name=f"Route_{r}_Requirement")

# Optimize
model.optimize()

# -----------------------------
# Output Results
# -----------------------------

if model.status == GRB.OPTIMAL:
    print(f"Minimum number of ships required: {int(model.objVal)}\n")
    for r in routes:
        print(f"Route {r}: {int(ships[r].x)} ships")
else:
    print("No optimal solution found.")
