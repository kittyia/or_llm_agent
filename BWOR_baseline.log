import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Hongyin_Fund_Planning")

# Decision variables
R = model.addVar(lb=0, name="Initial_Fund")

xA = model.addVar(lb=0, ub=60, name="Bond_A")
xB = model.addVar(lb=0, ub=90, name="Bond_B")
xC = model.addVar(lb=0, ub=50, name="Bond_C")

D2003 = model.addVar(lb=0, name="Deposit_2003")
D2004 = model.addVar(lb=0, name="Deposit_2004")
D2005 = model.addVar(lb=0, name="Deposit_2005")
D2006 = model.addVar(lb=0, name="Deposit_2006")

# Constraints

# Year 2003 balance
model.addConstr(R == 100 + xA + xB + D2003, "Balance_2003")

# Year 2004 balance
model.addConstr(1.04 * D2003 == 150 + xC + D2004, "Balance_2004")

# Year 2005 balance
model.addConstr(1.04 * D2004 + 1.25 * xB == 120 + D2005, "Balance_2005")

# Year 2006 balance
model.addConstr(1.04 * D2005 + 1.30 * xC + 1.40 * xA == 110 + D2006, "Balance_2006")

# Objective: Minimize initial funds raised
model.setObjective(R, GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum Initial Funds Required: {R.X:.2f} thousand dollars")
    print(f"Bond A Investment: {xA.X:.2f}")
    print(f"Bond B Investment: {xB.X:.2f}")
    print(f"Bond C Investment: {xC.X:.2f}")
    print(f"Deposit in 2003: {D2003.X:.2f}")
    print(f"Deposit in 2004: {D2004.X:.2f}")
    print(f"Deposit in 2005: {D2005.X:.2f}")
    print(f"Deposit in 2006: {D2006.X:.2f}")
