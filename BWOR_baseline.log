    ("Backstroke", "Wang"): 37.0,
    ("Backstroke", "Zhou"): 35.4,
    ("Breaststroke", "Zhao"): 43.4,
    ("Breaststroke", "Qian"): 33.1,
    ("Breaststroke", "Zhang"): 42.2,
    ("Breaststroke", "Wang"): 34.7,
    ("Breaststroke", "Zhou"): 41.8,
    ("Butterfly", "Zhao"): 33.3,
    ("Butterfly", "Qian"): 28.5,
    ("Butterfly", "Zhang"): 38.9,
    ("Butterfly", "Wang"): 30.4,
