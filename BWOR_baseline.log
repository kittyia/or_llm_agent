【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun"]
products = ["I", "II", "III", "IV", "V", "VI", "VII"]
machines = ["Grinding", "Upright", "Horizontal", "Boring", "Planer"]

# Parameters
profit = {
    "I": 100, "II": 60, "III": 80, "IV": 40,
    "V": 110, "VI": 90, "VII": 30
}

storage_cost = 5
storage_limit = 100
final_inventory_required = 50

# Machine-hours per unit (0 if not required)
mh = {
    ("Grinding","I"):0.5, ("Grinding","II"):0.7, ("Grinding","III"):0, ("Grinding","IV"):0,
    ("Grinding","V"):0.3, ("Grinding","VI"):0.2, ("Grinding","VII"):0.5,
    ("Upright","I"):0.1, ("Upright","II"):0.2, ("Upright","III"):0, ("Upright","IV"):0.3,
    ("Upright","V"):0, ("Upright","VI"):0.6, ("Upright","VII"):0,
    ("Horizontal","I"):0.2, ("Horizontal","II"):0, ("Horizontal","III"):0.8, ("Horizontal","IV"):0,
    ("Horizontal","V"):0, ("Horizontal","VI"):0, ("Horizontal","VII"):0.6,
    ("Boring","I"):0.05, ("Boring","II"):0.03, ("Boring","III"):0, ("Boring","IV"):0.07,
    ("Boring","V"):0.1, ("Boring","VI"):0, ("Boring","VII"):0.08,
    ("Planer","I"):0, ("Planer","II"):0, ("Planer","III"):0.01, ("Planer","IV"):0,
    ("Planer","V"):0.05, ("Planer","VI"):0, ("Planer","VII"):0.05,
}

# Machine counts
machine_count = {
    "Grinding":4,
    "Upright":2,
    "Horizontal":3,
    "Boring":1,
    "Planer":1
}

# Maintenance schedule (machines unavailable)
maintenance = {
    "Jan":{"Grinding":1},
    "Feb":{"Horizontal":2},
    "Mar":{"Boring":1},
    "Apr":{"Upright":1},
    "May":{"Grinding":1,"Upright":1},
    "Jun":{"Planer":1,"Horizontal":1}
}

# Monthly demand
demand = {
    "Jan":{"I":500,"II":1000,"III":300,"IV":300,"V":800,"VI":200,"VII":100},
    "Feb":{"I":600,"II":500,"III":200,"IV":0,"V":400,"VI":300,"VII":150},
    "Mar":{"I":300,"II":600,"III":0,"IV":0,"V":500,"VI":400,"VII":100},
    "Apr":{"I":200,"II":300,"III":400,"IV":500,"V":200,"VI":0,"VII":100},
    "May":{"I":0,"II":100,"III":500,"IV":100,"V":1000,"VI":300,"VII":0},
    "Jun":{"I":500,"II":500,"III":100,"IV":300,"V":1100,"VI":500,"VII":60}
}

# Available hours per machine per month
hours_per_machine = 24 * 2 * 8  # 384 hours

available_hours = {}
for m in months:
    available_hours[m] = {}
    for mach in machines:
        unavailable = maintenance.get(m, {}).get(mach, 0)
        available_machines = machine_count[mach] - unavailable
        available_hours[m][mach] = available_machines * hours_per_machine

# Model
model = gp.Model("Production_Planning")

# Decision variables
x = model.addVars(months, products, name="Production", lb=0)
s = model.addVars(months, products, name="Sales", lb=0)
inv = model.addVars(months, products, name="Inventory", lb=0)

# Objective: maximize profit - storage cost
model.setObjective(
    gp.quicksum(profit[p] * s[m,p] for m in months for p in products)
    - gp.quicksum(storage_cost * inv[m,p] for m in months for p in products),
    GRB.MAXIMIZE
)

# Constraints

# Inventory balance
for p in products:
    for i, m in enumerate(months):
        if i == 0:
            model.addConstr(x[m,p] - s[m,p] == inv[m,p], name=f"InvBal_{m}_{p}")
        else:
            prev = months[i-1]
            model.addConstr(inv[prev,p] + x[m,p] - s[m,p] == inv[m,p],
                            name=f"InvBal_{m}_{p}")

# Final inventory requirement
for p in products:
    model.addConstr(inv["Jun",p] == final_inventory_required,
                    name=f"FinalInv_{p}")

# Storage limit
for m in months:
    for p in products:
        model.addConstr(inv[m,p] <= storage_limit,
                        name=f"StorageLimit_{m}_{p}")

# Demand constraints
for m in months:
    for p in products:
        model.addConstr(s[m,p] <= demand[m][p],
                        name=f"Demand_{m}_{p}")

# Machine capacity constraints
for m in months:
    for mach in machines:
        model.addConstr(
            gp.quicksum(mh[(mach,p)] * x[m,p] for p in products)
            <= available_hours[m][mach],
            name=f"Capacity_{m}_{mach}"
        )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Profit: {model.objVal:.2f}\n")
    for m in months:
        print(f"Month: {m}")
        for p in products:
            print(f"  Product {p}: Production={x[m,p].x:.2f}, Sales={s[m,p].x:.2f}, Inventory={inv[m,p].x:.2f}")
        print()
