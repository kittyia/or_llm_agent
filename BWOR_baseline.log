【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Blended_Liquor_Production")

# Sets
grades = ['I', 'II', 'III']
brands = ['Red', 'Yellow', 'Blue']

# Data
supply = {'I': 1500, 'II': 2000, 'III': 1000}
cost = {'I': 6.0, 'II': 4.5, 'III': 3.0}
price = {'Red': 5.5, 'Yellow': 5.0, 'Blue': 4.8}

# Decision variables: amount of grade i used in brand j
x = model.addVars(grades, brands, name="x", lb=0)

# Total production of each brand
total = model.addVars(brands, name="Total", lb=0)

# Slack variable for Red production shortfall
s_red = model.addVar(name="Red_Shortfall", lb=0)

# Link total production with grade usage
for j in brands:
    model.addConstr(total[j] == gp.quicksum(x[i, j] for i in grades), name=f"TotalDef_{j}")

# Supply constraints
for i in grades:
    model.addConstr(gp.quicksum(x[i, j] for j in brands) <= supply[i], name=f"Supply_{i}")

# Blending requirements (strictly enforced as hard constraints)

# Red: Grade III < 10%, Grade I > 50%
model.addConstr(x['III', 'Red'] <= 0.10 * total['Red'], name="Red_GradeIII")
model.addConstr(x['I', 'Red'] >= 0.50 * total['Red'], name="Red_GradeI")

# Yellow: Grade III < 70%, Grade I > 20%
model.addConstr(x['III', 'Yellow'] <= 0.70 * total['Yellow'], name="Yellow_GradeIII")
model.addConstr(x['I', 'Yellow'] >= 0.20 * total['Yellow'], name="Yellow_GradeI")

# Blue: Grade III < 50%, Grade I > 10%
model.addConstr(x['III', 'Blue'] <= 0.50 * total['Blue'], name="Blue_GradeIII")
model.addConstr(x['I', 'Blue'] >= 0.10 * total['Blue'], name="Blue_GradeI")

# Red production target with slack
model.addConstr(total['Red'] + s_red >= 2000, name="Red_Target")

# Profit calculation
revenue = gp.quicksum(price[j] * total[j] for j in brands)
total_cost = gp.quicksum(cost[i] * gp.quicksum(x[i, j] for j in brands) for i in grades)
profit = revenue - total_cost

# Multi-objective settings
# Priority 2: Maximize profit
model.setObjectiveN(profit, index=0, priority=2, sense=GRB.MAXIMIZE)

# Priority 1: Minimize Red shortfall
model.setObjectiveN(-s_red, index=1, priority=1, sense=GRB.MAXIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Maximum Profit: {profit.getValue():.2f}")
    for j in brands:
        print(f"{j} Production: {total[j].X:.2f} kg")
        for i in grades:
            print(f"  Grade {i} used: {x[i,j].X:.2f} kg")
    print(f"Red Shortfall: {s_red.X:.2f} kg")
```
