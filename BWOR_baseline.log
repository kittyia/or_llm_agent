from gurobipy import Model, GRB

# Data
months = [1, 2, 3, 4]
buy_price = {1: 10, 2: 9, 3: 11, 4: 15}
sell_price = {1: 12, 2: 9, 3: 13, 4: 17}
capacity = 1000
initial_inventory = 500

# Create model
model = Model("Warehouse_Planning")

# Decision variables
buy = model.addVars(months, vtype=GRB.INTEGER, name="Buy", lb=0)
sell = model.addVars(months, vtype=GRB.INTEGER, name="Sell", lb=0)
inventory = model.addVars(months, vtype=GRB.INTEGER, name="Inventory", lb=0)

# Objective: Maximize total profit
model.setObjective(
    sum(sell_price[k] * sell[k] - buy_price[k] * buy[k] for k in months),
    GRB.MAXIMIZE
)

# Constraints

# Inventory balance constraints
for k in months:
    if k == 1:
        model.addConstr(
            inventory[k] == initial_inventory - sell[k],
            name=f"InventoryBalance_{k}"
        )
    else:
        model.addConstr(
            inventory[k] == inventory[k-1] + buy[k-1] - sell[k],
            name=f"InventoryBalance_{k}"
        )

# Warehouse capacity constraints
for k in months:
    model.addConstr(inventory[k] <= capacity, name=f"Capacity_{k}")

# Sales cannot exceed available inventory
for k in months:
    if k == 1:
        model.addConstr(sell[k] <= initial_inventory, name=f"SalesLimit_{k}")
    else:
        model.addConstr(sell[k] <= inventory[k-1] + buy[k-1], name=f"SalesLimit_{k}")

# Solve model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal}")
    for k in months:
        print(f"Month {k}: Buy = {buy[k].x}, Sell = {sell[k].x}, Inventory End = {inventory[k].x}")
