【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Garage_Construction_Scheduling")

# Task data
tasks = {
    'a': 10, 'b': 8, 'c': 6, 'd': 16, 'e': 24,
    'f': 4, 'g': 4, 'h': 10, 'i': 4, 'j': 12,
    'k': 16, 'L': 8, 'm': 24, 'n': 4
}

# Predecessor relationships
predecessors = {
    'a': [],
    'b': [],
    'c': ['a', 'b'],
    'd': ['b'],
    'e': ['c'],
    'f': ['d', 'e'],
    'g': ['f'],
    'h': ['f'],
    'i': ['f'],
    'j': ['g'],
    'k': ['h', 'i', 'j'],
    'L': ['c'],
    'm': ['L'],
    'n': ['k', 'm']
}

# Decision variables: start times
start = model.addVars(tasks.keys(), lb=0, name="Start")

# Project completion time
makespan = model.addVar(lb=0, name="Makespan")

# Precedence constraints
for task in tasks:
    for pred in predecessors[task]:
        model.addConstr(start[task] >= start[pred] + tasks[pred],
                        name=f"prec_{pred}_{task}")

# Makespan constraints
for task in tasks:
    model.addConstr(makespan >= start[task] + tasks[task],
                    name=f"makespan_{task}")

# Objective: minimize makespan
model.setObjective(makespan, GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Shortest project duration: {makespan.X} days\n")
    for task in tasks:
        print(f"Task {task}: Start = {start[task].X}, Finish = {start[task].X + tasks[task]}")
