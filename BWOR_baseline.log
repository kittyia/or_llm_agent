import gurobipy as gp
from gurobipy import GRB

# Data
machines = ['A', 'B', 'C', 'D']
setup_cost = {'A': 1000, 'B': 920, 'C': 800, 'D': 700}
unit_cost = {'A': 20, 'B': 24, 'C': 16, 'D': 28}
capacity = {'A': 900, 'B': 1000, 'C': 1200, 'D': 1600}
demand = 2000

# Create model
model = gp.Model("Production_Planning")

# Decision variables
x = model.addVars(machines, vtype=GRB.CONTINUOUS, name="Production", lb=0)
y = model.addVars(machines, vtype=GRB.BINARY, name="Setup")

# Objective function
model.setObjective(
    gp.quicksum(setup_cost[i] * y[i] + unit_cost[i] * x[i] for i in machines),
    GRB.MINIMIZE
)

# Demand constraint
model.addConstr(gp.quicksum(x[i] for i in machines) == demand, name="Demand")

# Capacity constraints
for i in machines:
    model.addConstr(x[i] <= capacity[i] * y[i], name=f"Capacity_{i}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {model.objVal:.2f} Yuan\n")
    for i in machines:
        print(f"Machine {i}:")
        print(f"  Setup Decision: {y[i].x}")
        print(f"  Production Quantity: {x[i].x:.2f}")
else:
    print("No optimal solution found.")
