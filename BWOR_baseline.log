 ```python
import gurobipy as gp
from gurobipy import GRB

# Distance matrix
distance = {
    (1,1):0, (1,2):6, (1,3):7, (1,4):9,
    (2,1):8, (2,2):0, (2,3):9, (2,4):7,
    (3,1):5, (3,2):8, (3,3):0, (3,4):8,
    (4,1):6, (4,2):5, (4,3):5, (4,4):0
}

nodes = [1,2,3,4]

# Create model
model = gp.Model("TSP")

# Decision variables: x[i,j] = 1 if travel from i to j
x = model.addVars(nodes, nodes, vtype=GRB.BINARY, name="x")

# MTZ variables
u = model.addVars(nodes, vtype=GRB.CONTINUOUS, lb=0, ub=len(nodes)-1, name="u")

# Objective: minimize total distance
model.setObjective(gp.quicksum(distance[i,j]*x[i,j] for i in nodes for j in nodes if i != j), GRB.MINIMIZE)

# Constraint: each city has exactly one outgoing arc
for i in nodes:
    model.addConstr(gp.quicksum(x[i,j] for j in nodes if j != i) == 1)

# Constraint: each city has exactly one incoming arc
for j in nodes:
    model.addConstr(gp.quicksum(x[i,j] for i in nodes if i != j) == 1)

# Eliminate self-loops
for i in nodes:
    model.addConstr(x[i,i] == 0)

# MTZ subtour elimination constraints
n = len(nodes)
for i in nodes:
    for j in nodes:
        if i != j and i != 1 and j != 1:
            model.addConstr(u[i] - u[j] + n * x[i,j] <= n - 1)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal tour:")
    tour = []
    current = 1
    visited = set([1])
    tour.append(1)
    while len(visited) < n:
        for j in nodes:
            if x[current,j].X > 0.5:
                tour.append(j)
                visited.add(j)
                current = j
                break
    tour.append(1)
    print(" -> ".join(map(str, tour)))
    print("Total distance:", model.objVal)
```
