y3 = model.addVar(vtype=GRB.BINARY, name="Use_LargeTruck")

# Objective function: Minimize total pollution
model.setObjective(40 * x1 + 70 * x2 + 100 * x3, GRB.MINIMIZE)

# Constraints

# Demand requirement
model.addConstr(10 * x1 + 20 * x2 + 50 * x3 >= 300, name="Demand")

# Total trip limit
model.addConstr(x1 + x2 + x3 <= 20, name="TotalTrips")

# Individual trip bounds
model.addConstr(x1 <= 8, name="MaxMotorcycle")
model.addConstr(x2 <= 15, name="MaxSmallTruck")
model.addConstr(x3 <= 6, name="MaxLargeTruck")

# Exactly two transportation methods selected
model.addConstr(y1 + y2 + y3 == 2, name="SelectTwoMethods")

# Linking constraints
model.addConstr(x1 <= 8 * y1, name="LinkMotorcycle")
model.addConstr(x2 <= 15 * y2, name="LinkSmallTruck")
model.addConstr(x3 <= 6 * y3, name="LinkLargeTruck")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal solution found:")
    print(f"Motorcycle trips: {x1.X}")
    print(f"Small truck trips: {x2.X}")
    print(f"Large truck trips: {x3.X}")
    print(f"Total pollution: {model.ObjVal}")
else:
    print("No optimal solution found.")
