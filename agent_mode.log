【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Zhang_Family_Trip")

# Decision variables (binary)
x_H = model.addVar(vtype=GRB.BINARY, name="Harry")
x_He = model.addVar(vtype=GRB.BINARY, name="Hermione")
x_R = model.addVar(vtype=GRB.BINARY, name="Ron")
x_F = model.addVar(vtype=GRB.BINARY, name="Fred")
x_G = model.addVar(vtype=GRB.BINARY, name="George")

# Objective function (Ginny's cost is fixed at 1500)
model.setObjective(
    1200 * x_H +
    1650 * x_He +
    750 * x_R +
    800 * x_F +
    800 * x_G +
    1500,
    GRB.MINIMIZE
)

# Constraints

# At most four children total (Ginny already included)
model.addConstr(x_H + x_He + x_R + x_F + x_G <= 3, name="Max_Children")

# At least three children total (Ginny already included)
model.addConstr(x_H + x_He + x_R + x_F + x_G >= 2, name="Min_Children")

# Harry and Fred cannot both go
model.addConstr(x_H + x_F <= 1, name="Harry_Fred")

# Harry and George cannot both go
model.addConstr(x_H + x_G <= 1, name="Harry_George")

# If George goes, Fred must go
model.addConstr(x_G <= x_F, name="George_requires_Fred")

# If George goes, Hermione must go
model.addConstr(x_G <= x_He, name="George_requires_Hermione")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal total cost:", model.objVal)
    print("Children going on the trip:")
    print("Ginny (mandatory)")
    if x_H.x > 0.5:
        print("Harry")
    if x_He.x > 0.5:
        print("Hermione")
    if x_R.x > 0.5:
        print("Ron")
    if x_F.x > 0.5:
        print("Fred")
    if x_G.x > 0.5:
        print("George")
else:
    print("No optimal solution found.")
```
