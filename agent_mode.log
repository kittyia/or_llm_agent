【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("TwoStage_Mixing_Problem")

# -----------------------
# Variables
# -----------------------

# Stage 1 variables (A, B, D into mixing tank)
y_AA = model.addVar(lb=0, name="y_AA")
y_BA = model.addVar(lb=0, name="y_BA")
y_DA = model.addVar(lb=0, name="y_DA")

y_AB = model.addVar(lb=0, name="y_AB")
y_BB = model.addVar(lb=0, name="y_BB")
y_DB = model.addVar(lb=0, name="y_DB")

# Stage 2 variables (C added)
x_CA = model.addVar(lb=0, name="x_CA")
x_CB = model.addVar(lb=0, name="x_CB")

# Final product quantities
Q_A = model.addVar(lb=0, name="Q_A")
Q_B = model.addVar(lb=0, name="Q_B")

model.update()

# -----------------------
# Constraints
# -----------------------

# Product quantity definitions
model.addConstr(Q_A == y_AA + y_BA + y_DA + x_CA, name="Prod_A_Def")
model.addConstr(Q_B == y_AB + y_BB + y_DB + x_CB, name="Prod_B_Def")

# Demand constraints
model.addConstr(Q_A <= 100, name="Demand_A")
model.addConstr(Q_B <= 200, name="Demand_B")

# Sulfur constraints
model.addConstr(
    0.03 * y_AA + 0.01 * y_BA + 0.01 * y_DA + 0.02 * x_CA
    <= 0.025 * Q_A,
    name="Sulfur_A"
)

model.addConstr(
    0.03 * y_AB + 0.01 * y_BB + 0.01 * y_DB + 0.02 * x_CB
    <= 0.015 * Q_B,
    name="Sulfur_B"
)

# Raw material D supply limit
model.addConstr(y_DA + y_DB <= 50, name="Supply_D")

# -----------------------
# Objective Function
# -----------------------

revenue = 9.15 * (Q_A + Q_B)
cost = (
    6 * (y_AA + y_AB)
    + 16 * (y_BA + y_BB)
    + 15 * (y_DA + y_DB)
    + 10 * (x_CA + x_CB)
)

model.setObjective(revenue - cost, GRB.MAXIMIZE)

# -----------------------
# Solve
# -----------------------

model.optimize()

# -----------------------
# Output Results
# -----------------------

if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.4f} (thousand yuan)")
    for v in model.getVars():
        if v.x > 1e-6:
            print(f"{v.varName} = {v.x:.4f}")
else:
    print("No optimal solution found.")
```
