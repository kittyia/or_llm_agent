x2 = model.addVar(vtype=GRB.CONTINUOUS, name="x2", lb=0)

# Objective function: Minimize total fuel cost
model.setObjective(50 * x1 + 70 * x2, GRB.MINIMIZE)

# Constraints
# Production requirement: x1 + x2 >= 3
model.addConstr(x1 + x2 >= 3, name="Production")

# Time capacity constraint: 2x1 + 3x2 <= 24
model.addConstr(2 * x1 + 3 * x2 <= 24, name="TimeCapacity")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    print(f"x1 = {x1.X}")
    print(f"x2 = {x2.X}")
    print(f"Minimum Cost = {model.ObjVal}")
else:
    print("No optimal solution found.")
