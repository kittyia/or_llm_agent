【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Data
# -----------------------------
T = range(6)  # 0=Jan,...,5=Jun

D = [20000, 40000, 42000, 35000, 19000, 18500]

p = 300
c_r = 90
c_o = 200
c_h = 15
c_b = 35
c_rw = 30
c_ot = 40
c_hire = 5000
c_fire = 8000

a = 5
H_regular = 160
H_ot_max = 20

W0 = 1000
I0 = 15000
B0 = 0

# -----------------------------
# Model
# -----------------------------
m = gp.Model("Foldable_Table_Planning")

# Decision variables
P = m.addVars(T, lb=0, name="Production")
O = m.addVars(T, lb=0, name="Outsource")
I = m.addVars(T, lb=0, name="Inventory")
B = m.addVars(T, lb=0, name="Backorder")
W = m.addVars(T, lb=0, name="Workforce")
H = m.addVars(T, lb=0, name="Hire")
F = m.addVars(T, lb=0, name="Fire")
OT = m.addVars(T, lb=0, name="Overtime")

# -----------------------------
# Objective (Minimize total cost)
# -----------------------------
m.setObjective(
    gp.quicksum(
        c_r * P[t]
        + c_o * O[t]
        + c_h * I[t]
        + c_b * B[t]
        + (H_regular * c_rw) * W[t]
        + c_ot * OT[t]
        + c_hire * H[t]
        + c_fire * F[t]
        for t in T
    ),
    GRB.MINIMIZE
)

# -----------------------------
# Constraints
# -----------------------------

# 1. Inventory–Backorder balance
for t in T:
    if t == 0:
        m.addConstr(
            I0 - B0 + P[t] + O[t] - D[t] == I[t] - B[t],
            name=f"InvBal_{t}"
        )
    else:
        m.addConstr(
            I[t-1] - B[t-1] + P[t] + O[t] - D[t] == I[t] - B[t],
            name=f"InvBal_{t}"
        )

# 2. Workforce balance
for t in T:
    if t == 0:
        m.addConstr(
            W[t] == W0 + H[t] - F[t],
            name=f"WorkforceBal_{t}"
        )
    else:
        m.addConstr(
            W[t] == W[t-1] + H[t] - F[t],
            name=f"WorkforceBal_{t}"
        )

# 3. Production capacity
for t in T:
    m.addConstr(
        a * P[t] <= H_regular * W[t] + OT[t],
        name=f"Capacity_{t}"
    )

# 4. Overtime limit
for t in T:
    m.addConstr(
        OT[t] <= H_ot_max * W[t],
        name=f"OTLimit_{t}"
    )

# 5. Terminal conditions
m.addConstr(I[5] >= 10000, name="TerminalInventory")
m.addConstr(B[5] == 0, name="TerminalBackorder")

# -----------------------------
# Optimize
# -----------------------------
m.optimize()

# -----------------------------
# Results
# -----------------------------
if m.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {m.objVal:,.2f}")
    total_revenue = sum(p * D[t] for t in T)
    print(f"Total Revenue (constant): {total_revenue:,.2f}")
    print(f"Total Net Profit: {total_revenue - m.objVal:,.2f}\n")

    months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun"]

    for t in T:
        print(f"Month {months[t]}:")
        print(f"  Workforce     : {W[t].x:,.2f}")
        print(f"  Hire           : {H[t].x:,.2f}")
        print(f"  Fire           : {F[t].x:,.2f}")
        print(f"  Production     : {P[t].x:,.2f}")
        print(f"  Outsourcing    : {O[t].x:,.2f}")
        print(f"  Overtime Hours : {OT[t].x:,.2f}")
        print(f"  Ending Inventory: {I[t].x:,.2f}")
        print(f"  Ending Backorder: {B[t].x:,.2f}")
        print("-" * 40)
else:
    print("No optimal solution found.")
```
