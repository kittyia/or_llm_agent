import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Project_Scheduling")

# Activity durations
durations = {
    "A": 4,
    "B": 3,
    "C": 5,
    "D": 2,
    "E": 10,
    "F": 10,
    "G": 1
}

# Create start time variables
s = {}
for act in durations:
    s[act] = model.addVar(lb=0.0, vtype=GRB.CONTINUOUS, name=f"s_{act}")

# Precedence constraints
model.addConstr(s["G"] >= s["A"] + durations["A"], name="A_to_G")
model.addConstr(s["D"] >= s["A"] + durations["A"], name="A_to_D")
model.addConstr(s["F"] >= s["E"] + durations["E"], name="E_to_F")
model.addConstr(s["F"] >= s["G"] + durations["G"], name="G_to_F")
model.addConstr(s["C"] >= s["D"] + durations["D"], name="D_to_C")
model.addConstr(s["C"] >= s["F"] + durations["F"], name="F_to_C")
model.addConstr(s["B"] >= s["F"] + durations["F"], name="F_to_B")

# Objective: Minimize machine rental cost
# Rental period = (finish of B) - (start of A)
rental_period = (s["B"] + durations["B"]) - s["A"]
model.setObjective(5000 * rental_period, GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("\nOptimal Start Times:")
    for act in durations:
        print(f"{act}: {s[act].X:.2f}")

    rental_days = (s["B"].X + durations["B"]) - s["A"].X
    machine_cost = 5000 * rental_days
    work_cost = 1000 * sum(durations.values())
    total_cost = machine_cost + work_cost

    print(f"\nMachine Rental Duration: {rental_days:.2f} days")
    print(f"Machine Rental Cost: {machine_cost:.2f} Euros")
    print(f"Work Cost (constant): {work_cost:.2f} Euros")
    print(f"Total Cost: {total_cost:.2f} Euros")
else:
    print("No optimal solution found.")
