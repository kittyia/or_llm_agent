【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Production_Planning")

# Decision variables
x1 = model.addVar(vtype=GRB.CONTINUOUS, name="x1", lb=0)  # Units of product A
x2 = model.addVar(vtype=GRB.CONTINUOUS, name="x2", lb=0)  # Units of product B
h = model.addVar(vtype=GRB.CONTINUOUS, name="h", lb=0)    # Overtime hours

# Set objective: Maximize profit minus overtime cost
model.setObjective(5000 * x1 + 11000 * x2 - 100 * h, GRB.MAXIMIZE)

# Add constraints
model.addConstr(6 * x1 + 12 * x2 <= 200, name="Steel")
model.addConstr(8 * x1 + 20 * x2 <= 300, name="Aluminum")
model.addConstr(11 * x1 + 24 * x2 - h <= 300, name="Labor")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    print(f"Units of Product A (x1): {x1.X:.4f}")
    print(f"Units of Product B (x2): {x2.X:.4f}")
    print(f"Overtime Hours (h): {h.X:.4f}")
    print(f"Maximum Profit: {model.ObjVal:.2f} yuan")
else:
    print("No optimal solution found.")
```
