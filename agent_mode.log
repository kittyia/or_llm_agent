import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Farm_Optimization")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Corn")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Wheat")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Soybeans")
x4 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="Sorghum")

# Objective function
model.setObjective(
    1500 * x1 + 1200 * x2 + 1800 * x3 + 1600 * x4,
    GRB.MAXIMIZE
)

# Constraints
model.addConstr(x1 + x2 + x3 + x4 <= 100, name="Total_Land")
model.addConstr(x1 - 2 * x2 >= 0, name="Corn_Wheat")
model.addConstr(2 * x3 - x4 >= 0, name="Soybean_Sorghum")
model.addConstr(x2 - 3 * x4 == 0, name="Wheat_Sorghum")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution:")
    print(f"Corn (acres): {x1.X}")
    print(f"Wheat (acres): {x2.X}")
    print(f"Soybeans (acres): {x3.X}")
    print(f"Sorghum (acres): {x4.X}")
    print(f"Maximum Profit: ${model.objVal}")
else:
    print("No optimal solution found.")
