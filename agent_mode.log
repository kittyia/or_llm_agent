【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Animal_Feed_Optimization")

# Decision variables (kg of each feed per day)
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x1")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x2")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x3")
x4 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x4")
x5 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x5")

# Objective function: Minimize total cost
model.setObjective(
    0.2 * x1 + 0.7 * x2 + 0.4 * x3 + 0.3 * x4 + 0.8 * x5,
    GRB.MINIMIZE
)

# Nutritional constraints
# Protein constraint (g)
model.addConstr(
    3 * x1 + 2 * x2 + 1 * x3 + 6 * x4 + 18 * x5 >= 700,
    name="Protein"
)

# Mineral constraint (g)
model.addConstr(
    1 * x1 + 0.5 * x2 + 0.2 * x3 + 2 * x4 + 0.5 * x5 >= 30,
    name="Minerals"
)

# Vitamin constraint (mg)
model.addConstr(
    0.5 * x1 + 1 * x2 + 0.2 * x3 + 2 * x4 + 0.8 * x5 >= 100,
    name="Vitamins"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal solution found:")
    print(f"x1 = {x1.X:.4f} kg")
    print(f"x2 = {x2.X:.4f} kg")
    print(f"x3 = {x3.X:.4f} kg")
    print(f"x4 = {x4.X:.4f} kg")
    print(f"x5 = {x5.X:.4f} kg")
    print(f"Minimum total cost = {model.objVal:.4f} ¥")
else:
    print("No optimal solution found.")
```
