【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Grain_Trading_Optimization")

# Decision variables
x = model.addVars(3, lb=0, name="x")  # purchase quantities x[0], x[1], x[2]
y = model.addVars(3, lb=0, name="y")  # sales quantities y[0], y[1], y[2]
I = model.addVars(3, lb=0, name="I")  # inventory levels I[0], I[1], I[2]

# Parameters
c = [2.85, 3.05, 2.90]  # purchase prices
p = [3.10, 3.25, 2.95]  # selling prices
I0 = 1000
F0 = 20000
capacity = 5000

# Objective function
model.setObjective(
    gp.quicksum(p[t] * y[t] - c[t] * x[t] for t in range(3)),
    GRB.MAXIMIZE
)

# Inventory balance constraints
model.addConstr(I[0] == I0 + x[0] - y[0], name="Inventory_balance_1")
model.addConstr(I[1] == I[0] + x[1] - y[1], name="Inventory_balance_2")
model.addConstr(I[2] == I[1] + x[2] - y[2], name="Inventory_balance_3")

# Warehouse capacity constraints
for t in range(3):
    model.addConstr(I[t] <= capacity, name=f"Capacity_{t+1}")

# Month 1 sales constraint (only initial inventory available)
model.addConstr(y[0] <= I0, name="Sales_limit_month1")

# Ending inventory requirement
model.addConstr(I[2] == 2000, name="Ending_inventory")

# Cash feasibility constraint
model.addConstr(
    gp.quicksum(c[t] * x[t] for t in range(3)) <=
    F0 + gp.quicksum(p[t] * y[t] for t in range(3)),
    name="Cash_constraint"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal objective value (Total Profit):", model.objVal)
    for t in range(3):
        print(f"Month {t+1}:")
        print(f"  Purchase x[{t+1}] =", x[t].x)
        print(f"  Sales    y[{t+1}] =", y[t].x)
        print(f"  Inventory I[{t+1}] =", I[t].x)
else:
    print("No optimal solution found.")
```
