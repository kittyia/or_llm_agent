【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Hiring_Optimization")

# Decision variables
xA = model.addVar(vtype=GRB.BINARY, name="xA")
xB = model.addVar(vtype=GRB.BINARY, name="xB")
xC = model.addVar(vtype=GRB.BINARY, name="xC")
xD = model.addVar(vtype=GRB.BINARY, name="xD")
xE = model.addVar(vtype=GRB.BINARY, name="xE")

# Objective function: Minimize total salary cost
model.setObjective(
    8100 * xA +
    20000 * xB +
    21000 * xC +
    3000 * xD +
    8000 * xE,
    GRB.MINIMIZE
)

# Hiring quantity constraints
model.addConstr(xA + xB + xC + xD + xE >= 2, name="min_hires")
model.addConstr(xA + xB + xC + xD + xE <= 3, name="max_hires")

# Budget constraint
model.addConstr(
    8100 * xA +
    20000 * xB +
    21000 * xC +
    3000 * xD +
    8000 * xE <= 35000,
    name="budget"
)

# Education requirement (at least one Master’s or Doctorate)
model.addConstr(xB + xC >= 1, name="education_requirement")

# Work experience requirement (at least 12 years)
model.addConstr(
    3 * xA +
    10 * xB +
    4 * xC +
    3 * xD +
    7 * xE >= 12,
    name="experience_requirement"
)

# Mutual exclusivity (A and E)
model.addConstr(xA + xE <= 1, name="mutual_exclusivity")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total salary cost: ${model.objVal:.2f}")
    print("Hiring decisions:")
    for var in model.getVars():
        print(f"{var.varName} = {int(var.x)}")
else:
    print("No optimal solution found.")
```
