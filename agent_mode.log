from gurobipy import Model, GRB

# Create model
model = Model("Microcomputer_Goal_Programming")

# Decision variables
x1 = model.addVar(lb=0, name="x1")  # Model A
x2 = model.addVar(lb=0, name="x2")  # Model B

# Deviational variables
d1_minus = model.addVar(lb=0, name="d1_minus")
d1_plus  = model.addVar(lb=0, name="d1_plus")

d2_minus = model.addVar(lb=0, name="d2_minus")
d2_plus  = model.addVar(lb=0, name="d2_plus")

d3_minus = model.addVar(lb=0, name="d3_minus")
d3_plus  = model.addVar(lb=0, name="d3_plus")

d4_minus = model.addVar(lb=0, name="d4_minus")
d4_plus  = model.addVar(lb=0, name="d4_plus")

d5_minus = model.addVar(lb=0, name="d5_minus")
d5_plus  = model.addVar(lb=0, name="d5_plus")

# Goal constraints
model.addConstr(300*x1 + 450*x2 + d1_minus - d1_plus == 10000, "Profit_Goal")
model.addConstr(x1 + d2_minus - d2_plus == 10, "Min_A_Goal")
model.addConstr(x2 + d3_minus - d3_plus == 15, "Min_B_Goal")
model.addConstr(4*x1 + 6*x2 + d4_minus - d4_plus == 150, "Process_I_Goal")
model.addConstr(3*x1 + 2*x2 + d5_minus - d5_plus == 70, "Process_II_Goal")

# Set preemptive (hierarchical) objectives
model.ModelSense = GRB.MINIMIZE

# Priority 1: Minimize profit shortfall
model.setObjectiveN(d1_minus, index=0, priority=3)

# Priority 2: Minimize contractual violations
model.setObjectiveN(d2_minus + d3_minus, index=1, priority=2)

# Priority 3: Process utilization goals
model.setObjectiveN(d4_minus + d4_plus + d5_minus, index=2, priority=1)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"x1 (Model A production): {x1.X}")
    print(f"x2 (Model B production): {x2.X}")
    print(f"Total Profit: {300*x1.X + 450*x2.X}")
    print("\nDeviational Variables:")
    for v in model.getVars():
        if "d" in v.VarName:
            print(f"{v.VarName}: {v.X}")
else:
    print("No optimal solution found.")
```
