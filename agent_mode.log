【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Supermarket_Set_Covering")

# Areas
areas = ['A','B','C','D','E','F','G','H','I','J','K','L']

# Coverage sets (optimized model without duplicate constraints)
coverage = {
    'A': ['A','C','E','G','H','I'],
    'B': ['B','H','I'],
    'D': ['D','J'],
    'E': ['A','E','G'],
    'F': ['F','J','K'],
    'G': ['A','C','E','G'],
    'H': ['A','B','C','H','I'],
    'J': ['D','F','J','K','L'],
    'K': ['F','J','K','L'],
    'L': ['J','K','L']
}

# Decision variables
x = model.addVars(areas, vtype=GRB.BINARY, name="x")

# Objective: minimize number of stores
model.setObjective(gp.quicksum(x[i] for i in areas), GRB.MINIMIZE)

# Coverage constraints
for area, cover_set in coverage.items():
    model.addConstr(gp.quicksum(x[i] for i in cover_set) >= 1, name=f"Cover_{area}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum number of stores: {int(model.objVal)}")
    print("Build stores in areas:")
    for i in areas:
        if x[i].x > 0.5:
            print(f"  Area {i}")
else:
    print("No optimal solution found.")
```
