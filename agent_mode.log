【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB
import math

# -----------------------
# Data
# -----------------------
J = range(4)

d = [450, 480, 540, 600]

pH = [0.03, 0.10, 0.05, 0.05]
pL = [0.08, 0.11, 0.12, 0.09]

F_H = [3*d[j]/4 + 100 for j in J]
F_L = [7*d[j]/12 + 100 for j in J]

# -----------------------
# Model
# -----------------------
model = gp.Model("Strategic_Bombing")

# Decision variables
xH = model.addVars(J, vtype=GRB.INTEGER, lb=0, name="xH")
xL = model.addVars(J, vtype=GRB.INTEGER, lb=0, name="xL")

# Nonlinear expressions for P_j
P = {}
for j in J:
    termH = (1 - pH[j]) ** xH[j]
    termL = (1 - pL[j]) ** xL[j]
    P[j] = 1 - termH * termL

# Objective: maximize probability of at least 2 destroyed
prod0 = 1
for j in J:
    prod0 *= (1 - P[j])

prod1 = 0
for j in J:
    term = P[j]
    for k in J:
        if k != j:
            term *= (1 - P[k])
    prod1 += term

Z = 1 - prod0 - prod1

model.setObjective(Z, GRB.MAXIMIZE)

# Constraints
model.addConstr(gp.quicksum(xH[j] for j in J) <= 28, name="HeavyLimit")
model.addConstr(gp.quicksum(xL[j] for j in J) <= 12, name="LightLimit")
model.addConstr(
    gp.quicksum(F_H[j]*xH[j] + F_L[j]*xL[j] for j in J) <= 10000,
    name="FuelLimit"
)

# Enable nonconvex solving
model.Params.NonConvex = 2

# Optimize
model.optimize()

# -----------------------
# Output results
# -----------------------
if model.status == GRB.OPTIMAL:
    print("Optimal Bombing Plan:")
    for j in J:
        print(f"Target {j+1}: Heavy = {int(xH[j].X)}, Light = {int(xL[j].X)}")
    print(f"Maximum Probability of Success: {model.ObjVal:.6f}")
else:
    print("No optimal solution found.")
```
