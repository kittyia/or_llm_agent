【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Farmer_Transportation")

# Decision variables
x_h = model.addVar(vtype=GRB.INTEGER, lb=0, name="horse_trips")
x_b = model.addVar(vtype=GRB.INTEGER, lb=0, name="bicycle_trips")
x_c = model.addVar(vtype=GRB.INTEGER, lb=0, name="handcart_trips")

y_b = model.addVar(vtype=GRB.BINARY, name="use_bicycle")
y_c = model.addVar(vtype=GRB.BINARY, name="use_handcart")

# Objective: Minimize pollution
model.setObjective(80 * x_h, GRB.MINIMIZE)

# Constraints

# Demand satisfaction
model.addConstr(55 * x_h + 30 * x_b + 40 * x_c >= 1000, name="demand")

# Pollution limit
model.addConstr(80 * x_h <= 1000, name="pollution_limit")

# Minimum horse trips
model.addConstr(x_h >= 8, name="min_horse_trips")

# Only one of bicycle or handcart can be used
model.addConstr(y_b + y_c <= 1, name="exclusive_transport")

# Logical linking constraints with tightened Big-M
model.addConstr(x_b <= 34 * y_b, name="bicycle_link")
model.addConstr(x_c <= 25 * y_c, name="handcart_link")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    print(f"Horse trips: {int(x_h.X)}")
    print(f"Bicycle trips: {int(x_b.X)}")
    print(f"Handcart trips: {int(x_c.X)}")
    print(f"Total Pollution: {model.objVal}")
else:
    print("No optimal solution found.")
```
