import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Course_Selection")

# Courses
courses = ["CAL", "OR", "DS", "MS", "CSIM", "CP", "F"]

# Decision variables
x = model.addVars(courses, vtype=GRB.BINARY, name="x")

# Objective: minimize total number of courses
model.setObjective(gp.quicksum(x[c] for c in courses), GRB.MINIMIZE)

# Category constraints
# Mathematics ≥ 2
model.addConstr(x["CAL"] + x["OR"] + x["DS"] + x["MS"] + x["F"] >= 2, name="Math_requirement")

# Operations Research ≥ 2
model.addConstr(x["OR"] + x["MS"] + x["CSIM"] + x["F"] >= 2, name="OR_requirement")

# Computer Science ≥ 2
model.addConstr(x["CP"] + x["DS"] + x["CSIM"] >= 2, name="CS_requirement")

# Prerequisite constraints
model.addConstr(x["CSIM"] <= x["CP"], name="CSIM_requires_CP")
model.addConstr(x["DS"] <= x["CP"], name="DS_requires_CP")
model.addConstr(x["MS"] <= x["CAL"], name="MS_requires_CAL")
model.addConstr(x["F"] <= x["MS"], name="F_requires_MS")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Minimum number of courses: {int(model.objVal)}")
    print("Selected courses:")
    for c in courses:
        if x[c].x > 0.5:
            print(c)
else:
    print("No optimal solution found.")
```
