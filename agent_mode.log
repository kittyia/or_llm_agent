import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Shopping_Mall_Leasing")

# -------------------------
# Decision Variables
# -------------------------
# Binary selection variables

# Jewelry (1-3)
x11 = model.addVar(vtype=GRB.BINARY, name="x11")
x12 = model.addVar(vtype=GRB.BINARY, name="x12")
x13 = model.addVar(vtype=GRB.BINARY, name="x13")

# Shoes & Hats (1-2)
x21 = model.addVar(vtype=GRB.BINARY, name="x21")
x22 = model.addVar(vtype=GRB.BINARY, name="x22")

# General Merchandise (1-3)
x31 = model.addVar(vtype=GRB.BINARY, name="x31")
x32 = model.addVar(vtype=GRB.BINARY, name="x32")
x33 = model.addVar(vtype=GRB.BINARY, name="x33")

# Bookstore (0-2)
x40 = model.addVar(vtype=GRB.BINARY, name="x40")
x41 = model.addVar(vtype=GRB.BINARY, name="x41")
x42 = model.addVar(vtype=GRB.BINARY, name="x42")

# Catering (1-3)
x51 = model.addVar(vtype=GRB.BINARY, name="x51")
x52 = model.addVar(vtype=GRB.BINARY, name="x52")
x53 = model.addVar(vtype=GRB.BINARY, name="x53")

model.update()

# -------------------------
# Selection Constraints
# -------------------------
model.addConstr(x11 + x12 + x13 == 1, "Jewelry_select")
model.addConstr(x21 + x22 == 1, "Shoes_select")
model.addConstr(x31 + x32 + x33 == 1, "General_select")
model.addConstr(x40 + x41 + x42 == 1, "Bookstore_select")
model.addConstr(x51 + x52 + x53 == 1, "Catering_select")

# -------------------------
# Area Constraint
# -------------------------
model.addConstr(
    250 * (1*x11 + 2*x12 + 3*x13) +
    350 * (1*x21 + 2*x22) +
    800 * (1*x31 + 2*x32 + 3*x33) +
    400 * (1*x41 + 2*x42) +
    500 * (1*x51 + 2*x52 + 3*x53)
    <= 5000,
    "Area_constraint"
)

# -------------------------
# Objective Function
# -------------------------
profit = (
    9*1*x11 + 8*2*x12 + 7*3*x13 +
    10*1*x21 + 9*2*x22 +
    27*1*x31 + 21*2*x32 + 20*3*x33 +
    0*x40 + 16*1*x41 + 10*2*x42 +
    17*1*x51 + 15*2*x52 + 12*3*x53
)

model.setObjective(0.2 * profit, GRB.MAXIMIZE)

# -------------------------
# Solve Model
# -------------------------
model.optimize()

# -------------------------
# Output Results
# -------------------------
if model.status == GRB.OPTIMAL:
    print("\nOptimal Leasing Plan:")
    print("Jewelry stores:", int(1*x11.X + 2*x12.X + 3*x13.X))
    print("Shoes & Hats stores:", int(1*x21.X + 2*x22.X))
    print("General Merchandise stores:", int(1*x31.X + 2*x32.X + 3*x33.X))
    print("Bookstores:", int(1*x41.X + 2*x42.X))
    print("Catering stores:", int(1*x51.X + 2*x52.X + 3*x53.X))
    print("Maximum Rental Income (10,000 yuan):", model.objVal)
else:
    print("No optimal solution found.")
```
