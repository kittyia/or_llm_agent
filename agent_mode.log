model.addConstr(x3 <= 50, name="ChickenLimit")
model.addConstr(x1 >= 10, name="MinCows")
model.addConstr(x2 >= 20, name="MinSheep")
model.addConstr(x1 + x2 + x3 <= 100, name="TotalAnimals")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: ${model.objVal:.2f}")
    print(f"Number of cows: {x1.x}")
    print(f"Number of sheep: {x2.x}")
    print(f"Number of chickens: {x3.x}")
else:
    print("No optimal solution found.")
