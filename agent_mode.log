【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("R&D_Team_Selection")

# Decision variables
x_F = model.addVar(vtype=GRB.BINARY, name="x_F")
x_G = model.addVar(vtype=GRB.BINARY, name="x_G")
x_H = model.addVar(vtype=GRB.BINARY, name="x_H")
x_I = model.addVar(vtype=GRB.BINARY, name="x_I")
x_J = model.addVar(vtype=GRB.BINARY, name="x_J")

# Objective function: Minimize total salary
model.setObjective(
    12000 * x_F +
    15000 * x_G +
    18000 * x_H +
    5000  * x_I +
    10000 * x_J,
    GRB.MINIMIZE
)

# Constraints

# Maximum number of hires
model.addConstr(
    x_F + x_G + x_H + x_I + x_J <= 4,
    name="Max_Hires"
)

# Minimum total skill level
model.addConstr(
    2 * x_F + 3 * x_G + 4 * x_H + 1 * x_I + 2 * x_J >= 8,
    name="Min_Skill"
)

# Minimum total project management experience
model.addConstr(
    1 * x_F + 2 * x_G + 2 * x_H + 5 * x_I + 4 * x_J >= 8,
    name="Min_Experience"
)

# Mutual exclusivity between G and J
model.addConstr(
    x_G + x_J <= 1,
    name="Mutual_Exclusivity_G_J"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total salary: ${model.objVal:.2f}")
    print("Selected candidates:")
    for var in model.getVars():
        if var.x > 0.5:
            print(f"  {var.varName}")
else:
    print("No optimal solution found.")
```
