【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Candy_Production_Optimization")

# Sets
materials = ['A', 'B', 'C']
candies = ['A', 'B', 'C']

# Parameters
raw_cost = {'A': 2.0, 'B': 1.5, 'C': 1.0}
availability = {'A': 2000, 'B': 2500, 'C': 1200}
selling_price = {'A': 3.40, 'B': 2.85, 'C': 2.25}
processing_fee = {'A': 0.50, 'B': 0.40, 'C': 0.30}

# Decision variables: x[i,j] = kg of raw material i used in candy j
x = model.addVars(materials, candies, lb=0, name="x")

# Objective function
profit_expr = gp.quicksum(
    (selling_price[j] - processing_fee[j]) * gp.quicksum(x[i, j] for i in materials)
    for j in candies
) - gp.quicksum(
    raw_cost[i] * gp.quicksum(x[i, j] for j in candies)
    for i in materials
)

model.setObjective(profit_expr, GRB.MAXIMIZE)

# Composition constraints

# Candy A
model.addConstr(
    x['A', 'A'] >= 0.60 * (x['A', 'A'] + x['B', 'A'] + x['C', 'A']),
    name="Comp_A_minA"
)
model.addConstr(
    x['C', 'A'] <= 0.20 * (x['A', 'A'] + x['B', 'A'] + x['C', 'A']),
    name="Comp_A_maxC"
)

# Candy B
model.addConstr(
    x['A', 'B'] >= 0.15 * (x['A', 'B'] + x['B', 'B'] + x['C', 'B']),
    name="Comp_B_minA"
)
model.addConstr(
    x['C', 'B'] <= 0.60 * (x['A', 'B'] + x['B', 'B'] + x['C', 'B']),
    name="Comp_B_maxC"
)

# Candy C
model.addConstr(
    x['C', 'C'] <= 0.50 * (x['A', 'C'] + x['B', 'C'] + x['C', 'C']),
    name="Comp_C_maxC"
)

# Raw material availability constraints
for i in materials:
    model.addConstr(
        gp.quicksum(x[i, j] for j in candies) <= availability[i],
        name=f"Availability_{i}"
    )

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Profit: {model.objVal:.2f} Yuan\n")
    for j in candies:
        total_production = sum(x[i, j].x for i in materials)
        print(f"Production of Candy {j}: {total_production:.2f} kg")
        for i in materials:
            print(f"  Raw Material {i} used: {x[i, j].x:.2f} kg")
        print()
else:
    print("No optimal solution found.")
```
