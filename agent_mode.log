【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Data
# -----------------------------
months = [7, 8, 9, 10, 11, 12]

purchase_price = {
    7: 28, 8: 24, 9: 25, 10: 27, 11: 23, 12: 23
}

selling_price = {
    7: 29, 8: 24, 9: 26, 10: 28, 11: 22, 12: 25
}

initial_inventory = 200
capacity = 500

# -----------------------------
# Model
# -----------------------------
model = gp.Model("Purchase_Sales_Planning")

# Decision variables
x = model.addVars(months, lb=0, vtype=GRB.CONTINUOUS, name="Purchase")
y = model.addVars(months, lb=0, vtype=GRB.CONTINUOUS, name="Sales")
I = model.addVars(months, lb=0, ub=capacity, vtype=GRB.CONTINUOUS, name="Inventory")

# Objective function
model.setObjective(
    gp.quicksum(selling_price[t] * y[t] - purchase_price[t] * x[t] for t in months),
    GRB.MAXIMIZE
)

# Inventory balance constraints
for idx, t in enumerate(months):
    if idx == 0:
        model.addConstr(I[t] == initial_inventory + x[t] - y[t], name=f"Inventory_Balance_{t}")
    else:
        prev_t = months[idx - 1]
        model.addConstr(I[t] == I[prev_t] + x[t] - y[t], name=f"Inventory_Balance_{t}")

# Optimize
model.optimize()

# -----------------------------
# Results
# -----------------------------
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Revenue: {model.objVal:.2f}\n")
    print("Month | Purchase | Sales | Ending Inventory")
    print("---------------------------------------------")
    for t in months:
        print(f"{t:5d} | {x[t].x:8.2f} | {y[t].x:6.2f} | {I[t].x:16.2f}")
else:
    print("No optimal solution found.")
```
