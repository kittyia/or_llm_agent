    print(f"Optimal number of Type A trucks: {int(x_A.x)}")
    print(f"Optimal number of Type B trucks: {int(x_B.x)}")
    print(f"Minimum total cost per km: £{model.objVal}")
else:
    print("No optimal solution found.")
```
