This is the final optimized and complete linear integer programming model.
【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Furniture_Production")

# Decision variables
x1 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Tables")
x2 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Chairs")
x3 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Bookshelves")

# Objective function: Maximize profit
model.setObjective(80 * x1 + 30 * x2 + 60 * x3, GRB.MAXIMIZE)

# Constraints
model.addConstr(5 * x1 + 2 * x2 + 3 * x3 <= 500, name="Warehouse_Space")
model.addConstr(x1 >= 10, name="Min_Tables")
model.addConstr(x3 >= 20, name="Min_Bookshelves")
model.addConstr(x1 + x2 + x3 <= 200, name="Total_Production_Limit")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    print(f"Tables: {int(x1.X)}")
    print(f"Chairs: {int(x2.X)}")
    print(f"Bookshelves: {int(x3.X)}")
    print(f"Maximum Profit: ${model.objVal:.2f}")
else:
    print("No optimal solution found.")
