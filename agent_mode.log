 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
students = [1, 2, 3, 4, 5, 6]
days = ["Mon", "Tue", "Wed", "Thu", "Fri"]

# Parameters
H = 14  # required working hours per day

wage = {
    1: 10.0,
    2: 10.0,
    3: 9.9,
    4: 9.8,
    5: 10.8,
    6: 11.3
}

availability = {
    (1, "Mon"): 6, (1, "Tue"): 0, (1, "Wed"): 6, (1, "Thu"): 0, (1, "Fri"): 7,
    (2, "Mon"): 0, (2, "Tue"): 6, (2, "Wed"): 0, (2, "Thu"): 6, (2, "Fri"): 0,
    (3, "Mon"): 4, (3, "Tue"): 8, (3, "Wed"): 3, (3, "Thu"): 0, (3, "Fri"): 5,
    (4, "Mon"): 5, (4, "Tue"): 5, (4, "Wed"): 6, (4, "Thu"): 0, (4, "Fri"): 4,
    (5, "Mon"): 3, (5, "Tue"): 0, (5, "Wed"): 4, (5, "Thu"): 8, (5, "Fri"): 0,
    (6, "Mon"): 0, (6, "Tue"): 6, (6, "Wed"): 0, (6, "Thu"): 6, (6, "Fri"): 3
}

min_hours = {
    1: 8, 2: 8, 3: 8, 4: 8,
    5: 7, 6: 7
}

# Model
model = gp.Model("Lab_Scheduling")

# Decision variables
y = model.addVars(students, days, vtype=GRB.BINARY, name="y")

# Objective
model.setObjective(
    gp.quicksum(H * wage[i] * y[i, d] for i in students for d in days),
    GRB.MINIMIZE
)

# Constraints

# 1. Exactly one student per day
for d in days:
    model.addConstr(gp.quicksum(y[i, d] for i in students) == 1,
                    name=f"OneStudent_{d}")

# 2. Availability feasibility
for i in students:
    for d in days:
        model.addConstr(H * y[i, d] <= availability[i, d],
                        name=f"Availability_{i}_{d}")

# 3. Weekly minimum working hours
for i in students:
    model.addConstr(H * gp.quicksum(y[i, d] for d in days) >= min_hours[i],
                    name=f"MinHours_{i}")

# 4. At most 2 shifts per week
for i in students:
    model.addConstr(gp.quicksum(y[i, d] for d in days) <= 2,
                    name=f"MaxShifts_{i}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total cost: {model.objVal:.2f} CNY")
    print("\nSchedule:")
    for d in days:
        for i in students:
            if y[i, d].x > 0.5:
                print(f"{d}: Student {i}")
else:
    print("No optimal solution found.")
```
