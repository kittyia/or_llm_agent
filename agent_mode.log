【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
products = range(3)   # i = 0,1,2
machines = range(3)   # j = 0,1,2
positions = range(3)  # k = 0,1,2

# Processing times t[i][j]
t = [
    [2, 3, 1],  # Product 1
    [4, 2, 3],  # Product 2
    [3, 5, 2]   # Product 3
]

# Create model
model = gp.Model("Permutation_Flow_Shop")

# Decision variables
x = model.addVars(products, positions, vtype=GRB.BINARY, name="x")
C = model.addVars(positions, machines, vtype=GRB.CONTINUOUS, lb=0.0, name="C")
Cmax = model.addVar(vtype=GRB.CONTINUOUS, lb=0.0, name="Cmax")

# Assignment constraints
for k in positions:
    model.addConstr(gp.quicksum(x[i, k] for i in products) == 1, name=f"AssignPos_{k}")

for i in products:
    model.addConstr(gp.quicksum(x[i, k] for k in positions) == 1, name=f"AssignProd_{i}")

# Processing time expression
def P(k, j):
    return gp.quicksum(t[i][j] * x[i, k] for i in products)

# Machine 1 constraints
model.addConstr(C[0, 0] >= P(0, 0), name="M1_pos0")

for k in positions:
    if k > 0:
        model.addConstr(C[k, 0] >= C[k-1, 0] + P(k, 0), name=f"M1_pos{k}")

# Machines 2 and 3 constraints
for j in machines:
    if j > 0:
        # First position
        model.addConstr(C[0, j] >= C[0, j-1] + P(0, j), name=f"M{j+1}_pos0")
        
        for k in positions:
            if k > 0:
                model.addConstr(C[k, j] >= C[k-1, j] + P(k, j), name=f"M{j+1}_seq_pos{k}")
                model.addConstr(C[k, j] >= C[k, j-1] + P(k, j), name=f"M{j+1}_flow_pos{k}")

# Makespan definition
model.addConstr(Cmax >= C[2, 2], name="Makespan")

# Objective
model.setObjective(Cmax, GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Makespan: {Cmax.X}")
    print("Optimal Job Sequence:")
    sequence = []
    for k in positions:
        for i in products:
            if x[i, k].X > 0.5:
                sequence.append(i + 1)
    print(sequence)
    
    print("Completion Times:")
    for k in positions:
        for j in machines:
            print(f"C[{k+1},{j+1}] = {C[k,j].X}")
else:
    print("No optimal solution found.")
```
