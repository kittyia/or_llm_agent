【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Mary_Dinner_Optimization")

# Decision variables
# Protein sources (continuous, 100g units)
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="chicken")
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="salmon")
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="tofu")

# Vegetables (integer packs, 100g each)
y = model.addVars(5, vtype=GRB.INTEGER, lb=0, name="veg")

# Binary selection variables for vegetables
z = model.addVars(5, vtype=GRB.BINARY, name="select")

# Objective function: maximize total protein
model.setObjective(
    23 * x1 + 20 * x2 + 8 * x3 +
    2.8 * y[0] + 0.9 * y[1] + 2.9 * y[2] + 1.0 * y[3] + 3.1 * y[4],
    GRB.MAXIMIZE
)

# Budget constraint
model.addConstr(
    3 * x1 + 5 * x2 + 1.5 * x3 +
    1.2 * y[0] + 0.8 * y[1] + 1.5 * y[2] + 1.0 * y[3] + 2.0 * y[4]
    <= 20,
    name="Budget"
)

# Weight constraint (100g units, total <= 8)
model.addConstr(
    x1 + x2 + x3 + gp.quicksum(y[i] for i in range(5)) <= 8,
    name="Weight"
)

# At least three different vegetables
model.addConstr(
    gp.quicksum(z[i] for i in range(5)) >= 3,
    name="Min_Veg_Types"
)

# Linking constraints (Big-M = 8)
for i in range(5):
    model.addConstr(y[i] <= 8 * z[i], name=f"Link_ub_{i}")
    model.addConstr(y[i] >= z[i], name=f"Link_lb_{i}")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Maximum Protein: {model.objVal:.2f} g")
    print(f"Chicken (100g units): {x1.x:.2f}")
    print(f"Salmon (100g units): {x2.x:.2f}")
    print(f"Tofu (100g units): {x3.x:.2f}")
    veg_names = ["Broccoli", "Carrots", "Spinach", "Bell Pepper", "Mushrooms"]
    for i in range(5):
        print(f"{veg_names[i]} packs (100g each): {int(round(y[i].x))}")
else:
    print("No optimal solution found.")
```
