 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Carelland_GDP_Maximization")

# Decision variables: production
S = model.addVar(lb=0, name="Steel")
E = model.addVar(lb=0, name="Engines")
C = model.addVar(lb=0, name="Electronics")
P = model.addVar(lb=0, name="Plastic")

# Decision variables: imports
MS = model.addVar(lb=0, name="Import_Steel")
ME = model.addVar(lb=0, name="Import_Engines")
MC = model.addVar(lb=0, name="Import_Electronics")
MP = model.addVar(lb=0, name="Import_Plastic")

# Objective function: Maximize GDP
model.setObjective(
    250*S + 1200*E + 250*C + 900*P
    - 500*MS - 1500*ME - 300*MC - 1200*MP,
    GRB.MAXIMIZE
)

# Material balance constraints
model.addConstr(S + MS - 0.8*E - 0.01*C - 0.2*P == 0, "Steel_Balance")
model.addConstr(E + ME - 0.02*S - 0.01*C - 0.03*P == 0, "Engine_Balance")
model.addConstr(C + MC - 0.15*E - 0.05*P == 0, "Electronics_Balance")
model.addConstr(P + MP - 0.01*S - 0.11*E - 0.05*C == 0, "Plastic_Balance")

# Labor constraint (person-months)
model.addConstr(6*S + 12*E + 6*C + 24*P <= 830000, "Labor")

# Capacity constraints
model.addConstr(E <= 650000, "Engine_Capacity")
model.addConstr(P <= 60000, "Plastic_Capacity")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("\nOptimal Solution:")
    print(f"Steel Production: {S.X:.2f}")
    print(f"Engine Production: {E.X:.2f}")
    print(f"Electronics Production: {C.X:.2f}")
    print(f"Plastic Production: {P.X:.2f}")
    print(f"Steel Imports: {MS.X:.2f}")
    print(f"Engine Imports: {ME.X:.2f}")
    print(f"Electronics Imports: {MC.X:.2f}")
    print(f"Plastic Imports: {MP.X:.2f}")
    print(f"\nMaximum GDP: {model.ObjVal:.2f}")
else:
    print("No optimal solution found.")
```
