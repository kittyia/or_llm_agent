【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Furniture_Order_Optimization")

# Decision variables
xA = model.addVar(vtype=GRB.INTEGER, lb=0, name="xA")
xB = model.addVar(vtype=GRB.INTEGER, lb=0, name="xB")
xC = model.addVar(vtype=GRB.INTEGER, lb=0, name="xC")

yA = model.addVar(vtype=GRB.BINARY, name="yA")
yB = model.addVar(vtype=GRB.BINARY, name="yB")
yC = model.addVar(vtype=GRB.BINARY, name="yC")

# Objective function
model.setObjective(750 * xA + 450 * xB + 400 * xC, GRB.MINIMIZE)

# Chair quantity constraints
model.addConstr(15 * xA + 10 * xB + 10 * xC >= 100, name="MinChairs")
model.addConstr(15 * xA + 10 * xB + 10 * xC <= 500, name="MaxChairs")

# Upper bound linking constraints
model.addConstr(xA <= 33 * yA, name="LinkA")
model.addConstr(xB <= 50 * yB, name="LinkB")
model.addConstr(xC <= 50 * yC, name="LinkC")

# Logical constraints
model.addConstr(xB >= yA, name="A_implies_B_order")
model.addConstr(yA <= yB, name="A_implies_B_use")
model.addConstr(yB <= yC, name="B_implies_C_use")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal total cost:", model.objVal)
    print("Orders from A:", int(xA.x))
    print("Orders from B:", int(xB.x))
    print("Orders from C:", int(xC.x))
    print("Use A:", int(yA.x))
    print("Use B:", int(yB.x))
    print("Use C:", int(yC.x))
else:
    print("No optimal solution found.")
```
