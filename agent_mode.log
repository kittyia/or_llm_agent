from gurobipy import Model, GRB

# Create model
model = Model("Truck_Rental_Optimization")

# Decision variables
x_A = model.addVar(vtype=GRB.INTEGER, lb=0, name="x_A")
x_B = model.addVar(vtype=GRB.INTEGER, lb=0, name="x_B")

# Objective function
