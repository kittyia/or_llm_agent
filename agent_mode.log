【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
weeks = range(4)
d = [15, 25, 35, 25]          # Demand (1000 boxes)
u = [30, 40, 45, 20]          # Production capacity (1000 boxes)
c = [5.0, 5.1, 5.4, 5.5]      # Production cost (1000 yuan per 1000 boxes)
h = 0.2                       # Holding cost (1000 yuan per 1000 boxes per week)

# Create model
model = gp.Model("Beverage_Production_Planning")

# Decision variables
x = model.addVars(weeks, lb=0, name="Production")        # Production
I = model.addVars(weeks, lb=0, name="Inventory")         # Inventory

# Objective function
model.setObjective(
    gp.quicksum(c[t] * x[t] for t in weeks) +
    h * gp.quicksum(I[t] for t in weeks),
    GRB.MINIMIZE
)

# Initial inventory
I0 = 0

# Inventory balance constraints
for t in weeks:
    if t == 0:
        model.addConstr(I[t] == I0 + x[t] - d[t], name=f"InventoryBalance_{t+1}")
    else:
        model.addConstr(I[t] == I[t-1] + x[t] - d[t], name=f"InventoryBalance_{t+1}")

# Production capacity constraints
for t in weeks:
    model.addConstr(x[t] <= u[t], name=f"Capacity_{t+1}")

# Ending inventory constraint
model.addConstr(I[3] == 0, name="EndingInventory")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal:.2f} (thousand yuan)")
    for t in weeks:
        print(f"Week {t+1}: Production = {x[t].x:.2f}, Inventory = {I[t].x:.2f}")
else:
    print("No optimal solution found.")
```
