【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Coal_Transportation")

# Index sets
yards = [1, 2]
areas = [1, 2, 3]

# Distance matrix (ton-kilometers cost coefficients)
distance = {
    (1, 1): 10, (1, 2): 5, (1, 3): 6,
    (2, 1): 4,  (2, 2): 8, (2, 3): 15
}

# Supply and demand
supply = {1: 80, 2: 100}
demand = {1: 55, 2: 75, 3: 50}

# Decision variables
x = model.addVars(yards, areas, lb=0, vtype=GRB.CONTINUOUS, name="x")

# Objective function
model.setObjective(
    gp.quicksum(distance[i, j] * x[i, j] for i in yards for j in areas),
    GRB.MINIMIZE
)

# Supply constraints
for i in yards:
    model.addConstr(
        gp.quicksum(x[i, j] for j in areas) == supply[i],
        name=f"supply_{i}"
    )

# Demand constraints
for j in areas:
    model.addConstr(
        gp.quicksum(x[i, j] for i in yards) == demand[j],
        name=f"demand_{j}"
    )

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total transportation cost (ton-km): {model.objVal}")
    for i in yards:
        for j in areas:
            print(f"x[{i},{j}] = {x[i,j].x}")
else:
    print("No optimal solution found.")
```
