import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Factory_Production_Planning")

# Decision variables

# Product A
xA1 = model.addVar(lb=0, ub=40, vtype=GRB.CONTINUOUS, name="xA1")
xA2 = model.addVar(lb=0, ub=60, vtype=GRB.CONTINUOUS, name="xA2")
xA3 = model.addVar(lb=0, ub=50, vtype=GRB.CONTINUOUS, name="xA3")
xA4 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="xA4")

# Product B
xB1 = model.addVar(lb=0, ub=50, vtype=GRB.CONTINUOUS, name="xB1")
xB2 = model.addVar(lb=0, ub=50, vtype=GRB.CONTINUOUS, name="xB2")
xB3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="xB3")

# Product C
xC1 = model.addVar(lb=0, ub=100, vtype=GRB.CONTINUOUS, name="xC1")
xC2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="xC2")

model.update()

# Total production expressions
xA = xA1 + xA2 + xA3 + xA4
xB = xB1 + xB2 + xB3
xC = xC1 + xC2

# Resource constraints
model.addConstr(xA + 2*xB + xC <= 100, name="Technical_Time")
model.addConstr(10*xA + 4*xB + 5*xC <= 700, name="Labor_Time")
model.addConstr(3*xA + 2*xB + xC <= 400, name="Material")

# Objective function
model.setObjective(
    10*xA1 + 9*xA2 + 8*xA3 + 7*xA4 +
    6*xB1 + 4*xB2 + 3*xB3 +
    5*xC1 + 4*xC2,
    GRB.MAXIMIZE
)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Objective Value (Total Profit):", model.objVal)
    print("\nOptimal Production Plan:")
    print(f"Product A Total: {xA.getValue()}")
    print(f"  xA1: {xA1.x}, xA2: {xA2.x}, xA3: {xA3.x}, xA4: {xA4.x}")
    print(f"Product B Total: {xB.getValue()}")
    print(f"  xB1: {xB1.x}, xB2: {xB2.x}, xB3: {xB3.x}")
    print(f"Product C Total: {xC.getValue()}")
    print(f"  xC1: {xC1.x}, xC2: {xC2.x}")
else:
    print("No optimal solution found.")
```
