from gurobipy import Model, GRB

# Create model
model = Model("Factory_Production_Optimization")

# Decision variables
x1 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x1")  # Product I
x2 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x2")  # Product II
x3 = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="x3")  # Product III

# Objective function: Maximize profit
model.setObjective(3 * x1 + 2 * x2 + 2.9 * x3, GRB.MAXIMIZE)

# Constraints
model.addConstr(8 * x1 + 2 * x2 + 10 * x3 <= 300, name="Equipment_A")
model.addConstr(10 * x1 + 5 * x2 + 8 * x3 <= 400, name="Equipment_B")
model.addConstr(2 * x1 + 13 * x2 + 10 * x3 <= 420, name="Equipment_C")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal production plan:")
    print(f"Product I (x1): {x1.X:.4f}")
    print(f"Product II (x2): {x2.X:.4f}")
    print(f"Product III (x3): {x3.X:.4f}")
    print(f"Maximum Profit (thousand yuan): {model.objVal:.4f}")
else:
    print("No optimal solution found.")
