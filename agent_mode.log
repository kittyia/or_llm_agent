 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Purchasing_and_Sales_Plan")

# Decision variables
x = model.addVars(3, lb=0, name="x")  # Purchase quantities (x[0]=x1, x[1]=x2, x[2]=x3)
y = model.addVars(3, lb=0, name="y")  # Sales quantities (y[0]=y1, y[1]=y2, y[2]=y3)

# Objective function coefficients
purchase_price = [8, 6, 9]
selling_price = [9, 8, 10]

# Set objective: Maximize profit
model.setObjective(
    gp.quicksum(selling_price[t] * y[t] for t in range(3)) -
    gp.quicksum(purchase_price[t] * x[t] for t in range(3)),
    GRB.MAXIMIZE
)

# Initial inventory
initial_inventory = 200
capacity = 500

# Inventory feasibility constraints (cumulative sales ≤ cumulative available inventory)
model.addConstr(y[0] <= initial_inventory + x[0], name="Inventory_Feasibility_1")
model.addConstr(y[0] + y[1] <= initial_inventory + x[0] + x[1], name="Inventory_Feasibility_2")
model.addConstr(y[0] + y[1] + y[2] <= initial_inventory + x[0] + x[1] + x[2], name="Inventory_Feasibility_3")

# Warehouse capacity constraints
model.addConstr(initial_inventory + x[0] - y[0] <= capacity, name="Capacity_1")
model.addConstr(initial_inventory + x[0] + x[1] - y[0] - y[1] <= capacity, name="Capacity_2")
model.addConstr(initial_inventory + x[0] + x[1] + x[2] - y[0] - y[1] - y[2] <= capacity, name="Capacity_3")

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found:")
    for t in range(3):
        print(f"Month {t+1}: Purchase = {x[t].X:.2f}, Sell = {y[t].X:.2f}")
    print(f"Maximum Profit: {model.ObjVal:.2f}")
else:
    print("No optimal solution found.")
```
