【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Mary_Dinner_Optimization")

# Small epsilon to enforce positive quantity if selected
epsilon = 1.0

# Continuous variables (grams)
x_o  = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="okra")
x_ca = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="carrots")
x_ce = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="celery")
x_cb = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="cabbage")

x_s = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="salmon")
x_b = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="beef")
x_p = model.addVar(lb=0, vtype=GRB.CONTINUOUS, name="pork")

# Binary variables
y_o  = model.addVar(vtype=GRB.BINARY, name="y_okra")
y_ca = model.addVar(vtype=GRB.BINARY, name="y_carrots")
y_ce = model.addVar(vtype=GRB.BINARY, name="y_celery")
y_cb = model.addVar(vtype=GRB.BINARY, name="y_cabbage")

y_s = model.addVar(vtype=GRB.BINARY, name="y_salmon")
y_b = model.addVar(vtype=GRB.BINARY, name="y_beef")
y_p = model.addVar(vtype=GRB.BINARY, name="y_pork")

model.update()

# Objective: maximize fiber intake
model.setObjective(
    0.032 * x_o +
    0.027 * x_ca +
    0.016 * x_ce +
    0.020 * x_cb,
    GRB.MAXIMIZE
)

# Budget constraint
model.addConstr(
    0.026 * x_o +
    0.012 * x_ca +
    0.016 * x_ce +
    0.023 * x_cb +
    0.04  * x_s +
    0.036 * x_b +
    0.018 * x_p
    <= 15,
    name="Budget"
)

# Total weight constraint
model.addConstr(
    x_o + x_ca + x_ce + x_cb +
    x_s + x_b + x_p
    == 600,
    name="Total_Weight"
)

# Exactly one protein selected
model.addConstr(y_s + y_b + y_p == 1, name="One_Protein")

# At least two vegetables selected
model.addConstr(y_o + y_ca + y_ce + y_cb >= 2, name="Two_Vegetables")

# Linking constraints (Big-M with M=600)
M = 600

# Vegetables
model.addConstr(x_o  <= M * y_o)
model.addConstr(x_ca <= M * y_ca)
model.addConstr(x_ce <= M * y_ce)
model.addConstr(x_cb <= M * y_cb)

model.addConstr(x_o  >= epsilon * y_o)
model.addConstr(x_ca >= epsilon * y_ca)
model.addConstr(x_ce >= epsilon * y_ce)
model.addConstr(x_cb >= epsilon * y_cb)

# Proteins
model.addConstr(x_s <= M * y_s)
model.addConstr(x_b <= M * y_b)
model.addConstr(x_p <= M * y_p)

model.addConstr(x_s >= epsilon * y_s)
model.addConstr(x_b >= epsilon * y_b)
model.addConstr(x_p >= epsilon * y_p)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Fiber Intake: {model.objVal:.4f} grams")
    print("Food quantities (grams):")
    for v in model.getVars():
        if v.varName.startswith("y_"):
            continue
        print(f"{v.varName}: {v.x:.2f}")
else:
    print("No optimal solution found.")
```
