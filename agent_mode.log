This is the recommended final mathematical programming formulation.
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Workforce_Optimization")

# Decision variables
x1 = model.addVar(vtype=GRB.CONTINUOUS, name="x1")  # Skilled alone - Task 1
y1 = model.addVar(vtype=GRB.CONTINUOUS, name="y1")  # 1 Skilled + 2 Laborers - Task 1

x2 = model.addVar(vtype=GRB.CONTINUOUS, name="x2")  # Skilled alone - Task 2
y2 = model.addVar(vtype=GRB.CONTINUOUS, name="y2")  # Laborer alone - Task 2

x3 = model.addVar(vtype=GRB.CONTINUOUS, name="x3")  # 5 Laborers - Task 3
y3 = model.addVar(vtype=GRB.CONTINUOUS, name="y3")  # 1 Skilled + 3 Laborers - Task 3

# Objective function
model.setObjective(
    100 * (x1 + y1 + x2 + y3) +
    80 * (2 * y1 + y2 + 5 * x3 + 3 * y3),
    GRB.MINIMIZE
)

# Task completion constraints
model.addConstr(42 * x1 + 114 * y1 >= 10000, name="Task1")
model.addConstr(42 * x2 + 36 * y2 >= 20000, name="Task2")
model.addConstr(180 * x3 + 150 * y3 >= 30000, name="Task3")

# Workforce upper bounds
model.addConstr(x1 + y1 + x2 + y3 <= 400, name="Skilled_Limit")
model.addConstr(2 * y1 + y2 + 5 * x3 + 3 * y3 <= 800, name="Laborer_Limit")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Objective Value (Total Wage):", model.objVal)
    for var in model.getVars():
        print(f"{var.varName} = {var.x}")
else:
    print("No optimal solution found.")
```
