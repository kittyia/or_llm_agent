【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------
# Sets
# -----------------------
months = [7, 8, 9, 10, 11, 12]
products = [1, 2]

# -----------------------
# Parameters
# -----------------------

# Demand
d = {}
for t in months:
    if t in [7, 8, 9]:
        d[1, t] = 30000
        d[2, t] = 15000
    else:
        d[1, t] = 100000
        d[2, t] = 50000

# Production cost
c = {}
for t in months:
    c[1, t] = 4.5
    c[2, t] = 7.0

# Volume per unit
v = {1: 0.2, 2: 0.4}

# Capacities
production_capacity = 120000
warehouse_capacity = 15000  # m^3

# Storage cost
h_in = 1.0
h_ex = 1.5

# Initial inventory
initial_inventory = {1: 0, 2: 0}

# -----------------------
# Model
# -----------------------
model = gp.Model("Production_Inventory_Planning")

# Decision variables
x = model.addVars(products, months, lb=0, name="Production")
I = model.addVars(products, months, lb=0, name="Inventory")
S_in = model.addVars(months, lb=0, name="InternalStorage")
S_ex = model.addVars(months, lb=0, name="ExternalStorage")

# -----------------------
# Objective function
# -----------------------
model.setObjective(
    gp.quicksum(c[i, t] * x[i, t] for i in products for t in months) +
    gp.quicksum(h_in * S_in[t] + h_ex * S_ex[t] for t in months),
    GRB.MINIMIZE
)

# -----------------------
# Constraints
# -----------------------

# Inventory balance
for i in products:
    for t in months:
        if t == 7:
            model.addConstr(
                I[i, t] == initial_inventory[i] + x[i, t] - d[i, t],
                name=f"InventoryBalance_{i}_{t}"
            )
        else:
            model.addConstr(
                I[i, t] == I[i, t-1] + x[i, t] - d[i, t],
                name=f"InventoryBalance_{i}_{t}"
            )

# Production capacity
for t in months:
    model.addConstr(
        x[1, t] + x[2, t] <= production_capacity,
        name=f"ProductionCapacity_{t}"
    )

# Warehouse volume balance
for t in months:
    model.addConstr(
        v[1] * I[1, t] + v[2] * I[2, t] == S_in[t] + S_ex[t],
        name=f"WarehouseBalance_{t}"
    )

# Internal warehouse capacity
for t in months:
    model.addConstr(
        S_in[t] <= warehouse_capacity,
        name=f"InternalCapacity_{t}"
    )

# Terminal inventory condition
for i in products:
    model.addConstr(
        I[i, 12] == 0,
        name=f"TerminalInventory_{i}"
    )

# -----------------------
# Optimize
# -----------------------
model.optimize()

# -----------------------
# Output results
# -----------------------
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {model.objVal:.2f}\n")
    for t in months:
        print(f"Month {t}:")
        for i in products:
            print(f"  Product {i} Production: {x[i, t].x:.2f}")
            print(f"  Product {i} Inventory: {I[i, t].x:.2f}")
        print(f"  Internal Storage Used: {S_in[t].x:.2f}")
        print(f"  External Storage Used: {S_ex[t].x:.2f}")
        print("-" * 40)
else:
    print("No optimal solution found.")
```
