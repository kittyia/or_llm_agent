【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Sets
products = [1, 2, 3]
quarters = [1, 2, 3, 4]

# Parameters
demand = {
    (1,1):1500, (1,2):1000, (1,3):2000, (1,4):1200,
    (2,1):1500, (2,2):1500, (2,3):1200, (2,4):1500,
    (3,1):1000, (3,2):2000, (3,3):1500, (3,4):2500
}

a = {1:2, 2:4, 3:3}
H = 15000
h = {1:5, 2:5, 3:5}
p = {1:20, 2:20, 3:10}

# Model
model = gp.Model("Production_Planning")

# Decision Variables
x = model.addVars(products, quarters, lb=0, name="x")
I = model.addVars(products, quarters, lb=0, name="I")
B = model.addVars(products, quarters, lb=0, name="B")

# Objective Function
model.setObjective(
    gp.quicksum(h[i] * I[i,t] + p[i] * B[i,t] for i in products for t in quarters),
    GRB.MINIMIZE
)

# Inventory-Backlog Balance Constraints
for i in products:
    for t in quarters:
        if t == 1:
            model.addConstr(
                I[i,t] - B[i,t] == x[i,t] - demand[(i,t)],
                name=f"balance_{i}_{t}"
            )
        else:
            model.addConstr(
                I[i,t] - B[i,t] == I[i,t-1] - B[i,t-1] + x[i,t] - demand[(i,t)],
                name=f"balance_{i}_{t}"
            )

# Final Inventory Requirement
for i in products:
    model.addConstr(I[i,4] == 150, name=f"final_inventory_{i}")

# Production Capacity Constraints
for t in quarters:
    model.addConstr(
        gp.quicksum(a[i] * x[i,t] for i in products) <= H,
        name=f"capacity_{t}"
    )

# Production Restriction: Product 1 cannot be produced in Q2
model.addConstr(x[1,2] == 0, name="prod_restriction_1_2")

# Optimize
model.optimize()

# Output Results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Objective Value: {model.objVal:.2f}\n")
    for t in quarters:
        print(f"Quarter {t}:")
        for i in products:
            print(f"  Product {i}: "
                  f"Production={x[i,t].x:.2f}, "
                  f"Inventory={I[i,t].x:.2f}, "
