【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
m = Model("Factory_Production_Optimization")

# =====================
# Decision Variables
# =====================

# Process A variables
a11 = m.addVar(lb=0, name="a11")  # Product I on A1
a12 = m.addVar(lb=0, name="a12")  # Product I on A2
a21 = m.addVar(lb=0, name="a21")  # Product II on A1
a22 = m.addVar(lb=0, name="a22")  # Product II on A2
a32 = m.addVar(lb=0, name="a32")  # Product III on A2

# Process B variables
b11 = m.addVar(lb=0, name="b11")  # Product I on B1
b12 = m.addVar(lb=0, name="b12")  # Product I on B2
b13 = m.addVar(lb=0, name="b13")  # Product I on B3
b21 = m.addVar(lb=0, name="b21")  # Product II on B1
b32 = m.addVar(lb=0, name="b32")  # Product III on B2

m.update()

# =====================
# Flow Balance Constraints
# =====================

m.addConstr(a11 + a12 == b11 + b12 + b13, name="Flow_Product_I")
m.addConstr(a21 + a22 == b21, name="Flow_Product_II")
m.addConstr(a32 == b32, name="Flow_Product_III")

# =====================
# Machine Capacity Constraints
# =====================

# Process A
m.addConstr(5*a11 + 10*a21 <= 6000, name="Capacity_A1")
m.addConstr(7*a12 + 9*a22 + 12*a32 <= 10000, name="Capacity_A2")

# Process B
m.addConstr(6*b11 + 8*b21 <= 4000, name="Capacity_B1")
m.addConstr(4*b12 + 11*b32 <= 7000, name="Capacity_B2")
m.addConstr(7*b13 <= 4000, name="Capacity_B3")

# =====================
# Objective Function
# =====================

# Net unit profits
profit = (
    1.00*(a11 + a12) +
    1.65*(a21 + a22) +
    2.30*a32
)

# Machine operating costs per time unit
cost = (
    0.05*(5*a11 + 10*a21) +
    0.0321*(7*a12 + 9*a22 + 12*a32) +
    0.0625*(6*b11 + 8*b21) +
    (783/7000)*(4*b12 + 11*b32) +
    0.05*(7*b13)
)

m.setObjective(profit - cost, GRB.MAXIMIZE)

# =====================
# Solve Model
# =====================

m.optimize()

# =====================
# Output Results
# =====================

if m.status == GRB.OPTIMAL:
    print("Optimal Objective Value (Maximum Profit):", m.objVal)
    print("\nOptimal Production Plan:")
    for v in m.getVars():
        if v.x > 1e-6:
            print(f"{v.varName} = {v.x}")
else:
    print("No optimal solution found.")
```
