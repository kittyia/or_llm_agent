【Python Gurobi 代码】:
 ```python
from gurobipy import Model, GRB

# Create model
model = Model("Haus_Toys_Optimization")

# Decision variables (integer production quantities)
x1 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Trucks")
x2 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Airplanes")
x3 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Boats")
x4 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Trains")

# Binary variables (whether a toy type is produced)
y1 = model.addVar(vtype=GRB.BINARY, name="Produce_Trucks")
y2 = model.addVar(vtype=GRB.BINARY, name="Produce_Airplanes")
y3 = model.addVar(vtype=GRB.BINARY, name="Produce_Boats")
y4 = model.addVar(vtype=GRB.BINARY, name="Produce_Trains")

# Objective function
model.setObjective(
    5 * x1 + 10 * x2 + 8 * x3 + 7 * x4,
    GRB.MAXIMIZE
)

# Resource constraints
model.addConstr(12 * x1 + 20 * x2 + 15 * x3 + 10 * x4 <= 890, "Wood")
model.addConstr(6 * x1 + 3 * x2 + 5 * x3 + 4 * x4 <= 500, "Steel")

# Logical constraints
model.addConstr(y1 + y4 <= 1, "Truck_Train_Exclusion")
model.addConstr(y3 <= y2, "Boat_Implies_Airplane")
model.addConstr(x3 <= x4, "Boats_Less_Equal_Trains")

# Tight linking constraints
model.addConstr(x1 <= 74 * y1, "Link_Trucks")
model.addConstr(x2 <= 44 * y2, "Link_Airplanes")
model.addConstr(x3 <= 59 * y3, "Link_Boats")
model.addConstr(x4 <= 89 * y4, "Link_Trains")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Profit:", model.objVal)
    print("Production Plan:")
    print("Trucks:", int(x1.X))
    print("Airplanes:", int(x2.X))
    print("Boats:", int(x3.X))
    print("Trains:", int(x4.X))
    print("Types of Toys Manufactured:")
    print("Trucks:", int(y1.X))
    print("Airplanes:", int(y2.X))
    print("Boats:", int(y3.X))
    print("Trains:", int(y4.X))
else:
    print("No optimal solution found.")
```
