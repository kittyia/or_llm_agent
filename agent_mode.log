【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Bus_Crew_Scheduling")

# Parameters
demand = [60, 70, 60, 50, 20, 30]
n_periods = 6

# Decision variables
x = model.addVars(n_periods, vtype=GRB.INTEGER, lb=0, name="x")

# Objective function: minimize total number of drivers
model.setObjective(gp.quicksum(x[i] for i in range(n_periods)), GRB.MINIMIZE)

# Coverage constraints
for i in range(n_periods):
    model.addConstr(
        x[i] + x[(i - 1) % n_periods] >= demand[i],
        name=f"coverage_period_{i+1}"
    )

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal total number of drivers: {int(model.objVal)}")
    for i in range(n_periods):
        print(f"Number of drivers starting at period {i+1}: {int(x[i].x)}")
else:
    print("No optimal solution found.")
```
