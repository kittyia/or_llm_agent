【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Investment_Planning")

# Decision variables
x1 = model.addVar(lb=0, name="x1")
x2 = model.addVar(lb=0, name="x2")
x3 = model.addVar(lb=0, name="x3")
y  = model.addVar(lb=0, ub=150000, name="y")
z  = model.addVar(lb=0, ub=200000, name="z")
w  = model.addVar(lb=0, ub=100000, name="w")

# Objective function
model.setObjective(1.2 * x3 + 1.6 * z + 1.4 * w, GRB.MAXIMIZE)

# Constraints
model.addConstr(x1 + y <= 300000, name="Year1_Budget")
model.addConstr(x2 + z <= 1.2 * x1, name="Year2_Budget")
model.addConstr(x3 + w <= 1.2 * x2 + 1.5 * y, name="Year3_Budget")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Investment Plan:")
    print(f"x1 = {x1.X:.2f}")
    print(f"x2 = {x2.X:.2f}")
    print(f"x3 = {x3.X:.2f}")
    print(f"y  = {y.X:.2f}")
    print(f"z  = {z.X:.2f}")
    print(f"w  = {w.X:.2f}")
    print(f"Maximum Final Wealth = {model.objVal:.2f}")
else:
    print("No optimal solution found.")
```
