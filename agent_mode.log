【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# ----------------------------
# Sets
# ----------------------------
containers = range(1, 8)  # K = {1,...,7}
goods = ['A', 'B', 'C', 'D', 'E']

# ----------------------------
# Parameters
# ----------------------------
Q = {
    'A': 120,
    'B': 90,
    'C': 300,
    'D': 90,
    'E': 120
}

w = {
    'A': 0.5,
    'B': 1.0,
    'C': 0.4,
    'D': 0.6,
    'E': 0.65
}

W_max = 60
W_min = 18

# ----------------------------
# Model
# ----------------------------
model = gp.Model("Container_Packing_Min_Containers")

# Decision variables
x = model.addVars(goods, containers, vtype=GRB.INTEGER, lb=0, name="x")
y = model.addVars(containers, vtype=GRB.BINARY, name="y")

# ----------------------------
# Objective: Minimize number of used containers
# ----------------------------
model.setObjective(gp.quicksum(y[k] for k in containers), GRB.MINIMIZE)

# ----------------------------
# Constraints
# ----------------------------

# 1. Inventory fulfillment
for i in goods:
    model.addConstr(gp.quicksum(x[i, k] for k in containers) == Q[i],
                    name=f"Inventory_{i}")

# 2. Container capacity constraints
for k in containers:
    total_weight = gp.quicksum(w[i] * x[i, k] for i in goods)
    
    # Upper bound
    model.addConstr(total_weight <= W_max * y[k],
                    name=f"Capacity_UB_{k}")
    
    # Lower bound
    model.addConstr(total_weight >= W_min * y[k],
                    name=f"Capacity_LB_{k}")

# 3. A–C coupling constraint
for k in containers:
    model.addConstr(x['C', k] >= x['A', k],
                    name=f"A_C_Coupling_{k}")

# 4. Minimum D per used container
for k in containers:
    model.addConstr(x['D', k] >= 12 * y[k],
                    name=f"Min_D_{k}")

# ----------------------------
# Optimize
# ----------------------------
model.optimize()

# ----------------------------
# Output results
# ----------------------------
if model.status == GRB.OPTIMAL:
    print(f"\nMinimum number of containers used: {int(model.objVal)}\n")
    for k in containers:
        if y[k].x > 0.5:
            print(f"Container {k}:")
            total_weight = 0
            for i in goods:
                qty = int(x[i, k].x)
                if qty > 0:
                    print(f"  {i}: {qty}")
                    total_weight += w[i] * qty
            print(f"  Total weight: {total_weight:.2f} tons\n")
else:
    print("No optimal solution found.")
```
