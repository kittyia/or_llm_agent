    print("Optimal solution found:")
    print(f"x1 (3x3m pattern) = {int(x1.X)}")
    print(f"x2 (2x3m + 1x4m pattern) = {int(x2.X)}")
    print(f"x3 (2x4m pattern) = {int(x3.X)}")
    print(f"Minimum number of 10m raw bars used = {int(model.ObjVal)}")
else:
    print("No optimal solution found.")
