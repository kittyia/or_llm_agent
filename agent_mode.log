【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Inheritance_Partition")

# Item values (dogs combined as one item worth 6000)
values = [
    25000,  # Caillebotte painting
    5000,   # Diocletian bust
    20000,  # Yuan vase
    40000,  # Porsche 911
    12000,  # Diamond 1
    12000,  # Diamond 2
    12000,  # Diamond 3
    3000,   # Louis XV sofa
    6000,   # Two dogs (combined)
    10000,  # Sculpture (200 AD)
    15000,  # Sailing boat
    10000,  # Harley Davidson
    13000   # Cavour furniture
]

n = len(values)
V = sum(values)

# Decision variables
x = model.addVars(n, vtype=GRB.BINARY, name="x")
t = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="t")

# Expression for Son 1 total value
S1 = gp.quicksum(values[i] * x[i] for i in range(n))

# Constraints for absolute difference
model.addConstr(2 * S1 - V <= t, name="diff_pos")
model.addConstr(V - 2 * S1 <= t, name="diff_neg")

# Objective: minimize difference
model.setObjective(t, GRB.MINIMIZE)

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal difference: {t.X}")
    son1_value = sum(values[i] * x[i].X for i in range(n))
    son2_value = V - son1_value
    print(f"Son 1 total value: {son1_value}")
    print(f"Son 2 total value: {son2_value}")
    print("\nItems assigned to Son 1:")
    for i in range(n):
        if x[i].X > 0.5:
            print(f"  Item {i+1} (Value: {values[i]})")
    print("\nItems assigned to Son 2:")
    for i in range(n):
        if x[i].X <= 0.5:
            print(f"  Item {i+1} (Value: {values[i]})")
else:
    print("No optimal solution found.")
```
