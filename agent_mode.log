This is the **final recommended mathematical formulation** for implementation.
【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -------------------------
# Data
# -------------------------
types = range(6)

d = [500, 550, 700, 900, 400, 300]
c = [5, 8, 10, 12, 16, 18]
F = 1200

# -------------------------
# Model
# -------------------------
model = gp.Model("Red_Star_Plastics")

# Decision variables
x = model.addVars(types, vtype=GRB.CONTINUOUS, lb=0, name="x")
y = model.addVars(types, vtype=GRB.BINARY, name="y")

# Objective function
model.setObjective(
    gp.quicksum(c[i] * x[i] for i in types) +
    gp.quicksum(F * y[i] for i in types),
    GRB.MINIMIZE
)

# -------------------------
# Constraints
# -------------------------

# 1. Cumulative demand satisfaction constraints
for k in types:
    model.addConstr(
        gp.quicksum(x[j] for j in range(k, 6)) >= sum(d[i] for i in range(k, 6)),
        name=f"cum_demand_{k+1}"
    )

# 2. Equipment activation constraints (tight Big-M)
for i in types:
    M_i = sum(d[k] for k in range(i + 1))
    model.addConstr(
        x[i] <= M_i * y[i],
        name=f"activation_{i+1}"
    )

# -------------------------
# Solve
# -------------------------
model.optimize()

# -------------------------
# Output Results
# -------------------------
if model.status == GRB.OPTIMAL:
    print(f"\nOptimal Total Cost: {model.objVal:.2f}\n")
    for i in types:
        print(f"Type {i+1}: Production = {x[i].x:.2f}, Activated = {int(y[i].x)}")
else:
    print("No optimal solution found.")
```
