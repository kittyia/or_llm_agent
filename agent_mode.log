 ```python
import gurobipy as gp
from gurobipy import GRB

# Create model
model = gp.Model("Farm_Optimization")

# Decision variables
x1 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Soybeans_hectares")
x2 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Corn_hectares")
x3 = model.addVar(vtype=GRB.CONTINUOUS, lb=0, name="Wheat_hectares")

x4 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Dairy_cows")
x5 = model.addVar(vtype=GRB.INTEGER, lb=0, name="Chickens")

Ls = model.addVar(vtype=GRB.INTEGER, lb=0, name="External_labor_spring_summer")
La = model.addVar(vtype=GRB.INTEGER, lb=0, name="External_labor_autumn_winter")

# Objective function
model.setObjective(
    175 * x1 +
    300 * x2 +
    120 * x3 +
    400 * x4 +
    2 * x5 +
    2.1 * Ls +
    1.8 * La,
    GRB.MAXIMIZE
)

# Constraints

# Land constraint
model.addConstr(x1 + x2 + x3 + 1.5 * x4 <= 100, name="Land")

# Capital constraint
model.addConstr(400 * x4 + 3 * x5 <= 15000, name="Capital")

# Labor constraints (scaled by 10)
model.addConstr(
    500 * x1 + 750 * x2 + 400 * x3 + 500 * x4 + 3 * x5 + 10 * Ls <= 40000,
    name="Labor_Spring_Summer"
)

model.addConstr(
    200 * x1 + 350 * x2 + 100 * x3 + 1000 * x4 + 6 * x5 + 10 * La <= 35000,
    name="Labor_Autumn_Winter"
)

# Facility capacity constraints
model.addConstr(x4 <= 32, name="Cow_Barn_Capacity")
model.addConstr(x5 <= 3000, name="Chicken_Coop_Capacity")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Objective Value (Max Annual Net Income): {model.objVal:.2f}\n")
    for var in model.getVars():
        print(f"{var.varName}: {var.x}")
else:
    print("No optimal solution found.")
```
