model.addConstr(
    1.6 * x_A +
    2.5 * x_B +
    1.8 * x_C +
    3.0 * x_D <= 6,
    name="Budget"
)

# Mutual exclusivity constraint (A and D cannot both be selected)
model.addConstr(
    x_A + x_D <= 1,
    name="Mutual_Exclusivity_AD"
)

# Optimize model
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print("Optimal Solution Found")
    print(f"Maximum Annual Revenue: ${model.objVal:,.2f}")
    print("Purchase Decisions:")
    print(f"Restaurant A: {int(x_A.x)}")
    print(f"Restaurant B: {int(x_B.x)}")
    print(f"Restaurant C: {int(x_C.x)}")
    print(f"Restaurant D: {int(x_D.x)}")
else:
    print("No optimal solution found.")
