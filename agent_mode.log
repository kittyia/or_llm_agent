【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# Data
devices = ['A', 'B', 'C', 'D']
fixed_cost = {'A': 1000, 'B': 920, 'C': 800, 'D': 700}
unit_cost = {'A': 20, 'B': 24, 'C': 16, 'D': 28}
capacity = {'A': 900, 'B': 1000, 'C': 1200, 'D': 1600}
demand = 2000

# Create model
model = gp.Model("Device_Selection_Production_Planning")

# Decision variables
x = model.addVars(devices, lb=0, ub=capacity, vtype=GRB.CONTINUOUS, name="Production")
y = model.addVars(devices, vtype=GRB.BINARY, name="Enable")

# Objective function
model.setObjective(
    gp.quicksum(fixed_cost[i] * y[i] + unit_cost[i] * x[i] for i in devices),
    GRB.MINIMIZE
)

# Demand constraint
model.addConstr(gp.quicksum(x[i] for i in devices) == demand, name="Demand")

# Capacity linking constraints
for i in devices:
    model.addConstr(x[i] <= capacity[i] * y[i], name=f"Capacity_Link_{i}")

# Optimize
model.optimize()

# Output results
if model.status == GRB.OPTIMAL:
    print(f"Optimal Total Cost: {model.objVal:.2f}")
    print("\nProduction Plan:")
    for i in devices:
        print(f"Device {i}: Enable = {int(y[i].x)}, Production = {x[i].x:.2f}")
else:
    print("No optimal solution found.")
```
