x2 = model.addVar(vtype=GRB.INTEGER, lb=0, name="x2")  # Pattern 2: 2x3m + 1x4m
x3 = model.addVar(vtype=GRB.INTEGER, lb=0, name="x3")  # Pattern 3: 2x4m

