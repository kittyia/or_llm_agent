【Python Gurobi 代码】:
 ```python
import gurobipy as gp
from gurobipy import GRB

# -----------------------------
# Data
# -----------------------------
weeks = range(1, 9)
products = [1, 2]

S0 = 50

demand = {
    1: {1:10000, 2:10000, 3:12000, 4:12000, 5:16000, 6:16000, 7:20000, 8:20000},
    2: {1:6000, 2:7200, 3:8400, 4:10800, 5:10800, 6:12000, 7:12000, 8:12000}
}

penalty = {1:0.5, 2:0.6}

# -----------------------------
# Model
# -----------------------------
m = gp.Model("Factory_Production_Training")

# Workforce variables
R_S = m.addVars(weeks, vtype=GRB.INTEGER, name="R_S")   # skilled regular
O_S = m.addVars(weeks, vtype=GRB.INTEGER, name="O_S")   # skilled overtime
U   = m.addVars(weeks, vtype=GRB.INTEGER, name="U")     # trainers

R_N = m.addVars(weeks, vtype=GRB.INTEGER, name="R_N")   # trained regular
O_N = m.addVars(weeks, vtype=GRB.INTEGER, name="O_N")   # trained overtime

X = m.addVars(weeks, vtype=GRB.INTEGER, name="X")       # training start
T = m.addVars(weeks, vtype=GRB.INTEGER, name="T")       # trainees in training
G = m.addVars(weeks, vtype=GRB.INTEGER, name="G")       # graduates
N = m.addVars(weeks, vtype=GRB.INTEGER, name="N")       # trained workforce

# Production and backlog
x = m.addVars(products, weeks, vtype=GRB.CONTINUOUS, lb=0, name="x")
B = m.addVars(products, weeks, vtype=GRB.CONTINUOUS, lb=0, name="B")

# -----------------------------
# Constraints
# -----------------------------

# Skilled workforce fixed at 50
for t in weeks:
    m.addConstr(R_S[t] + O_S[t] + U[t] == S0)

# Training dynamics
for t in weeks:
    if t == 1:
        m.addConstr(T[t] == X[t])
    else:
        m.addConstr(T[t] == X[t] + X[t-1])

for t in weeks:
    if t <= 2:
        m.addConstr(G[t] == 0)
    else:
        m.addConstr(G[t] == X[t-2])

# Trained workforce balance
for t in weeks:
    if t == 1:
        m.addConstr(N[t] == G[t])
    else:
        m.addConstr(N[t] == N[t-1] + G[t])

# Training capacity
for t in weeks:
    m.addConstr(X[t] <= 3 * U[t])

# Total graduates must be 50
m.addConstr(gp.quicksum(G[t] for t in weeks) == 50)

# Allocation of trained workers
for t in weeks:
    m.addConstr(R_N[t] + O_N[t] == N[t])

# Production capacity (labor hour constraint)
for t in weeks:
    m.addConstr(
        x[1,t]/10 + x[2,t]/6
        <= 40*(R_S[t] + R_N[t]) + 60*(O_S[t] + O_N[t])
    )

# Demand and backlog balance
for p in products:
    for t in weeks:
        if t == 1:
            m.addConstr(B[p,t] == demand[p][t] - x[p,t])
        else:
            m.addConstr(B[p,t] == B[p,t-1] + demand[p][t] - x[p,t])

# -----------------------------
# Objective
# -----------------------------
obj = gp.quicksum(
    360*R_S[t] + 540*O_S[t] +
    240*R_N[t] + 360*O_N[t] +
    360*U[t] +
    120*T[t]
    for t in weeks
) + gp.quicksum(
    penalty[p] * B[p,t]
    for p in products for t in weeks
)

m.setObjective(obj, GRB.MINIMIZE)

# -----------------------------
# Solve
# -----------------------------
m.optimize()

# -----------------------------
# Output Results
# -----------------------------
if m.status == GRB.OPTIMAL:
    print(f"Optimal total cost: {m.objVal:.2f}\n")

    for t in weeks:
        print(f"Week {t}:")
        print(f"  Skilled - Regular: {R_S[t].x}, Overtime: {O_S[t].x}, Trainers: {U[t].x}")
        print(f"  Trained - Regular: {R_N[t].x}, Overtime: {O_N[t].x}")
        print(f"  Training Start: {X[t].x}, Trainees: {T[t].x}, Graduates: {G[t].x}, Total Trained Workforce: {N[t].x}")
        print(f"  Production I: {x[1,t].x:.2f}, Production II: {x[2,t].x:.2f}")
        print(f"  Backlog I: {B[1,t].x:.2f}, Backlog II: {B[2,t].x:.2f}")
        print("")
else:
    print("No optimal solution found.")
```
